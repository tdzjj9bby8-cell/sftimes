# Brief pipeline queue files. Generated by the cron jobs nightly.
# Excluded from git: these are operational state, not source.
# The audit-log/ subdirectory is also generated; ops can opt to commit it
# if a long-term audit trail in git is desired.

*-ingested.json
*-audited.json
*-decisions.json
audit-log/*.json

# Keep this gitignore tracked so the directory exists.
!.gitignore
