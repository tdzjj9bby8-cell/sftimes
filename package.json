{
  "name": "sftimes-astro",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "SF Times — static publication, built with Astro, deploys to SiteGround.",
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/check-placeholders.mjs --pre && node scripts/generate-responsive-heroes.mjs && astro build && node scripts/check-placeholders.mjs --post",
    "build:dev": "astro build",
    "preview": "astro preview",
    "migrate": "node scripts/migrate-articles.mjs",
    "responsive": "node scripts/generate-responsive-heroes.mjs",
    "subset-fonts": "node scripts/subset-fonts.mjs",
    "lighthouse": "node scripts/lighthouse-baseline.mjs",
    "guard": "node scripts/check-placeholders.mjs --post"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.7",
    "@astrojs/sitemap": "^3.2.0",
    "astro": "^4.16.0"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
