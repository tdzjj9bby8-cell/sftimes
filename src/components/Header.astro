---
export interface Props {
  variant?: 'transparent' | 'solid';
  current?: string;
}
const { variant = 'solid', current = '' } = Astro.props;

const nav = [
  { label: 'stories', href: '/stories' },
  { label: 'best of', href: '/best-of' },
  { label: 'hidden spots', href: '/hidden-spots' },
  { label: 'quizzes', href: '/quizzes' },
  { label: 'about', href: '/about' },
  { label: 'support', href: '/support' },
];
---

<header class={`site-header site-header--${variant}`} data-variant={variant}>
  <a class="skip-link" href="#main">Skip to content</a>
  <div class="site-header__inner container">
    <a class="site-header__wordmark" href="/" aria-label="the keepers. SF Times">
      <span class="wordmark-text">the keepers.</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {nav.map((item) => {
          const slug = item.label.replace(' ', '-');
          return (
            <li>
              <a
                href={item.href}
                class={`site-nav__link ${current === slug || current === item.label ? 'is-active' : ''}`}
              >{item.label}</a>
            </li>
          );
        })}
      </ul>
    </nav>
    <button class="site-header__menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile primary">
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    /* Background and border paint FIRST (120ms) so a solid surface is in place
       before the text color flips to dark (200ms). Eliminates the flicker
       where dark text would otherwise hover over still-transparent bg during
       the scroll-state transition. */
    transition: background 120ms var(--ease-out),
                border-color 120ms var(--ease-out),
                color 200ms var(--ease-out),
                padding 200ms var(--ease-out);
  }
  .site-header--solid {
    background: var(--bg);
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
  }
  /* Transparent variant lifts out of flow entirely so the hero photo runs
     edge-to-edge from the top of the viewport. On scroll past 60px the
     is-scrolled class flips it solid. */
  .site-header--transparent {
    position: fixed;
    left: 0;
    right: 0;
    background: transparent;
    color: var(--bg);
    border-bottom: 1px solid transparent;
  }
  .site-header--transparent.is-scrolled {
    background: var(--bg);
    color: var(--ink);
    border-bottom-color: var(--rule);
  }
  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--s-5);
    padding-block: var(--s-4);
  }
  .site-header--transparent .site-header__inner { padding-block: var(--s-5); }
  .site-header--transparent.is-scrolled .site-header__inner { padding-block: var(--s-3); }

  .site-header__wordmark {
    display: inline-flex;
    align-items: baseline;
    color: inherit;
  }
  .wordmark-text {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 2.2vw, 1.875rem);
    line-height: 1;
    letter-spacing: -0.025em;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }

  .site-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: flex-end;
    gap: var(--s-5);
  }
  .site-nav__link {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    color: inherit;
    position: relative;
    padding-block: 4px;
    opacity: 0.85;
    transition: opacity var(--t-fast) var(--ease-out);
  }
  .site-nav__link:hover, .site-nav__link.is-active { opacity: 1; }
  .site-nav__link::after {
    content: '';
    position: absolute;
    inset: auto 50% -2px 50%;
    height: 1px;
    background: currentColor;
    transition: inset var(--t-fast) var(--ease-out);
  }
  .site-nav__link:hover::after,
  .site-nav__link.is-active::after { inset: auto 0 -2px 0; }

  .site-header__menu-toggle {
    display: none;
    width: 36px;
    height: 36px;
    background: transparent;
    border: 0;
    padding: 0;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    color: inherit;
  }
  .site-header__menu-toggle span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: currentColor;
    transition: transform var(--t-fast) var(--ease-out), opacity var(--t-fast) var(--ease-out);
  }
  .mobile-menu {
    position: fixed;
    inset: 0 0 0 auto;
    width: min(82vw, 380px);
    background: var(--bg);
    color: var(--ink);
    transform: translateX(100%);
    transition: transform 300ms var(--ease-out);
    z-index: 99;
    padding: var(--s-9) var(--s-5);
  }
  .mobile-menu[aria-hidden="false"] { transform: none; }
  .mobile-menu ul { list-style: none; padding: 0; margin: 0; }
  .mobile-menu li + li { margin-top: var(--s-3); }
  .mobile-menu a {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.875rem;
    color: var(--ink);
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }

  @media (max-width: 880px) {
    .site-nav { display: none; }
    .site-header__menu-toggle { display: inline-flex; }
  }
</style>

<script>
  // Re-binds on every astro:page-load too. View Transitions don't re-run
  // inline scripts, so without this the scroll handler never attaches to the
  // newly-rendered header and the transparent variant stays white-text on a
  // paper body when you scroll down.
  function initHeader() {
    const header = document.querySelector<HTMLElement>('.site-header[data-variant="transparent"]');
    if (header && !header.dataset.scrollBound) {
      header.dataset.scrollBound = '1';
      const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 60);
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
    const toggle = document.querySelector<HTMLButtonElement>('.site-header__menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (toggle && menu && !toggle.dataset.menuBound) {
      toggle.dataset.menuBound = '1';
      toggle.addEventListener('click', () => {
        const open = menu.getAttribute('aria-hidden') === 'false';
        menu.setAttribute('aria-hidden', open ? 'true' : 'false');
        toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
      });
    }
  }
  initHeader();
  document.addEventListener('astro:page-load', initHeader);
</script>
