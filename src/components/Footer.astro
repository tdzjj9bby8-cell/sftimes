---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <span class="wordmark">SF Times</span>
      <p class="tagline">One San Francisco keeper every Saturday. Reader-funded. No parent company. No paywall. No AI bylines.</p>
    </div>
    <nav class="site-footer__nav" aria-label="Footer primary">
      <h4 class="ui-label">Read</h4>
      <ul>
        <li><a href="/stories">Stories</a></li>
        <li><a href="/best-of">Best Of</a></li>
        <li><a href="/hidden-spots">Hidden Spots</a></li>
        <li><a href="/quizzes">Quizzes</a></li>
      </ul>
    </nav>
    <nav class="site-footer__nav" aria-label="Footer trust">
      <h4 class="ui-label">Trust</h4>
      <ul>
        <li><a href="/standards">Standards</a></li>
        <li><a href="/corrections">Corrections</a></li>
        <li><a href="/partners">Partners</a></li>
        <li><a href="/about">About</a></li>
      </ul>
    </nav>
    <nav class="site-footer__nav" aria-label="Footer support">
      <h4 class="ui-label">Support</h4>
      <ul>
        <li><a href="/support">Donate</a></li>
        <li><a href="/submit">Submit a spot</a></li>
        <li><a href="/team">Team</a></li>
        <li><a href="/rss.xml">RSS</a></li>
      </ul>
    </nav>
  </div>
  <div class="site-footer__bottom container">
    <p class="mono">© {year} SF Times · Independent · Reader-supported · Made in San Mateo</p>
    <p class="mono">
      <a href="/privacy">Privacy</a>
      <span>·</span>
      <a href="/terms">Terms</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    padding-top: var(--s-8);
    margin-top: var(--s-10);
    background: var(--bg);
  }
  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: var(--s-7);
    padding-bottom: var(--s-8);
  }
  .site-footer__brand .wordmark {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
  }
  .site-footer__brand .tagline {
    margin-top: var(--s-3);
    max-width: 36ch;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .site-footer__nav h4 { margin-bottom: var(--s-3); }
  .site-footer__nav ul { list-style: none; margin: 0; padding: 0; }
  .site-footer__nav li + li { margin-top: var(--s-2); }
  .site-footer__nav a {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
  }
  .site-footer__nav a:hover { color: var(--terracotta); }
  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--s-5);
    border-top: 1px solid var(--rule);
    color: var(--fog);
  }
  .site-footer__bottom a { color: var(--fog); }
  .site-footer__bottom a:hover { color: var(--ink); }
  .site-footer__bottom span { margin-inline: var(--s-2); }

  @media (max-width: 880px) {
    .site-footer__inner { grid-template-columns: 1fr 1fr; }
    .site-footer__brand { grid-column: 1 / -1; }
    .site-footer__bottom { flex-direction: column; gap: var(--s-3); text-align: center; }
  }
</style>
