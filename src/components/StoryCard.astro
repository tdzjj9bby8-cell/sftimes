---
import Placeholder from './Placeholder.astro';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  story: CollectionEntry<'stories'>;
  size?: 'sm' | 'md' | 'lg';
}
const { story, size = 'md' } = Astro.props;
const { data } = story;
const url = `/stories/${data.url_slug}`;
const aspect = size === 'lg' ? '5:4' : size === 'sm' ? '4:3' : '5:4';
const dateStr = data.published.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---

<a class={`story-card story-card--${size} reveal`} href={url}>
  <div class="story-card__media">
    <Placeholder
      alt={data.hero_alt}
      filenameHint={data.hero_filename_hint}
      aspect={aspect}
      showLabel={false}
    />
  </div>
  <div class="story-card__meta">
    <span class="ui-label">Issue {data.issue} · {dateStr} · By {data.author}</span>
  </div>
  <h3 class="story-card__title">{data.title}</h3>
  {data.deck && <p class="story-card__deck">{data.deck}</p>}
</a>

<style>
  .story-card {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    color: var(--ink);
    cursor: pointer;
  }
  .story-card__media {
    overflow: hidden;
  }
  .story-card__media :global(.placeholder) {
    transition: transform var(--t-med) var(--ease-out);
  }
  .story-card:hover .story-card__media :global(.placeholder) {
    transform: scale(1.03);
  }
  .story-card__meta { color: var(--fog); }
  .story-card__title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.3vw, 1.25rem);
    line-height: 1.2;
    font-weight: 500;
    margin: 0;
  }
  .story-card__deck {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .story-card--lg .story-card__title { font-size: clamp(1.75rem, 3vw, 2.5rem); }
  .story-card--sm .story-card__deck { display: none; }
</style>
