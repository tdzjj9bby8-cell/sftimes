---
/**
 * Placeholder.astro
 * Renders a real image if one exists at the expected public path,
 * otherwise falls back to the neon-green placeholder block.
 *
 * The build guard still scans dist/ for #39FF14 and data-placeholder markers,
 * so any remaining green blocks will fail the production build.
 */
export interface Props {
  alt: string;
  filenameHint: string;
  aspect?: '5:4' | '4:3' | '3:4' | '16:9' | '1:1' | '21:9';
  rounded?: boolean;
  showLabel?: boolean;
  class?: string;
}

const {
  alt,
  filenameHint,
  aspect = '5:4',
  rounded = false,
  showLabel = true,
  class: className = '',
} = Astro.props;

const aspectMap: Record<string, string> = {
  '5:4': '5 / 4',
  '4:3': '4 / 3',
  '3:4': '3 / 4',
  '16:9': '16 / 9',
  '1:1': '1 / 1',
  '21:9': '21 / 9',
};
const aspectRatio = aspectMap[aspect];

// Derive the public image path from the filenameHint.
// filenameHint is like "heroes/2026-04-25-mrs-kim-tofu-house.jpg"
// or "best-of/korean-bbq-sf.jpg" or "team/eric.jpg"
// The processed images live at /heroes/*.jpg, /best-of/*.jpg, /team/*.jpg
const hintBase = filenameHint.replace(/\.[^.]+$/, '');
const imgSrc = `/${hintBase}.jpg`;

// At build time, check if the file exists in public/
import fs from 'node:fs';
import path from 'node:path';
const publicDir = path.resolve(process.cwd(), 'public');
const imgPath = path.join(publicDir, `${hintBase}.jpg`);
const hasRealImage = fs.existsSync(imgPath);
---

{hasRealImage ? (
  <img
    class={`real-image ${rounded ? 'real-image--rounded' : ''} ${className}`}
    src={imgSrc}
    alt={alt}
    loading="lazy"
    decoding="async"
    style={`aspect-ratio: ${aspectRatio}; object-fit: cover; width: 100%;`}
  />
) : (
  <figure
    class={`placeholder ${rounded ? 'placeholder--rounded' : ''} ${className}`}
    data-placeholder="true"
    data-alt={alt}
    data-filename-hint={filenameHint}
    data-aspect={aspect}
    role="img"
    aria-label={alt}
    style={`aspect-ratio: ${aspectRatio};`}
  >
    {showLabel && (
      <figcaption class="placeholder__label">
        <span class="placeholder__label-tag">PHOTO MISSING</span>
        <span class="placeholder__label-alt">{alt}</span>
        <span class="placeholder__label-hint">{filenameHint}</span>
      </figcaption>
    )}
  </figure>
)}

<style>
  .real-image {
    display: block;
    width: 100%;
    height: auto;
  }
  .real-image--rounded { border-radius: 999px; }
  .placeholder {
    margin: 0;
    background: var(--placeholder-green);
    width: 100%;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    color: #000;
    font-family: var(--font-ui);
  }
  .placeholder--rounded { border-radius: 999px; }
  .placeholder__label {
    width: 100%;
    padding: var(--s-3) var(--s-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
    background: linear-gradient(transparent, rgba(0,0,0,0.05));
    font-size: 0.6875rem;
    line-height: 1.4;
    letter-spacing: 0.04em;
  }
  .placeholder__label-tag {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .placeholder__label-alt {
    font-weight: 500;
    color: #000;
    opacity: 0.78;
  }
  .placeholder__label-hint {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: #000;
    opacity: 0.6;
  }
</style>
