<script is:inline>
  (function () {
    const toggle = document.getElementById('exMenuToggle');
    const drawer = document.getElementById('exDrawer');
    if (!toggle || !drawer) return;

    // Collect focusable elements inside the drawer for the tab trap.
    function focusables() {
      return Array.from(
        drawer.querySelectorAll('a[href], button, [tabindex]:not([tabindex="-1"])')
      ).filter((el) => !el.disabled && el.offsetParent !== null);
    }

    function setOpen(open) {
      drawer.classList.toggle('is-open', open);
      toggle.classList.toggle('is-open', open);
      drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');

      if (open) {
        // Move focus into the drawer so keyboard users land inside the open menu.
        const first = focusables()[0];
        if (first) setTimeout(() => first.focus(), 50);
      } else {
        // Return focus to the menu button when closing.
        toggle.focus();
      }
    }

    toggle.addEventListener('click', () => setOpen(!drawer.classList.contains('is-open')));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        setOpen(false);
        return;
      }
      // Tab trap: when the drawer is open, keep tab navigation inside it.
      if (e.key === 'Tab' && drawer.classList.contains('is-open')) {
        const items = focusables();
        if (items.length === 0) return;
        const first = items[0];
        const last = items[items.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    drawer.addEventListener('click', (e) => { if (e.target.tagName === 'A') setOpen(false); });
  })();

  (function () {
    const form = document.getElementById('exNlForm');
    const thanks = document.getElementById('exNlThanks');
    const errorEl = document.getElementById('exNlError');
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type=email]');
      const button = form.querySelector('button[type=submit]');
      const email = ((input || {}).value || '').trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (errorEl) { errorEl.textContent = 'ENTER A VALID EMAIL.'; errorEl.hidden = false; }
        return;
      }
      if (errorEl) errorEl.hidden = true;
      if (button) { button.disabled = true; button.textContent = 'Saving...'; }

      // Local fallback so captures aren't lost before ESP is wired.
      try {
        const KEY = 'keepers-newsletter';
        const arr = JSON.parse(localStorage.getItem(KEY) || '[]');
        arr.push({ email, at: new Date().toISOString(), page: location.pathname });
        localStorage.setItem(KEY, JSON.stringify(arr));
      } catch (_) {}

      // Endpoint placeholder. Wire to ESP (Buttondown, ConvertKit, Beehiiv) when ready.
      // Until then this just succeeds quietly so the UX is intact.
      try {
        await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: location.pathname }),
        }).catch(() => null);
      } catch (_) {}

      form.hidden = true;
      if (thanks) thanks.hidden = false;
    });
  })();

</script>
