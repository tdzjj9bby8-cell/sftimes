---
/**
 * ExhibitionLayout.astro
 * Shared chrome for every /* sample page.
 * Provides: utility bar, hamburger drawer, section nav, newsletter section,
 *           dark footer, all CSS tokens and shared styles.
 * Page content slots in via the default <slot/>.
 */
export interface Props {
  title: string;
  description?: string;
  active?: 'home' | 'stories' | 'best-of' | 'hidden-spots' | 'quizzes' | 'about' | 'support';
  /** Path to OG image. Defaults to the site brand image. Pass story hero filename
   *  hint for article pages, e.g. "heroes/2026-06-06-zareens-fourth-kitchen.jpg". */
  ogImage?: string;
  /** Page type. Defaults to "website", set "article" on individual story pages. */
  ogType?: 'website' | 'article';
}
const {
  title,
  description = 'One San Francisco keeper every Saturday. Reader-funded.',
  active = 'home',
  ogImage = 'og-image.svg',
  ogType = 'website',
} = Astro.props;

const SITE = 'https://sftimes.com';
const canonicalUrl = new URL(Astro.url.pathname, SITE).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${SITE}/${ogImage.replace(/^\//, '')}`;
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonicalUrl}>
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="alternate" type="application/rss+xml" title="SF Times · Saturday Letter" href="/rss.xml">

<!-- Open Graph -->
<meta property="og:type" content={ogType}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:url" content={canonicalUrl}>
<meta property="og:image" content={ogImageUrl}>
<meta property="og:site_name" content="SF Times · The Keepers">
<meta property="og:locale" content="en_US">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImageUrl}>

<link rel="preload" href="/fonts/anton/anton-regular.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/fonts/inter-tight/inter-tight-variable.woff2" as="font" type="font/woff2" crossorigin>

<!-- Schema.org: NewsMediaOrganization · sitewide. Tells Google AI Overviews
     and traditional crawlers that this is a real publication with named editors,
     a circulation model, and editorial standards. -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "NewsMediaOrganization",
  "@id": "https://sftimes.com/#org",
  "name": "SF Times",
  "alternateName": "The Keepers",
  "url": "https://sftimes.com",
  "logo": {
    "@type": "ImageObject",
    "url": "https://sftimes.com/og-image.svg",
    "width": 1200,
    "height": 630
  },
  "foundingDate": "2025",
  "publishingPrinciples": "https://sftimes.com/standards",
  "ethicsPolicy": "https://sftimes.com/standards",
  "actionableFeedbackPolicy": "https://sftimes.com/corrections",
  "diversityPolicy": "https://sftimes.com/standards",
  "correctionsPolicy": "https://sftimes.com/corrections",
  "areaServed": {
    "@type": "City",
    "name": "San Francisco",
    "containedInPlace": {
      "@type": "State",
      "name": "California"
    }
  },
  "sameAs": [
    "https://sftimes.com"
  ],
  "founder": {
    "@type": "Person",
    "name": "Eric",
    "jobTitle": "Founder, Editor"
  },
  "description": "One San Francisco keeper every Saturday morning. Reader-funded. Zero banner ads."
})} />

<!-- Schema.org: WebSite · enables sitelinks search box and named-entity context -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://sftimes.com/#website",
  "url": "https://sftimes.com",
  "name": "SF Times · The Keepers",
  "description": "A weekly San Francisco profile publication, reader-funded.",
  "publisher": { "@id": "https://sftimes.com/#org" },
  "inLanguage": "en-US"
})} />
<style is:global>
  /* Self-hosted display + UI faces. Replaces the previous jsDelivr CDN dependency. */
  @font-face {
    font-family: 'Anton';
    src: url('/fonts/anton/anton-regular.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }
  @font-face {
    font-family: 'Inter Tight Variable';
    src: url('/fonts/inter-tight/inter-tight-variable.woff2') format('woff2-variations');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }
  :root {
    --paper: #ebe6da;
    --paper-2: #e2ddcf;
    --ink: #0a0a0a;
    --ink-2: #1d1d1b;
    --rule: #bdb6a4;
    --muted: #6b6357;
    --accent: #d9551f;
    --display: 'Anton', 'Inter Tight Variable', sans-serif;
    --ui: 'Inter Tight Variable', system-ui, sans-serif;
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--paper); color: var(--ink); font-family: var(--ui); }
  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  button { font: inherit; cursor: pointer; background: none; border: 0; color: inherit; padding: 0; }

  /* === UTILITY TOP BAR === */
  .ex-util { display: grid; grid-template-columns: 60px 1fr auto; align-items: stretch; height: 48px; border-bottom: 1px solid var(--rule); }
  .ex-util__menu { display: flex; align-items: center; justify-content: center; border-right: 1px solid var(--rule); }
  .ex-util__menu div span { display: block; width: 18px; height: 1.5px; background: var(--ink); transition: transform 200ms; }
  .ex-util__menu div span + span { margin-top: 4px; }
  .ex-util__menu.is-open div span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .ex-util__menu.is-open div span:nth-child(2) { opacity: 0; }
  .ex-util__menu.is-open div span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }
  .ex-util__spacer { border-right: 1px solid var(--rule); }
  .ex-util__sub { display: flex; align-items: center; justify-content: center; gap: 8px; background: var(--ink); color: var(--paper); font-size: 13px; padding: 0 24px; }

  /* === DRAWER === */
  /* visibility:hidden when closed guarantees the giant link text never paints
     above the viewport edge as a phantom. transform alone isn't enough on
     some browsers; the translated element can still leak a 1-pixel slice. */
  .ex-drawer {
    position: fixed; inset: 48px 0 0 0; z-index: 100;
    background: var(--paper); overflow-y: auto;
    transform: translateY(-100%);
    visibility: hidden;
    opacity: 0;
    transition: transform 280ms cubic-bezier(0.16,1,0.3,1), opacity 220ms, visibility 0s linear 280ms;
  }
  .ex-drawer.is-open {
    transform: translateY(0);
    visibility: visible;
    opacity: 1;
    transition: transform 280ms cubic-bezier(0.16,1,0.3,1), opacity 220ms, visibility 0s linear 0s;
  }
  .ex-drawer__inner { padding: 64px 60px; display: grid; gap: 18px; max-width: 800px; }
  .ex-drawer a { font-family: var(--display); font-size: clamp(36px, 6vw, 80px); line-height: 1; text-transform: uppercase; color: var(--ink); letter-spacing: -0.005em; transition: opacity 150ms; }
  .ex-drawer a:hover { opacity: 0.5; }
  .ex-drawer__hint { font-family: var(--ui); font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-top: 32px; }
  .ex-drawer__group { display: grid; gap: 6px; margin-top: 4px; }
  .ex-drawer__group-label { font-family: var(--display); font-size: clamp(36px, 6vw, 80px); line-height: 1; text-transform: uppercase; color: var(--ink); letter-spacing: -0.005em; }
  .ex-drawer__sublink { font-family: var(--ui); font-size: 17px; font-weight: 500; color: var(--ink); padding-left: 6px; letter-spacing: 0.01em; text-transform: none; transition: opacity 150ms; }
  .ex-drawer__sublink:hover { opacity: 0.55; }

  /* === SECTION NAV === */
  /* Desktop: 7-item grid with padding column. Mobile: horizontal scroll
     so labels never wrap to two lines. */
  .ex-secnav { display: grid; grid-template-columns: 60px repeat(7, 1fr); border-top: 2px solid var(--ink); border-bottom: 1px solid var(--rule); height: 56px; align-items: center; }
  .ex-secnav__pad { border-right: 1px solid var(--rule); height: 100%; }
  .ex-secnav__item { padding: 0 20px; font-size: 14px; color: var(--ink); position: relative; transition: opacity 150ms; white-space: nowrap; }
  .ex-secnav__item:hover { opacity: 0.6; }
  .ex-secnav__item.is-active::after { content: ''; position: absolute; left: 20px; right: 20px; bottom: -1px; height: 2px; background: var(--ink); }

  /* === SHARED GIANT-WORDMARK BAND (used by ExhibitionMasthead) === */
  .ex-masthead {
    padding: 16px 0 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    overflow: hidden;             /* contain any SVG text spill */
  }
  .ex-masthead__svg {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: 0 12px;
    overflow: hidden;             /* explicit; Chrome treats SVG overflow inconsistently */
    /* Big and dominant. Eric wants the wordmark to own the top of the page. */
    max-height: clamp(180px, 24vw, 320px);
    height: auto;
  }
  .ex-masthead__sub {
    align-self: flex-end;
    margin: 0 28px 0 0;
    padding: 0;
    font-family: var(--display);
    font-size: clamp(16px, 2vw, 28px);
    letter-spacing: 0.06em;
    line-height: 1;
    color: var(--ink);
    /* Anton has no italic axis. Skew gives editorial slant. */
    transform: skewX(-10deg);
    transform-origin: right baseline;
  }

  /* === GIANT WORDMARK STRIP (used inside pages as section divider) === */
  .ex-colmark { padding: 56px 12px 28px; }
  .ex-colmark__text { font-family: var(--display); font-size: clamp(48px, 9vw, 130px); line-height: 0.95; letter-spacing: -0.005em; text-transform: uppercase; margin: 0; color: var(--ink); }
  .ex-colmark__link { color: var(--ink); display: block; transition: opacity 200ms; }
  .ex-colmark__link:hover { opacity: 0.7; }

  /* === GENERIC PROSE CONTENT BLOCK (used by text-heavy pages) === */
  .ex-prose { padding: 56px 12px; max-width: 880px; margin: 0 auto; }
  .ex-prose__eyebrow { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0 0 16px; }
  .ex-prose__title {
    font-family: var(--display);
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1; text-transform: uppercase;
    letter-spacing: -0.005em;
    margin: 0 0 24px;
  }
  .ex-prose p {
    font-size: clamp(16px, 1.2vw, 18px);
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 18px;
    max-width: 64ch;
  }
  .ex-prose h2 {
    font-family: var(--display);
    font-size: clamp(28px, 3vw, 44px);
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.005em;
    margin: 56px 0 18px;
  }
  .ex-prose h3 {
    font-family: var(--ui);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 600;
    margin: 32px 0 12px;
  }
  .ex-prose ol, .ex-prose ul { padding-left: 1.4em; }
  .ex-prose li { font-size: 16px; line-height: 1.6; color: var(--ink); margin: 0 0 8px; }
  .ex-prose a { color: var(--ink); border-bottom: 1px solid currentColor; padding-bottom: 1px; }
  .ex-prose a:hover { opacity: 0.7; }

  /* === SHARED CARD GRID === */
  .ex-cards { display: grid; gap: 12px; padding: 0 12px 48px; }
  .ex-cards--3 { grid-template-columns: repeat(3, 1fr); }
  .ex-cards--2 { grid-template-columns: repeat(2, 1fr); }
  .ex-card { color: var(--ink); display: block; }
  .ex-card__media { background: #2a2520; aspect-ratio: 4/3; overflow: hidden; }
  .ex-card__media :global(.real-image),
  .ex-card__media :global(.placeholder) {
    width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block;
    transition: transform 500ms;
  }
  .ex-card:hover .ex-card__media :global(.real-image),
  .ex-card:hover .ex-card__media :global(.placeholder) { transform: scale(1.03); }
  .ex-card__meta { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 10px 0 4px; display: flex; align-items: center; gap: 8px; }
  .ex-card__title { font-family: var(--ui); font-size: 18px; font-weight: 600; line-height: 1.2; margin: 0 0 6px; }
  .ex-card__deck { font-size: 13px; line-height: 1.45; color: var(--muted); margin: 0; }

  /* === TEXT-FIRST CARD (PATH A) ===
     Used on /stories, /best-of, and Read Next blocks. No photo column.
     Issue number watermark + keeper-typed top stripe + display headline. */
  .ex-card--text {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--rule);
    padding: 22px 24px 24px;
    overflow: hidden;
    transition: background 200ms, transform 200ms;
    color: var(--ink);
  }
  .ex-card--text:hover { background: var(--paper-2); transform: translateY(-2px); }
  .ex-card--text::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
    background: var(--accent);
  }
  .ex-card--keeper-routine.ex-card--text::before { background: #2c5582; }
  .ex-card--keeper-room.ex-card--text::before { background: var(--muted); }
  .ex-card--keeper-record.ex-card--text::before { background: var(--ink-2); }
  .ex-card--keeper-refusal.ex-card--text::before { background: #a82919; }
  .ex-card__issue-bg {
    position: absolute;
    right: -8px;
    top: 4px;
    font-family: var(--display);
    font-size: 64px;
    line-height: 1;
    color: rgba(189, 182, 164, 0.35);
    letter-spacing: -0.03em;
    pointer-events: none;
    user-select: none;
  }
  .ex-card--text .ex-card__tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin: 6px 0 14px;
    position: relative;
    z-index: 1;
  }
  .ex-card--text .ex-card__keeper,
  .ex-card--text .ex-card__neighborhood {
    display: inline-block;
    font-family: var(--ui);
    font-size: 9.5px;
    letter-spacing: 0.16em;
    font-weight: 700;
    text-transform: uppercase;
    padding: 3px 8px;
  }
  .ex-card--text .ex-card__keeper {
    background: var(--accent);
    color: var(--paper);
  }
  .ex-card--keeper-routine.ex-card--text .ex-card__keeper { background: #2c5582; }
  .ex-card--keeper-room.ex-card--text .ex-card__keeper { background: var(--muted); }
  .ex-card--keeper-record.ex-card--text .ex-card__keeper { background: var(--ink-2); }
  .ex-card--keeper-refusal.ex-card--text .ex-card__keeper { background: #a82919; }
  .ex-card--text .ex-card__neighborhood {
    background: var(--paper-2);
    color: var(--ink);
    border: 1px solid var(--rule);
  }
  .ex-card--text .ex-card__title {
    font-family: var(--display);
    font-size: clamp(20px, 2.4vw, 26px);
    line-height: 1.1;
    letter-spacing: -0.005em;
    margin: 0 0 12px;
    color: var(--ink);
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }
  .ex-card--text .ex-card__deck {
    font-family: var(--body);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 16px;
    font-style: italic;
    position: relative;
    z-index: 1;
  }
  .ex-card--text .ex-card__meta {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--muted);
    margin: 0;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }

  /* === NEWSLETTER === */
  .ex-nl { background: var(--ink); color: var(--paper); padding: 48px 28px 56px; }
  .ex-nl__inner { max-width: 56rem; margin: 0 auto; }
  .ex-nl__eyebrow { font-family: var(--ui); font-size: 11px; letter-spacing: 0.18em; font-weight: 700; text-transform: uppercase; color: var(--accent); margin: 0 0 18px; }
  .ex-nl__hed { font-family: var(--display); font-size: clamp(36px, 6vw, 72px); line-height: 0.96; letter-spacing: -0.01em; text-transform: uppercase; color: var(--paper); margin: 0 0 18px; }
  .ex-nl__deck { font-family: var(--body); font-size: 16px; line-height: 1.55; color: rgba(244,241,234,0.78); font-style: italic; margin: 0 0 28px; max-width: 52ch; }
  .ex-nl form { display: flex; align-items: stretch; gap: 0; max-width: 480px; }
  .ex-nl input { flex: 1; padding: 14px 18px; background: transparent; border: 1px solid rgba(244,241,234,0.3); color: var(--paper); font-family: var(--ui); font-size: 14px; border-radius: 0; }
  .ex-nl input::placeholder { color: rgba(244,241,234,0.5); text-transform: uppercase; letter-spacing: 0.1em; font-size: 12px; }
  .ex-nl button { padding: 14px 28px; background: var(--paper); color: var(--ink); font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; border: 1px solid var(--paper); transition: opacity 150ms; font-weight: 700; cursor: pointer; }
  .ex-nl button:hover { opacity: 0.85; }
  .ex-nl button:disabled { opacity: 0.5; cursor: wait; }
  .ex-nl__thanks { font-family: var(--display); font-size: clamp(24px, 3vw, 32px); text-transform: uppercase; padding: 18px 0 4px; color: var(--accent); margin: 0; }
  .ex-nl__error { font-family: var(--ui); font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: #e89a72; padding: 12px 0 0; margin: 0; }
  .ex-nl__fineprint { font-family: var(--ui); font-size: 11px; letter-spacing: 0.06em; color: rgba(244,241,234,0.5); margin: 20px 0 0; max-width: 52ch; }

  /* === FOOTER === */
  .ex-ft { background: var(--ink); color: var(--paper); }
  .ex-ft__discover {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 28px 36px;
    padding: 48px 28px 32px;
    border-top: 1px solid rgba(244,241,234,0.12);
  }
  @media (max-width: 880px) { .ex-ft__discover { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .ex-ft__discover { grid-template-columns: 1fr; } }
  .ex-ft__discover-label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(244,241,234,0.55); margin: 0 0 16px; font-weight: 700; }
  .ex-ft__discover ul { list-style: none; padding: 0; margin: 0; }
  .ex-ft__discover li { padding: 5px 0; }
  .ex-ft__discover a { font-size: 13px; color: rgba(244,241,234,0.9); transition: color 150ms; }
  .ex-ft__discover a:hover { color: var(--paper); }

  .ex-ft__row { display: grid; grid-template-columns: 1fr 1fr 1fr; align-items: center; padding: 28px; border-top: 1px solid rgba(244,241,234,0.12); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; }
  .ex-ft__row > div:nth-child(2) { text-align: center; color: rgba(244,241,234,0.6); }
  .ex-ft__row > div:last-child { text-align: right; }
  .ex-ft__bottom { display: grid; grid-template-columns: 1fr 1fr 1fr; padding: 18px 28px; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(244,241,234,0.7); }
  .ex-ft__bottom > div:nth-child(2) { text-align: center; text-decoration: underline; }
  .ex-ft__bottom > div:last-child { text-align: right; }

  @media (max-width: 980px) {
    .ex-util { grid-template-columns: 48px 1fr auto; }
    .ex-secnav { grid-template-columns: 48px repeat(7, 1fr); }
    .ex-secnav__item { padding: 0 14px; font-size: 12px; }
    .ex-drawer__inner { padding: 40px 24px; }
    .ex-cards--3 { grid-template-columns: repeat(2, 1fr); }
  }
  /* Very small screens: convert section nav to horizontal scroll so labels stay one line. */
  @media (max-width: 640px) {
    .ex-secnav {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      height: 48px;
    }
    .ex-secnav::-webkit-scrollbar { display: none; }
    .ex-secnav__pad { display: none; }
    .ex-secnav__item {
      flex: 0 0 auto;
      padding: 0 16px;
      font-size: 13px;
      line-height: 48px;
    }
    .ex-secnav__item:first-of-type { padding-left: 18px; }
    .ex-secnav__item:last-of-type { padding-right: 24px; }
    .ex-secnav__item.is-active::after { left: 16px; right: 16px; }
    .ex-cards--3, .ex-cards--2 { grid-template-columns: 1fr; }
    /* Tighter masthead band on small screens so the wordmark + subscript fit without dominating */
    .ex-masthead { padding: 12px 0 8px; gap: 2px; }
    .ex-masthead__svg { max-height: clamp(80px, 22vw, 140px); padding: 0 14px; }
    .ex-masthead__sub { font-size: clamp(14px, 4vw, 22px); margin: 0 16px 0 0; }
    /* Footer discover grid: single column on tiny screens for thumb scrolling */
    .ex-ft__discover { padding: 32px 18px 24px; gap: 24px; }
  }
</style>
<slot name="head" />
</head>
<body>

<div class="ex-util">
  <button class="ex-util__menu" id="exMenuToggle" aria-label="Menu" aria-expanded="false"><div><span></span><span></span><span></span></div></button>
  <div class="ex-util__spacer"></div>
  <a class="ex-util__sub" href="/partners#contact">Get in Touch <span aria-hidden="true">↗</span></a>
</div>

<aside class="ex-drawer" id="exDrawer" aria-hidden="true">
  <div class="ex-drawer__inner">
    <a href="/">HOME</a>
    <a href="/stories">FEATURES</a>
    <a href="/best-of">TOP TIER</a>
    <a href="/hidden-spots">UNPUBLISHED</a>
    <a href="/quizzes">CHECKUPS</a>
    <a href="/about">WHO WE ARE</a>
    <a href="/support">KEEP IT ALIVE</a>
    <div class="ex-drawer__group">
      <span class="ex-drawer__group-label">WORK WITH US</span>
