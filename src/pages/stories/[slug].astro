---
import ExhibitionLayout from '../../layouts/ExhibitionLayout.astro';
import AuthorAvatar from '../../components/AuthorAvatar.astro';
import { getCollection } from 'astro:content';

/**
 * Saturday Profile permalink, text-first hero.
 *
 * Path A from the photography discussion (2026-06-13): real photographs
 * carry the visual weight when we have them. Until then the typography
 * does. AI-generated imagery undermines the editorial firewall on
 * /standards which calls for reportorial, available-light, on-location
 * photography. The fix is no images until real ones exist.
 *
 * Each story gets a typographic hero anchored by the issue number set
 * large, the keeper_type pill colored by category, the headline at
 * display scale, the deck below, and the byline with avatar.
 *
 * When a real photo lands on a story (via a new `hero_photo` field that
 * does NOT default to a placeholder), the template will conditionally
 * render the photo + overlay treatment alongside the typography. For
 * now no photo path exists; the typography stands alone.
 */

// One Exhibition-styled article page per story. Body comes from the markdown
// via s.render(); read-next cards come from the three next most-recent stories.
export async function getStaticPaths() {
  const all = (await getCollection('stories')).sort(
    (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
  );
  return all.map((s) => ({
    params: { slug: s.data.url_slug },
    props: {
      story: s,
      more: all.filter((x) => x.slug !== s.slug).slice(0, 3),
    },
  }));
}

const { story: s, more } = Astro.props;
const { Content } = await s.render();
const dateLong = s.data.published
  .toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  .toUpperCase();

// Schema.org Article payload. Tells crawlers + AI Overviews the story metadata,
// author identity, sponsor (when present), and content classification.
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "@id": `https://www.sftimes.com/stories/${s.data.url_slug}#article`,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.sftimes.com/stories/${s.data.url_slug}`
  },
  "headline": s.data.title,
  "description": s.data.deck,
  "datePublished": s.data.published.toISOString().slice(0, 10),
  "dateModified": s.data.published.toISOString().slice(0, 10),
  "author": {
    "@type": "Person",
    "name": s.data.author,
    "url": `https://www.sftimes.com/team#${s.data.author.toLowerCase()}`
  },
  "publisher": { "@id": "https://www.sftimes.com/#org" },
  "articleSection": s.data.keeper_type || "Profile",
  "wordCount": Math.round(s.data.read_minutes * 220),
  "inLanguage": "en-US",
  "isAccessibleForFree": true,
  ...(s.data.neighborhood && {
    "contentLocation": {
      "@type": "Place",
      "name": `${s.data.neighborhood}, San Francisco`
    }
  }),
  ...(s.data.sponsor && {
    "sponsor": {
      "@type": "Organization",
      "name": s.data.sponsor.name,
      ...(s.data.sponsor.url && { "url": s.data.sponsor.url })
    }
  })
};
---
<ExhibitionLayout
  title={`${(s.data.seo_title || s.data.title).toUpperCase()} · The Keepers · SF Times`}
  description={s.data.deck}
  active="stories"
  ogType="article"
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />

  {s.data.is_sample && (
    <aside class="story-sample-banner" aria-label="Illustrative sample disclosure">
      <p class="story-sample-banner__label">ILLUSTRATIVE SAMPLE · NOT REPORTED JOURNALISM</p>
      <p class="story-sample-banner__body">This piece is a format example used to demonstrate the SF Times sponsored article structure. The subject, named characters, direct quotes, and reporter-presence scenes are constructed to show what a published piece looks like. They are not the result of an actual interview or reporting trip. Published pieces under SF Times bylines meet the standards on the <a href="/standards">standards page</a>; this one does not, and is labeled accordingly.</p>
    </aside>
  )}

  <!-- HERO · TYPOGRAPHIC (PATH A, text-first) -->
  <section class={`story-hero story-hero--text story-hero--keeper-${s.data.keeper_type || 'default'}`} aria-label="Story hero">
    <span class="story-hero__issue-bg" aria-hidden="true">№{String(s.data.issue).padStart(2, '0')}</span>
    <div class="story-hero__stripe" aria-hidden="true"></div>
    <div class="story-hero__inner">
      <div class="story-hero__tags">
        {s.data.sponsor && (
          <span class="story-hero__sponsor">IN COLLABORATION WITH <strong>{s.data.sponsor.name.toUpperCase()}</strong></span>
        )}
        {s.data.keeper_type && (
          <span class="story-hero__keeper">{s.data.keeper_type.toUpperCase()}</span>
        )}
        {s.data.neighborhood && (
          <span class="story-hero__neighborhood">{s.data.neighborhood.toUpperCase()}</span>
        )}
      </div>

      <p class="story-hero__eyebrow">ISSUE №{s.data.issue} · {dateLong} · {s.data.read_minutes}-MIN READ</p>
      <h1 class="story-hero__title">{s.data.title}</h1>
      <p class="story-hero__deck">{s.data.deck}</p>

      <p class="story-hero__byline">
        <AuthorAvatar name={s.data.author} size={28} />
        <span>BY {s.data.author.toUpperCase()}</span>
      </p>
    </div>
  </section>

  <!-- SPONSOR DISCLOSURE STRIP: editorial firewall language, full-bleed -->
  {s.data.sponsor && (
    <aside class="story-firewall" aria-label="Editorial firewall disclosure">
      <p class="story-firewall__label">EDITORIAL FIREWALL · IN COLLABORATION WITH {s.data.sponsor.name.toUpperCase()}</p>
      <p class="story-firewall__body">
        This story was commissioned as part of a paid editorial partnership with {s.data.sponsor.name}.
        {s.data.sponsor.url && (<> Visit them at <a href={s.data.sponsor.url} rel="sponsored noopener" target="_blank">{s.data.sponsor.url.replace(/^https?:\/\//, '')}</a>.</>)}
        Sponsor approved facts. The editor wrote every word. We do not run sponsored content we cannot honestly stand behind.
        <a class="story-firewall__more" href="/partners">How partnerships work →</a>
      </p>
    </aside>
  )}

  <!-- DECK -->
  <article class="ex-prose">
    <p class="story-deck">{s.data.deck}</p>
  </article>

  <!-- BODY (real markdown from the story file) -->
  <article class="ex-prose">
    <Content />
  </article>

  <!-- PULL QUOTE: uses typographic curly quotes -->
  {s.data.pull_quote && (
    <article class="ex-prose">
      <blockquote class="story-pull">
        <p>&ldquo;{s.data.pull_quote}&rdquo;</p>
        {s.data.pull_quote_attr && <cite>{s.data.pull_quote_attr.toUpperCase()}</cite>}
      </blockquote>
    </article>
  )}

  <!-- FOOT-OF-ARTICLE SPONSOR REMINDER (only on sponsored pieces) -->
  {s.data.sponsor && (
    <aside class="story-firewall story-firewall--foot" aria-label="Editorial firewall disclosure">
      <p class="story-firewall__label">END OF SPONSORED FEATURE</p>
      <p class="story-firewall__body">
        Brought to you in partnership with {s.data.sponsor.name}. The editor maintained full control of the angle and copy.
        Interested in your own collaboration? <a href="/partners#stories">See Profile packages →</a>
      </p>
    </aside>
  )}

  <!-- WORK WITH THE KEEPERS: 4 conversion paths surfaced above Read Next -->
  <section class="work-with-keepers" aria-label="Work with the keepers">
    <p class="work-with-keepers__eyebrow">WORK WITH THE KEEPERS</p>
    <div class="work-with-keepers__grid">
      <a href="/partners" class="work-with-keepers__card">
        <h3>Partner packages</h3>
        <p>Sponsor a saturday, a profile, a season, or a year. Real editorial firewall.</p>
      </a>
      <a href="/tell-your-story" class="work-with-keepers__card">
        <h3>Tell us your story</h3>
        <p>Operator, keeper, regular, kid with a paper route. Pitch us what you know.</p>
      </a>
      <a href="/submit" class="work-with-keepers__card">
        <h3>Send a tip</h3>
        <p>Anonymous if you want. We chase every one we can verify.</p>
      </a>
      <a href="/team#hiring" class="work-with-keepers__card">
        <h3>We're hiring</h3>
        <p>Student journalism roles. Paid. SF or Bay Area. See the open list.</p>
      </a>
    </div>
  </section>

  <!-- READ NEXT -->
  <a href="/stories" class="ex-colmark__link">
    <section class="ex-colmark">
      <h2 class="ex-colmark__text">READ NEXT</h2>
    </section>
  </a>

  <section class="ex-cards ex-cards--3">
    {more.map((m) => (
      <a class={`ex-card ex-card--text ex-card--keeper-${m.data.keeper_type || 'default'}`} href={`/stories/${m.data.url_slug}`}>
        <span class="ex-card__issue-bg" aria-hidden="true">№{String(m.data.issue).padStart(2, '0')}</span>
        <div class="ex-card__tags">
          {m.data.keeper_type && (
            <span class="ex-card__keeper">{m.data.keeper_type.toUpperCase()}</span>
          )}
          {m.data.neighborhood && (
            <span class="ex-card__neighborhood">{m.data.neighborhood.toUpperCase()}</span>
          )}
        </div>
        <h3 class="ex-card__title">{m.data.title}</h3>
        <p class="ex-card__deck">{m.data.deck}</p>
        <p class="ex-card__meta">
          <AuthorAvatar name={m.data.author} size={20} />
          <span>BY {m.data.author.toUpperCase()} · {m.data.read_minutes}-MIN READ</span>
        </p>
      </a>
    ))}
  </section>

  <style>
    /* ============ STORY HERO · TYPOGRAPHIC (PATH A) ============
       Photo-led hero replaced with display-type hero. The issue number
       sits in the background at massive scale, a colored stripe runs
       the top edge, the title takes 6 to 12 vw of vertical space.
       Each keeper_type gets a distinct stripe color. */
    .story-hero {
      position: relative;
      margin: 0;
      padding: 64px 28px 56px;
      background: var(--paper-2);
      overflow: hidden;
      border-bottom: 1px solid var(--rule);
    }
    .story-hero__inner {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
    }
    .story-hero__issue-bg {
      position: absolute;
      right: -6vw;
      top: 30%;
      transform: translateY(-50%);
      font-family: var(--display);
      font-size: clamp(180px, 28vw, 380px);
      line-height: 0.85;
      color: rgba(189, 182, 164, 0.35);
      letter-spacing: -0.04em;
      z-index: 0;
      pointer-events: none;
      user-select: none;
    }
    .story-hero__stripe {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 8px;
      background: var(--accent);
      z-index: 2;
    }
    .story-hero--keeper-recipe .story-hero__stripe { background: var(--accent); }
    .story-hero--keeper-routine .story-hero__stripe { background: #2c5582; }
    .story-hero--keeper-room .story-hero__stripe { background: var(--muted); }
    .story-hero--keeper-record .story-hero__stripe { background: var(--ink-2); }
    .story-hero--keeper-refusal .story-hero__stripe { background: #a82919; }
    .story-hero--keeper-default .story-hero__stripe { background: var(--accent); }

    .story-hero__tags {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 24px;
    }
    .story-hero__sponsor {
      display: inline-block;
      background: var(--accent);
      color: var(--paper);
      padding: 5px 12px;
      font-family: var(--ui);
      font-size: 10px;
      letter-spacing: 0.18em;
      font-weight: 700;
      text-transform: uppercase;
    }
    .story-hero__sponsor strong { font-weight: 700; }
    .story-hero__keeper,
    .story-hero__neighborhood {
      display: inline-block;
      background: var(--paper);
      color: var(--ink);
      padding: 5px 12px;
      font-family: var(--ui);
      font-size: 10px;
      letter-spacing: 0.18em;
      font-weight: 700;
      text-transform: uppercase;
      border: 1px solid var(--rule);
    }
    .story-hero__keeper {
      background: var(--accent);
      color: var(--paper);
      border-color: var(--accent);
    }
    .story-hero--keeper-routine .story-hero__keeper { background: #2c5582; border-color: #2c5582; }
    .story-hero--keeper-room .story-hero__keeper { background: var(--muted); border-color: var(--muted); }
    .story-hero--keeper-record .story-hero__keeper { background: var(--ink-2); border-color: var(--ink-2); }
    .story-hero--keeper-refusal .story-hero__keeper { background: #a82919; border-color: #a82919; }

    .story-hero__eyebrow {
      font-family: var(--ui);
      font-size: 11px;
      letter-spacing: 0.18em;
      color: var(--muted);
      margin: 0 0 18px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .story-hero__title {
      font-family: var(--display);
      font-size: clamp(40px, 7vw, 92px);
      line-height: 0.96;
      letter-spacing: -0.015em;
      margin: 0 0 24px;
      color: var(--ink);
      text-transform: uppercase;
      max-width: 22ch;
    }
    .story-hero__deck {
      font-family: var(--body);
      font-size: clamp(18px, 2vw, 24px);
      line-height: 1.45;
      color: var(--ink-2);
      margin: 0 0 28px;
      max-width: 52ch;
      font-style: italic;
    }
    .story-hero__byline {
      font-family: var(--ui);
      font-size: 12px;
      letter-spacing: 0.14em;
      color: var(--muted);
      margin: 0;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
      font-weight: 700;
      text-transform: uppercase;
      padding-top: 18px;
      border-top: 1px solid var(--rule);
    }

    @media (max-width: 640px) {
      .story-hero { padding: 40px 20px 36px; }
      .story-hero__issue-bg { font-size: clamp(140px, 50vw, 240px); top: 22%; right: -10vw; }
      .story-hero__title { font-size: clamp(32px, 11vw, 52px); }
      .story-hero__deck { font-size: 16px; }
    }

    /* ============ TEXT-FIRST EX-CARDS for Read Next ============ */
    .ex-card--text {
      position: relative;
      display: block;
      background: var(--paper);
      border: 1px solid var(--rule);
      padding: 22px 24px 24px;
      overflow: hidden;
      transition: background 200ms, transform 200ms;
      color: var(--ink);
    }
    .ex-card--text:hover {
      background: var(--paper-2);
      transform: translateY(-2px);
    }
    .ex-card--text::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 4px;
      background: var(--accent);
    }
    .ex-card--keeper-routine.ex-card--text::before { background: #2c5582; }
    .ex-card--keeper-room.ex-card--text::before { background: var(--muted); }
    .ex-card--keeper-record.ex-card--text::before { background: var(--ink-2); }
    .ex-card--keeper-refusal.ex-card--text::before { background: #a82919; }
    .ex-card__issue-bg {
      position: absolute;
      right: -8px;
      top: 4px;
      font-family: var(--display);
      font-size: 64px;
      line-height: 1;
      color: rgba(189, 182, 164, 0.35);
      letter-spacing: -0.03em;
      pointer-events: none;
      user-select: none;
    }
    .ex-card--text .ex-card__tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin: 6px 0 14px;
      position: relative;
      z-index: 1;
    }
    .ex-card--text .ex-card__keeper,
    .ex-card--text .ex-card__neighborhood {
      display: inline-block;
      font-family: var(--ui);
      font-size: 9.5px;
      letter-spacing: 0.16em;
      font-weight: 700;
      text-transform: uppercase;
      padding: 3px 8px;
    }
    .ex-card--text .ex-card__keeper {
      background: var(--accent);
      color: var(--paper);
    }
    .ex-card--keeper-routine.ex-card--text .ex-card__keeper { background: #2c5582; }
    .ex-card--keeper-room.ex-card--text .ex-card__keeper { background: var(--muted); }
    .ex-card--keeper-record.ex-card--text .ex-card__keeper { background: var(--ink-2); }
    .ex-card--keeper-refusal.ex-card--text .ex-card__keeper { background: #a82919; }
    .ex-card--text .ex-card__neighborhood {
      background: var(--paper-2);
      color: var(--ink);
      border: 1px solid var(--rule);
    }
    .ex-card--text .ex-card__title {
      font-family: var(--display);
      font-size: clamp(20px, 2.4vw, 26px);
      line-height: 1.1;
      letter-spacing: -0.005em;
      margin: 0 0 12px;
      color: var(--ink);
      text-transform: uppercase;
      position: relative;
      z-index: 1;
    }
    .ex-card--text .ex-card__deck {
      font-family: var(--body);
      font-size: 14px;
      line-height: 1.55;
      color: var(--ink-2);
      margin: 0 0 16px;
      font-style: italic;
      position: relative;
      z-index: 1;
    }
    .ex-card--text .ex-card__meta {
      font-family: var(--ui);
      font-size: 11px;
      letter-spacing: 0.14em;
      color: var(--muted);
      margin: 0;
      padding-top: 12px;
      border-top: 1px solid var(--rule);
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 700;
      text-transform: uppercase;
      position: relative;
      z-index: 1;
    }

    .story-firewall {
      max-width: 880px;
      margin: 32px auto 0;
      padding: 22px 28px;
      background: var(--paper-2);
      border-left: 3px solid var(--accent);
    }
    .story-firewall--foot { margin: 48px auto; }
    .story-firewall__label {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 700;
      margin: 0 0 10px;
    }
    .story-firewall__body {
      font-size: 13px;
      line-height: 1.6;
      color: var(--ink);
      margin: 0;
    }
    .story-firewall__body a {
      color: var(--ink);
      border-bottom: 1px solid currentColor;
      padding-bottom: 1px;
    }
    .story-firewall__more {
      display: inline-block;
      margin-left: 8px;
      font-weight: 600;
      text-transform: uppercase;
      font-size: 11px;
      letter-spacing: 0.12em;
    }

    .story-sample-banner {
      max-width: 880px;
      margin: 24px auto 0;
      padding: 18px 24px;
      background: #fef3e6;
      border: 1px solid var(--accent);
      border-left-width: 4px;
    }
    .story-sample-banner__label {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 700;
      margin: 0 0 8px;
    }
    .story-sample-banner__body {
      font-size: 13px;
      line-height: 1.55;
      color: var(--ink);
      margin: 0;
    }
    .story-sample-banner__body a {
      color: var(--ink);
      border-bottom: 1px solid currentColor;
      padding-bottom: 1px;
      font-weight: 600;
    }
    .story-deck { font-family: var(--display); font-size: clamp(22px, 2.6vw, 38px); line-height: 1.2; text-transform: none; letter-spacing: -0.005em; margin: 0; max-width: 36ch; }
    .story-pull { padding: 32px 0; border-block: 1px solid var(--rule); margin: 32px 0; text-align: center; }
    .story-pull p { font-family: var(--display); font-size: clamp(28px, 4vw, 56px); line-height: 1.1; letter-spacing: -0.005em; margin: 0 0 12px; text-transform: uppercase; }
    .story-pull cite { font-size: 11px; letter-spacing: 0.18em; color: var(--muted); font-style: normal; }

    /* Work-with-the-keepers footer block: surfaces 4 conversion paths above Read Next */
    .work-with-keepers { max-width: 1100px; margin: 64px auto 8px; padding: 0 12px; }
    .work-with-keepers__eyebrow { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0 0 18px; }
    .work-with-keepers__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    .work-with-keepers__card { display: block; padding: 24px; border: 1px solid var(--rule); background: var(--paper-2); color: var(--ink); transition: background 150ms, border-color 150ms; }
    .work-with-keepers__card:hover { background: var(--paper); border-color: var(--ink); }
    .work-with-keepers__card h3 { font-family: var(--display); font-size: clamp(22px, 2vw, 30px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 12px; }
    .work-with-keepers__card p { font-size: 13px; line-height: 1.5; color: var(--muted); margin: 0; }
    @media (max-width: 980px) { .work-with-keepers__grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .work-with-keepers__grid { grid-template-columns: 1fr; } }
  </style>
</ExhibitionLayout>
