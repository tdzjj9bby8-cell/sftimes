---
import ExhibitionLayout from '../../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../../components/ExhibitionMasthead.astro';
---
<ExhibitionLayout
  title="SUBMIT · The Keepers · SF Times"
  description="Pitch a hidden spot, a story tip, or a person we should profile."
  active="home"
>
  <ExhibitionMasthead
    slot="masthead"
    title="SUBMIT"
    subscript="TIP LINE"
    cutouts={[]}
  />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">READER TIPS · ANONYMITY HONORED · EDITOR READS WITHIN 7 DAYS</p>
    <h1 class="ex-prose__title">TELL US ABOUT<br>A PLACE, A PERSON,<br>OR A STORY.</h1>
    <p>Reader tips are the editorial pipeline. Anonymity is honored if you ask for it. Editor reads within seven days, replies only if there are follow-up questions.</p>
  </article>

  <section class="form-wrap">
    <form id="submitForm" class="sub-form" method="post" action="mailto:eric@seod.com" enctype="text/plain">
      <fieldset>
        <legend>WHAT ARE YOU SUBMITTING?</legend>
        <label><input type="radio" name="kind" value="spot" checked> A HIDDEN SPOT</label>
        <label><input type="radio" name="kind" value="pitch"> A STORY PITCH</label>
        <label><input type="radio" name="kind" value="tip"> A TIP</label>
      </fieldset>
      <label class="field">
        <span>YOUR NAME (OPTIONAL)</span>
        <input type="text" name="name">
      </label>
      <label class="field">
        <span>YOUR EMAIL</span>
        <input type="email" name="email" required>
      </label>
      <label class="field">
        <span>SUBJECT OR SPOT NAME</span>
        <input type="text" name="subject" required>
      </label>
      <label class="field">
        <span>TELL US ABOUT IT</span>
        <textarea name="body" rows="8" required></textarea>
      </label>
      <button type="submit">SEND TO THE EDITOR →</button>
    </form>
    <div id="submitThanks" hidden>
      <h3>THANKS. WE'LL READ IT.</h3>
      <p>Editor reads within seven days. If we have follow-up questions, we'll write back.</p>
    </div>
  </section>

  <style>
    .form-wrap { padding: 0 12px 80px; max-width: 720px; margin: 0 auto; }
    .sub-form { display: grid; gap: 18px; }
    fieldset { border: 1px solid var(--rule); padding: 18px; display: flex; flex-wrap: wrap; gap: 16px; }
    legend { font-size: 11px; letter-spacing: 0.16em; padding: 0 8px; }
    fieldset label { display: flex; align-items: center; gap: 8px; font-size: 13px; letter-spacing: 0.06em; }
    .field { display: flex; flex-direction: column; gap: 6px; }
    .field span { font-size: 11px; letter-spacing: 0.16em; color: var(--muted); }
    .field input, .field textarea {
      font-family: var(--ui);
      font-size: 16px;
      padding: 12px 14px;
      background: var(--paper);
      border: 1px solid var(--rule);
      color: var(--ink);
    }
    .field input:focus, .field textarea:focus { border-color: var(--ink); outline: 0; }
    .field textarea { resize: vertical; min-height: 160px; }
    button {
      padding: 14px 28px;
      background: var(--ink);
      color: var(--paper);
      border: 0;
      font-size: 12px;
      letter-spacing: 0.14em;
      cursor: pointer;
      justify-self: start;
      transition: opacity 200ms;
    }
    button:hover { opacity: 0.8; }
    #submitThanks h3 { font-family: var(--display); font-size: clamp(36px, 5vw, 64px); text-transform: uppercase; margin: 0 0 12px; }
    #submitThanks p { font-size: 14px; color: var(--muted); margin: 0; }
  </style>

  <script is:inline>
    (function () {
      const form = document.getElementById('submitForm');
      const thanks = document.getElementById('submitThanks');
      if (!form) return;
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        try {
          const data = Object.fromEntries(new FormData(form).entries());
          const KEY = 'keepers-submissions';
          const arr = JSON.parse(localStorage.getItem(KEY) || '[]');
          arr.push({ ...data, at: new Date().toISOString() });
          localStorage.setItem(KEY, JSON.stringify(arr));
        } catch (_) {}
        form.hidden = true;
        if (thanks) thanks.hidden = false;
      });
    })();
  </script>
</ExhibitionLayout>
