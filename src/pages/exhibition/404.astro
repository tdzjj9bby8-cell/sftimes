---
import ExhibitionLayout from '../../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../../components/ExhibitionMasthead.astro';
---
<ExhibitionLayout title="NOT FOUND · The Keepers · SF Times" active="home">
  <ExhibitionMasthead slot="masthead" title="404" subscript="PAGE NOT FOUND" cutouts={[]} />
  <article class="ex-prose">
    <p class="ex-prose__eyebrow">THE PAGE THAT WASN'T</p>
    <h1 class="ex-prose__title">THIS PAGE HASN'T<br>BEEN WRITTEN YET.</h1>
    <p>Or maybe it has been written and the link got tangled. Either way, here's where to go from here.</p>
  </article>
  <ul class="links404">
    <li><a href="/exhibition">HOME</a></li>
    <li><a href="/exhibition/stories">FEATURES</a></li>
    <li><a href="/exhibition/best-of">TOP TIER</a></li>
    <li><a href="/exhibition/hidden-spots">UNPUBLISHED</a></li>
    <li><a href="/exhibition/submit">SEND US A SPOT</a></li>
    <li><a href="/exhibition/support">KEEP IT ALIVE</a></li>
  </ul>
  <style>
    .links404 { list-style: none; padding: 0 12px 80px; max-width: 880px; margin: 0 auto; }
    .links404 li { border-bottom: 1px solid var(--rule); }
    .links404 a { font-family: var(--display); font-size: clamp(28px, 4vw, 56px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; display: block; padding: 18px 0; transition: padding 200ms; }
    .links404 a:hover { padding-left: 12px; }
  </style>
</ExhibitionLayout>
