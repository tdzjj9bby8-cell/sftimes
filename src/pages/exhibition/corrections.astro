---
import ExhibitionLayout from '../../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../../components/ExhibitionMasthead.astro';
const corrections: Array<{ date: string; story: string; note: string }> = [];
---
<ExhibitionLayout
  title="CORRECTIONS · The Keepers · SF Times"
  description="Every correction we have made, dated and named."
  active="home"
>
  <ExhibitionMasthead slot="masthead" title="CORRECTIONS" subscript={`№${corrections.length} LOGGED`} cutouts={[]} />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">DATED · NAMED · DESCRIBED</p>
    <h1 class="ex-prose__title">WHAT WE GOT WRONG.<br>WHAT WE CHANGED.</h1>
    <p>Every correction is dated. The story is named. The change is described. This page exists because we will eventually make a mistake, and the alternative to a public log is hiding it.</p>

    {corrections.length === 0 ? (
      <p style="font-family: var(--display); font-size: clamp(32px, 4vw, 56px); text-transform: uppercase; margin-top: 48px; color: var(--muted);">NO CORRECTIONS TO DATE.</p>
    ) : (
      <ul>
        {corrections.map((c) => (
          <li><strong>{c.date}</strong> · {c.story}<p>{c.note}</p></li>
        ))}
      </ul>
    )}
  </article>
</ExhibitionLayout>
