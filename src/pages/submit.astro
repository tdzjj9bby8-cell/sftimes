---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageMasthead from '../components/PageMasthead.astro';
---
<BaseLayout title="submit — the keepers." description="Pitch a hidden spot, a story tip, or a person we should profile." current="submit">

  <PageMasthead
    title="send us a tip."
    eyebrow="submissions · anonymity honored"
    subscript="THE KEEPERS"
  />

  <div class="container container-narrow page">
    <h2 class="page-subhead">tell us about a place, a <em>person</em>, or a story.</h2>
    <p class="lead">Reader tips are the editorial pipeline. Anonymity is honored if you ask for it. Editor reads within seven days, replies only if there are follow-up questions.</p>

    <form class="submit-form" method="post" action="mailto:submit@sftimes.com" enctype="text/plain">
      <fieldset>
        <legend class="ui-label">what are you submitting?</legend>
        <label><input type="radio" name="kind" value="spot" checked /> a hidden spot</label>
        <label><input type="radio" name="kind" value="pitch" /> a story pitch</label>
        <label><input type="radio" name="kind" value="tip" /> a tip</label>
      </fieldset>
      <label>your name (optional)
        <input type="text" name="name" />
      </label>
      <label>your email
        <input type="email" name="email" required />
      </label>
      <label>subject or spot name
        <input type="text" name="subject" required />
      </label>
      <label>tell us about it
        <textarea name="body" rows="8" required></textarea>
      </label>
      <button type="submit" class="btn-primary">send to the editor →</button>
    </form>
  </div>
</BaseLayout>

<style>
  .page { padding-block: var(--s-9); }
  .page-subhead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: var(--s-7) 0 var(--s-5);
    max-width: 22ch;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .page-subhead :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .page .lead { font-size: 1.125rem; color: var(--ink-soft); margin-bottom: var(--s-7); max-width: 56ch; }
  .submit-form { display: grid; gap: var(--s-4); max-width: 560px; }
  fieldset { border: 0; padding: 0; display: flex; gap: var(--s-5); flex-wrap: wrap; }
  legend { margin-bottom: var(--s-3); }
  label {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
  }
  fieldset label { flex-direction: row; align-items: center; gap: var(--s-2); color: var(--ink); }
  input[type=text], input[type=email], textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    padding: var(--s-3) var(--s-4);
    background: var(--bg);
    border: 1px solid var(--rule);
    color: var(--ink);
    transition: border-color var(--t-fast) var(--ease-out), background var(--t-fast) var(--ease-out);
  }
  input[type=text]:focus, input[type=email]:focus, textarea:focus {
    border-color: var(--ink);
    outline: 0;
  }
  textarea { resize: vertical; min-height: 160px; }
  .btn-primary {
    background: var(--ink);
    color: var(--bg);
    padding: var(--s-3) var(--s-5);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    border: 0;
    cursor: pointer;
    justify-self: start;
    transition: background var(--t-fast) var(--ease-out), transform var(--t-fast) var(--ease-out);
  }
  .btn-primary:hover { background: var(--terracotta); transform: translateY(-1px); }
</style>
