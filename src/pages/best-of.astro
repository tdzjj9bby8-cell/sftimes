---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';
import Placeholder from '../components/Placeholder.astro';
import { getCollection } from 'astro:content';

const cats = await getCollection('best-of');
const cutoutSrc = (c: any) => `/${c.data.hero_filename_hint.replace(/\.[^.]+$/, '')}.jpg`;
---
<ExhibitionLayout
  title="TOP TIER · The Keepers · SF Times"
  description="Hand-picked lists. Named editors. No affiliate links. No credit-card-partner inventory."
  active="best-of"
>
  <ExhibitionMasthead
    slot="masthead"
    title="TOP TIER"
    subscript={`№${cats.length} LISTS`}
    cutouts={[]}
  />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">QUARTERLY REFRESH · NAMED EDITORS · NO AFFILIATE LINKS</p>
    <h1 class="ex-prose__title">THE LISTS WE'D<br>ACTUALLY SEND<br>A FRIEND.</h1>
    <p>Quarterly refresh. Named editor on every list. No affiliate links. No credit-card-partner inventory. No chain restaurants. The editor who picks the list is named at the top of the list and lives in the city.</p>
  </article>

  <section class="ex-cards ex-cards--2">
    {cats.map((c, i) => (
      <a class="ex-card" href={`/best-of/${c.data.url_slug}`}>
        <div class="ex-card__media">
          <Placeholder alt={c.data.hero_alt} filenameHint={c.data.hero_filename_hint} aspect="4:3" showLabel={false} />
        </div>
        <p class="ex-card__meta">№{String(i + 1).padStart(2, '0')} · EDITED BY {c.data.editor.toUpperCase()}</p>
        <h3 class="ex-card__title">{c.data.title.toUpperCase()}</h3>
        <p class="ex-card__deck">Quarterly refresh · {c.data.last_refreshed.toLocaleDateString('en-US',{month:'long', year:'numeric'}).toUpperCase()}</p>
      </a>
    ))}
  </section>

  <a href="/partners" class="ex-colmark__link">
    <section class="ex-colmark">
      <h2 class="ex-colmark__text">SPONSOR A LIST</h2>
    </section>
  </a>
</ExhibitionLayout>
