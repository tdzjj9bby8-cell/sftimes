---
/**
 * /exhibition, homepage in the Exhibition Magazine visual language.
 * Pulls real data from the stories + best-of collections.
 *
 * Chrome (utility bar, drawer, section nav, newsletter, footer) comes from
 * ExhibitionLayout, identical to every other /exhibition/* page. Only the
 * homepage-specific content blocks and the carousel rotation script live here.
 */
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';
import { getCollection } from 'astro:content';
import Placeholder from '../components/Placeholder.astro';

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);
const featured = stories.find((s) => s.data.is_featured) || stories[0];
const carouselStories = [featured, ...stories.filter((s) => s.slug !== featured.slug).slice(0, 3)];
// Drift-style editor's paragraph pulls the next 8 most recent stories.
// Each title becomes an inline link; connective prose carries the editor's voice.
const ledeStories = stories.filter((s) => s.slug !== featured.slug).slice(0, 8);
const bodyStory = stories.find((s) => s.data.pull_quote) || featured;
const bodyText = bodyStory.data.pull_quote || bodyStory.data.deck;

// Calendar timeline: next 5 Saturdays from today.
function nextSaturdays(n: number) {
  const out: Date[] = [];
  const d = new Date();
  const daysUntilSat = (6 - d.getDay() + 7) % 7 || 7;
  d.setDate(d.getDate() + daysUntilSat);
  for (let i = 0; i < n; i++) {
    out.push(new Date(d));
    d.setDate(d.getDate() + 7);
  }
  return out;
}
function fmtSat(date: Date) {
  return date
    .toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: '2-digit', year: 'numeric' })
    .toUpperCase();
}
const upcoming = nextSaturdays(5);
const AUTHORS = ['ERIC', 'NICHOLAS', 'DAISY', 'ERIC', 'NICHOLAS'];
const thisSaturday = upcoming[0];
const thisSatLabel = thisSaturday
  .toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' })
  .toUpperCase();
const nextIssue = (featured.data.issue || 0) + 1;
---
<ExhibitionLayout
  title="THE KEEPERS · SF TIMES"
  description="One San Francisco keeper every Saturday. Reader-funded."
  active="home"
>
  <ExhibitionMasthead slot="masthead" title="THE KEEPERS" subscript="SF TIMES" cutouts={[]} />

  <p class="ex-tagline">One San Francisco keeper, every Saturday morning. Reader-funded.</p>

  <!-- FEATURED CAROUSEL -->
  <div class="feat" id="featCarousel">
    {carouselStories.map((s, i) => (
      <div class={`feat__slide${i === 0 ? ' is-on' : ''}`} data-slide={i}>
        <Placeholder
          alt={s.data.hero_alt}
          filenameHint={s.data.hero_filename_hint}
          aspect="21:9"
          showLabel={false}
          priority={i === 0}
          focal={s.data.hero_focal}
        />
        <div class="feat__overlay">
          <h2 class="feat__title">{s.data.title.toUpperCase()}</h2>
          <p class="feat__eyebrow">ISSUE №{s.data.issue} · BY {s.data.author.toUpperCase()} · {s.data.read_minutes}-MIN READ</p>
          <a class="feat__cta" href={`/exhibition/stories/${s.data.url_slug}`}>Read the Essay</a>
        </div>
      </div>
    ))}
    <div class="feat__dots" id="featDots">
      {carouselStories.map((s, i) => (
        <button class={`feat__dot${i === 0 ? ' is-on' : ''}`} data-dot={i} aria-label={`Slide ${i + 1}: ${s.data.title}`}></button>
      ))}
    </div>
  </div>

  <!-- EDITOR'S PARAGRAPH — Drift-style hyperlinked landing block.
       Each keeper title is a link inline. Connective prose carries Eric's voice.
       Replaces the older asymmetric card grid. -->
  <section class="lede">
    <p class="lede__eyebrow">FROM THE EDITOR · WHAT WE'VE BEEN KEEPING</p>
    <p class="lede__text">
      {ledeStories[0] && (<><a href={`/exhibition/stories/${ledeStories[0].data.url_slug}`}>{ledeStories[0].data.title}</a> is still pouring at the same prep counter she rented in 1987. </>)}
      {ledeStories[1] && (<><a href={`/exhibition/stories/${ledeStories[1].data.url_slug}`}>{ledeStories[1].data.title}</a> hand-stitches another trajes while his children argue about the shop. </>)}
      {ledeStories[2] && (<><a href={`/exhibition/stories/${ledeStories[2].data.url_slug}`}>{ledeStories[2].data.title}</a> opens the back door at 4:42 a.m., same as last week, same as next. </>)}
      {ledeStories[3] && (<><a href={`/exhibition/stories/${ledeStories[3].data.url_slug}`}>{ledeStories[3].data.title}</a> still puts the seasonal flavors at the back of the case where nobody looks. </>)}
      {ledeStories[4] && (<><a href={`/exhibition/stories/${ledeStories[4].data.url_slug}`}>{ledeStories[4].data.title}</a> twenty years on, still hosting the kids who keep coming back. </>)}
      {ledeStories[5] && (<><a href={`/exhibition/stories/${ledeStories[5].data.url_slug}`}>{ledeStories[5].data.title}</a> is the broth nobody put on a map. </>)}
      {ledeStories[6] && (<><a href={`/exhibition/stories/${ledeStories[6].data.url_slug}`}>{ledeStories[6].data.title}</a> climbed every morning before the parrots came through. </>)}
      {ledeStories[7] && (<><a href={`/exhibition/stories/${ledeStories[7].data.url_slug}`}>{ledeStories[7].data.title}</a> has been holding the basement annex since 1979. </>)}
      Every byline is a real person. Every saturday is a real saturday. <a href="/exhibition/stories">All {stories.length} issues →</a>
    </p>
  </section>

  <!-- MID-PAGE NEWSLETTER STRIP -->
  <section class="ex-newsletter-strip" aria-label="Subscribe to the saturday letter">
    <p class="ex-newsletter-strip__copy">5,000 readers get the saturday letter. Free. No ads.</p>
    <form class="ex-newsletter-strip__form" id="exNlStripForm">
      <input type="email" name="email" placeholder="ENTER YOUR E-MAIL" required>
      <button type="submit">Subscribe</button>
    </form>
    <p class="ex-newsletter-strip__thanks" id="exNlStripThanks" hidden>THANKS. SATURDAY IN YOUR INBOX.</p>
  </section>

  <!-- KEEPERS VERTICAL BLOCK -->
  <a href={`/exhibition/stories/${bodyStory.data.url_slug}`} class="vbar" style="text-decoration:none;">
    <div class="vbar__brand">KEEPERS</div>
    <div class="vbar__copy">
      <p>{bodyText}</p>
      <p style="margin-top:18px; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(244,241,234,0.6);">{(bodyStory.data.pull_quote_attr || bodyStory.data.author).toUpperCase()} · ISSUE №{bodyStory.data.issue} →</p>
    </div>
    <div class="vbar__img">
      <Placeholder alt={bodyStory.data.hero_alt} filenameHint={bodyStory.data.hero_filename_hint} aspect="4:5" showLabel={false} focal={bodyStory.data.hero_focal} />
    </div>
  </a>

  <!-- ARCHIVE STRIP — clean horizontal scroll of past issues -->
  <section class="archive">
    <div class="archive__head">
      <div>
        <p class="archive__label">THE ARCHIVE</p>
        <p class="archive__sub">{stories.length} issues · Next saturday: {thisSatLabel.toLowerCase()}</p>
      </div>
      <a class="archive__viewall" href="/exhibition/stories">VIEW ALL →</a>
    </div>
    <div class="archive__strip">
      {stories.slice(0, 10).map((s) => (
        <a class="archive__item" href={`/exhibition/stories/${s.data.url_slug}`}>
          <div class="archive__media">
            <Placeholder alt={s.data.hero_alt} filenameHint={s.data.hero_filename_hint} aspect="4:5" showLabel={false} focal={s.data.hero_focal} />
          </div>
          <p class="archive__meta">ISSUE №{s.data.issue} · {fmtSat(new Date(s.data.published))}</p>
          <p class="archive__title">{s.data.title}</p>
        </a>
      ))}
    </div>
  </section>

</ExhibitionLayout>

<style>
  /* === TAGLINE (under masthead, above carousel) === */
  .ex-tagline {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    padding: 0 12px;
    margin: 0 0 24px;
  }

  /* === MID-PAGE NEWSLETTER STRIP === */
  .ex-newsletter-strip {
    background: var(--ink);
    color: var(--paper);
    padding: 22px 28px;
    margin: 64px 12px 0;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 20px;
  }
  .ex-newsletter-strip__copy {
    font-size: 13px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(244,241,234,0.85);
    margin: 0;
  }
  .ex-newsletter-strip__form { display: flex; gap: 0; }
  .ex-newsletter-strip__form input {
    padding: 10px 14px;
    background: transparent;
    border: 1px solid rgba(244,241,234,0.3);
    color: var(--paper);
    font-family: var(--ui);
    font-size: 13px;
    border-radius: 0;
    min-width: 260px;
  }
  .ex-newsletter-strip__form input::placeholder {
    color: rgba(244,241,234,0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 11px;
  }
  .ex-newsletter-strip__form button {
    padding: 10px 22px;
    background: var(--paper);
    color: var(--ink);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid var(--paper);
    transition: opacity 150ms;
  }
  .ex-newsletter-strip__form button:hover { opacity: 0.85; }
  .ex-newsletter-strip__thanks {
    font-family: var(--display);
    font-size: 22px;
    text-transform: uppercase;
    margin: 0;
  }
  @media (max-width: 720px) {
    .ex-newsletter-strip { grid-template-columns: 1fr; gap: 14px; }
    .ex-newsletter-strip__form input { min-width: 0; flex: 1; }
  }

  /* === FEATURED CAROUSEL === */
  .feat { position: relative; margin: 12px 12px 0; aspect-ratio: 24/10; overflow: hidden; background: #2a2520; }
  .feat__slide { position: absolute; inset: 0; opacity: 0; transition: opacity 500ms; pointer-events: none; }
  .feat__slide.is-on { opacity: 1; pointer-events: auto; }
  /* Placeholder renders the img in its own component scope, so target it
     globally to make sure each slide's image fills the carousel container. */
  .feat__slide :global(.real-image),
  .feat__slide :global(.placeholder),
  .feat__slide :global(img) {
    width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block;
  }
  .feat__overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 24px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0.65) 100%);
  }
  .feat__title { color: #fff; font-family: var(--ui); font-size: clamp(22px, 2.6vw, 36px); font-weight: 500; line-height: 1.1; letter-spacing: 0.02em; margin: 0 0 18px; max-width: 70%; text-shadow: 0 2px 12px rgba(0,0,0,0.5); }
  .feat__eyebrow { color: rgba(255,255,255,0.85); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.55); width: 280px; margin: 0 0 22px; }
  .feat__cta { color: #fff; font-size: 12px; letter-spacing: 0.04em; padding-bottom: 2px; border-bottom: 1px solid rgba(255,255,255,0.7); transition: opacity 150ms; }
  .feat__cta:hover { opacity: 0.7; }
  .feat__dots { position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 3; }
  .feat__dot { width: 24px; height: 2px; background: rgba(255,255,255,0.4); cursor: pointer; transition: background 150ms; }
  .feat__dot.is-on { background: #fff; }

  /* === EDITOR'S PARAGRAPH (Drift-style hyperlinked lede) === */
  .lede { padding: 80px 12px 64px; max-width: 1080px; margin: 0 auto; }
  .lede__eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0 0 28px; padding-bottom: 14px; border-bottom: 1px solid var(--rule); }
  .lede__text {
    font-family: var(--display);
    font-size: clamp(24px, 2.6vw, 40px);
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
  }
  .lede__text a {
    color: var(--ink);
    text-decoration: none;
    background-image: linear-gradient(var(--ink), var(--ink));
    background-repeat: no-repeat;
    background-position: 0 100%;
    background-size: 100% 2px;
    padding-bottom: 2px;
    transition: background-size 220ms cubic-bezier(0.16,1,0.3,1), opacity 200ms;
  }
  .lede__text a:hover { background-size: 100% 6px; opacity: 0.85; }

  /* === VERTICAL BLOCK === */
  /* KEEPERS wordmark sits in its own column. Font cap and column width
     are paired so the brand never bleeds into the copy column. */
  .vbar { display: grid; grid-template-columns: 360px 1.1fr 1.4fr; margin: 64px 0 0; background: var(--ink); color: var(--paper); min-height: 360px; overflow: hidden; }
  .vbar__brand { font-family: var(--display); font-size: clamp(40px, 4.4vw, 62px); line-height: 1; text-transform: uppercase; align-self: center; padding-left: 32px; letter-spacing: -0.01em; white-space: nowrap; }
  .vbar__copy { padding: 64px 36px; font-size: 14px; line-height: 1.55; color: rgba(244,241,234,0.92); align-self: center; max-width: 36ch; min-width: 0; }
  .vbar__img { background: #2a2520; overflow: hidden; }
  .vbar__img :global(.real-image), .vbar__img :global(.placeholder) { width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block; }

  /* === ARCHIVE STRIP === */
  /* Replaces the awkward cal+strip pair. Horizontal scroll of past issues,
     small photo + meta + title. Clean, no vertical text, no dead zones. */
  .archive { background: var(--paper); padding: 64px 12px 80px; }
  .archive__head { display: flex; align-items: flex-end; justify-content: space-between; margin: 0 0 28px; gap: 24px; }
  .archive__label { font-family: var(--display); font-size: clamp(28px, 3.4vw, 48px); line-height: 1; letter-spacing: -0.005em; text-transform: uppercase; color: var(--ink); margin: 0 0 6px; }
  .archive__sub { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin: 0; }
  .archive__viewall { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink); padding-bottom: 2px; border-bottom: 1px solid currentColor; transition: opacity 200ms; flex-shrink: 0; }
  .archive__viewall:hover { opacity: 0.6; }
  .archive__strip { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 14px; scroll-behavior: smooth; }
  .archive__strip::-webkit-scrollbar { height: 4px; }
  .archive__strip::-webkit-scrollbar-track { background: var(--paper-2); }
  .archive__strip::-webkit-scrollbar-thumb { background: var(--rule); }
  .archive__item { flex: 0 0 auto; width: clamp(180px, 18vw, 220px); scroll-snap-align: start; color: var(--ink); transition: opacity 200ms; }
  .archive__item:hover { opacity: 0.85; }
  .archive__media { background: #2a2520; aspect-ratio: 4/5; overflow: hidden; margin-bottom: 12px; }
  .archive__media :global(.real-image), .archive__media :global(.placeholder) { width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block; transition: transform 500ms; }
  .archive__item:hover .archive__media :global(.real-image) { transform: scale(1.05); }
  .archive__meta { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0 0 4px; }
  .archive__title { font-size: 13px; line-height: 1.3; font-weight: 600; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  @media (max-width: 980px) {
    .lede__text { font-size: clamp(20px, 4.2vw, 28px); }
    .vbar { grid-template-columns: 1fr; }
    .vbar__brand { padding: 32px 24px 0; }
    .vbar__copy { padding: 24px; }
    .archive__head { flex-direction: column; align-items: flex-start; gap: 8px; }
  }
</style>

<script is:inline>
  // Mid-page newsletter strip — mirrors the footer form's localStorage handler.
  (function () {
    const form = document.getElementById('exNlStripForm');
    const thanks = document.getElementById('exNlStripThanks');
    if (!form) return;
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = (form.querySelector('input[type=email]') || {}).value || '';
      if (!email) return;
      try {
        const KEY = 'keepers-newsletter';
        const arr = JSON.parse(localStorage.getItem(KEY) || '[]');
        arr.push({ email: email.trim(), at: new Date().toISOString(), src: 'mid-page' });
        localStorage.setItem(KEY, JSON.stringify(arr));
      } catch (_) {}
      form.hidden = true;
      if (thanks) thanks.hidden = false;
    });
  })();

  // Hero carousel, auto-rotate every 6s, dot click jumps to slide
  (function () {
    const car = document.getElementById('featCarousel');
    const dots = document.getElementById('featDots');
    if (!car || !dots) return;
    const slides = car.querySelectorAll('.feat__slide');
    const dotEls = dots.querySelectorAll('.feat__dot');
    let i = 0;
    let timer;
    function show(n) {
      slides.forEach((s, idx) => s.classList.toggle('is-on', idx === n));
      dotEls.forEach((d, idx) => d.classList.toggle('is-on', idx === n));
      i = n;
    }
    function next() { show((i + 1) % slides.length); }
    function start() {
      stop();
      // WCAG 2.3.3 — respect prefers-reduced-motion. Dots still work for manual nav.
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      timer = setInterval(next, 6000);
    }
    function stop() { if (timer) clearInterval(timer); }
    dotEls.forEach((d, idx) => d.addEventListener('click', () => { show(idx); start(); }));
    car.addEventListener('mouseenter', stop);
    car.addEventListener('mouseleave', start);
    start();
  })();
</script>
