---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';

// Path 1 dashboard (editor reviews every item).
//
// After the 2026-07-15 quarantine event, the Brief moved off the auditor
// auto-publish model. The Cowork brief-daily task now drafts and audits every
// candidate and STAGES all of them (audit-passing and audit-failing alike). It
// publishes nothing. This dashboard is where the editor reviews every drafted
// item, accepts / rejects / edits each, and publishes the accepted set.
//
// One queue. No held-vs-auto split. The audit result on each card is advisory
// (it tells the editor which items cleared all five firewall checks and which
// failed, and why), but it does not gate anything: the editor decides.
//
// Data is fetched CLIENT-SIDE from /api/brief/staged on page load. The staging
// file for "today" only exists after the Cowork task has run, so the page ships
// static and hydrates: a loading state, then the review queue, or a friendly
// empty state before the task has run.
//
// Page is noindex + robots-disallowed. Intended to sit behind Vercel deployment
// protection (platform basic auth) in production; the API endpoints additionally
// honor an optional DASHBOARD_TOKEN bearer gate for direct hits.
//
// Publish POSTs the accepted items to /api/brief/publish, which composes the
// edition markdown and commits it via the GitHub Contents API (Vercel rebuilds).
---
<ExhibitionLayout
  title="THE BRIEF · DASHBOARD · INTERNAL"
  description="Path 1 editor-review model. Review every drafted item before publish."
  active="home"
>
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <ExhibitionMasthead
    slot="masthead"
    title="THE BRIEF"
    subscript="DASHBOARD · INTERNAL"
    cutouts={[]}
  />

  <section class="dash-head">
    <div class="dash-head__inner">
      <div class="dash-head__top">
        <div>
          <p class="dash-head__eyebrow"><span id="dateLabel">Loading</span> · <span id="auditState">FETCHING QUEUE</span></p>
          <h1 class="dash-head__title">Editorial review</h1>
          <p class="dash-head__sub">
            <strong><span id="itemCountHead">0</span> items drafted for review</strong> · Nothing publishes without your approval
          </p>
        </div>
        <div class="dash-head__timer-wrap">
          <p class="dash-head__timer-label">REVIEW TIMER</p>
          <p class="dash-head__timer" id="timer">00:00</p>
          <div class="dash-head__btn-row">
            <button class="dash-head__timer-btn" id="timerBtn" type="button">START</button>
            <button class="dash-head__help-btn" id="helpBtn" type="button" aria-label="Show keyboard shortcuts and audit legend" title="Help (?)">?</button>
          </div>
        </div>
      </div>

      <div class="dash-head__status" id="status">
        <span class="dash-head__status-item dash-head__status-item--accepted"><span id="acceptedCount">0</span> ACCEPTED</span>
        <span class="dash-head__status-item dash-head__status-item--rejected"><span id="rejectedCount">0</span> REJECTED</span>
        <span class="dash-head__status-item dash-head__status-item--pending"><span id="pendingCount">0</span> PENDING</span>
        <a class="dash-head__weekly-link" href="/brief-dashboard/weekly/">WEEKLY AUDIT →</a>
        <a class="dash-head__weekly-link" href="/brief-dashboard/health/">SOURCE HEALTH →</a>
      </div>
    </div>
  </section>

  <!-- ============ HELP MODAL ============ -->
  <div class="dash-help" id="helpModal" hidden aria-modal="true" role="dialog" aria-labelledby="helpModalTitle">
    <div class="dash-help__backdrop" id="helpBackdrop"></div>
    <div class="dash-help__panel" role="document">
      <header class="dash-help__head">
        <h2 class="dash-help__title" id="helpModalTitle">Dashboard reference</h2>
        <button class="dash-help__close" id="helpClose" type="button" aria-label="Close help">×</button>
      </header>

      <section class="dash-help__section">
        <h3 class="dash-help__h3">Keyboard shortcuts</h3>
        <dl class="dash-help__kbds">
          <div class="dash-help__kbd-row">
            <dt><kbd>A</kbd></dt>
            <dd>Accept the active item (include it in today's brief)</dd>
          </div>
          <div class="dash-help__kbd-row">
            <dt><kbd>R</kbd></dt>
            <dd>Reject the active item (drop it)</dd>
          </div>
          <div class="dash-help__kbd-row">
            <dt><kbd>J</kbd> or <kbd>↓</kbd></dt>
            <dd>Move to the next item</dd>
          </div>
          <div class="dash-help__kbd-row">
            <dt><kbd>K</kbd> or <kbd>↑</kbd></dt>
            <dd>Move to the previous item</dd>
          </div>
          <div class="dash-help__kbd-row">
            <dt><kbd>?</kbd></dt>
            <dd>Open or close this help panel</dd>
          </div>
          <div class="dash-help__kbd-row">
            <dt><kbd>Esc</kbd></dt>
            <dd>Close this help panel</dd>
          </div>
        </dl>
        <p class="dash-help__note">Shortcuts are disabled while typing in a textarea. Click outside the field to re-enable.</p>
      </section>

      <section class="dash-help__section">
        <h3 class="dash-help__h3">The five firewall checks (advisory)</h3>
        <p class="dash-help__note">Each card shows whether the AI auditor passed or failed the item on these five checks. The result is a signal, not a gate. You decide what publishes.</p>
        <ol class="dash-help__checks">
          <li>
            <strong>Recap test.</strong> Could a reader skip the source article and still understand the news from our editor's note alone? If yes, the note crossed into rewrite territory. Tighten it or reject.
          </li>
          <li>
            <strong>Angle statement test.</strong> The first sentence of the editor's note must state a specific editorial angle that goes beyond restating the news. Generic restatement fails.
          </li>
          <li>
            <strong>TLDR specificity test.</strong> The TLDR must include at least one specific number, named neighborhood, named person, or named institution. Generic phrasing fails.
          </li>
          <li>
            <strong>Word count test.</strong> The editor's note must be between 100 and 150 words (90 to 165 with tolerance). Under is thin, over is bloat.
          </li>
          <li>
            <strong>Voice test.</strong> The note must sound like SF Times (direct, specific, no filler). Phrases like "this is important because" or "moving forward" flag as generic news-brief voice.
          </li>
        </ol>
      </section>

      <section class="dash-help__section">
        <h3 class="dash-help__h3">Audit badges</h3>
        <dl class="dash-help__badges">
          <div class="dash-help__badge-row">
            <dt><span class="dash-help__pill dash-help__pill--pass">AUDIT PASSED</span></dt>
            <dd>Item cleared all five firewall checks. Still yours to accept, edit, or reject.</dd>
          </div>
          <div class="dash-help__badge-row">
            <dt><span class="dash-help__pill dash-help__pill--fail">AUDIT FLAGGED</span></dt>
            <dd>Item failed one or more of the five checks. Read the auditor reasons, then edit and accept, or reject.</dd>
          </div>
        </dl>
      </section>

      <section class="dash-help__section">
        <h3 class="dash-help__h3">Nothing publishes without you</h3>
        <p>The Cowork task drafts and audits, then stops. It publishes nothing. Every item in this queue is here because it was drafted, not because it was approved. The brief goes live only when you accept items and hit publish. If you do nothing, nothing ships that day.</p>
      </section>
    </div>
  </div>

  <!-- ============ QUEUE STATE BANNER ============ -->
  <div class="dash-banner" id="queueStatus" role="status" aria-live="polite">Loading today's queue…</div>

  <!-- ============ REVIEW QUEUE ============ -->
  <section class="dash-section" id="reviewSection" hidden>
    <div class="dash-section__head">
      <p class="dash-section__eyebrow">REQUIRES REVIEW</p>
      <h2 class="dash-section__title">All drafted items</h2>
      <p class="dash-section__sub">
        Every item the Cowork task drafted and audited today. Accept to include it in the brief,
        reject to drop it. Edit any field inline before you accept. The audit badge is advisory.
      </p>
    </div>

    <div class="dash-queue" id="reviewQueue"></div>
  </section>

  <!-- ============ PUBLISH BAR ============ -->
  <section class="dash-publish" id="publishBar" hidden>
    <div class="dash-publish__inner">
      <div>
        <p class="dash-publish__label">Ready to ship</p>
        <p class="dash-publish__sub" id="publishMsg">Waiting for today's queue…</p>
      </div>
      <button class="dash-publish__btn" id="publishBtn" type="button" disabled>PUBLISH ACCEPTED ITEMS</button>
    </div>
  </section>

  <!-- Global because the review cards are created client-side (createElement)
       and would not carry Astro's scoped-style marker. All class names are
       page-prefixed and this block only loads on /brief-dashboard. -->
  <style is:global>
    /* ============ HEAD ============ */
    .dash-head {
      background: var(--paper-2);
      border-block: 1px solid var(--rule);
      padding: 24px 0;
      margin: 0 0 32px;
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .dash-head__inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .dash-head__top { display: flex; justify-content: space-between; align-items: flex-start; gap: 32px; margin-bottom: 16px; }
    .dash-head__eyebrow {
      font-family: var(--ui); font-size: 11px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--muted); margin: 0 0 8px; font-weight: 700;
    }
    .dash-head__title {
      font-family: var(--display); font-size: clamp(28px, 4vw, 44px);
      line-height: 1; margin: 0 0 6px; letter-spacing: -0.01em; text-transform: uppercase;
    }
    .dash-head__sub { font-family: var(--ui); font-size: 13px; color: var(--muted); margin: 0; }
    .dash-head__sub strong { color: var(--accent); font-weight: 700; }
    .dash-head__timer-wrap { text-align: right; min-width: 140px; }
    .dash-head__timer-label {
      font-family: var(--ui); font-size: 10px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--muted); margin: 0 0 4px; font-weight: 700;
    }
    .dash-head__timer { font-family: var(--display); font-size: 32px; line-height: 1; margin: 0 0 8px; }
    .dash-head__timer.over { color: var(--accent); }
    .dash-head__timer-btn {
      font-family: var(--ui); font-size: 11px; letter-spacing: 0.16em; font-weight: 700;
      text-transform: uppercase; background: var(--ink); color: var(--paper);
      padding: 6px 14px; border: 0; cursor: pointer;
    }
    .dash-head__timer-btn:hover { background: var(--accent); }
    .dash-head__btn-row { display: flex; gap: 6px; justify-content: flex-end; align-items: center; }
    .dash-head__help-btn {
      font-family: var(--ui); font-size: 16px; line-height: 1;
      font-weight: 700; background: var(--paper); color: var(--ink);
      border: 1px solid var(--rule); padding: 0;
      width: 30px; height: 30px; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      transition: background 200ms, color 200ms;
    }
    .dash-head__help-btn:hover { background: var(--accent); color: var(--paper); border-color: var(--accent); }
    .dash-head__weekly-link {
      margin-left: auto;
      font-family: var(--ui); font-size: 11px; letter-spacing: 0.14em;
      font-weight: 700; color: var(--accent);
      border-bottom: 1px solid currentColor; padding-bottom: 1px;
    }

    /* ============ QUEUE STATE BANNER ============ */
    .dash-banner {
      max-width: 1200px; margin: 0 auto 40px; padding: 40px 24px;
      font-family: var(--ui); font-size: 14px; line-height: 1.6; color: var(--muted);
      background: var(--paper-2); border: 1px solid var(--rule);
      text-align: center;
    }
    .dash-banner strong { color: var(--ink); font-weight: 700; }
    .dash-banner--error { color: #a82919; border-color: #a82919; background: #fef0ed; }
    .dash-banner[hidden] { display: none; }
    .dash-section[hidden], .dash-publish[hidden] { display: none; }

    /* ============ HELP MODAL ============ */
    .dash-help[hidden] { display: none; }
    .dash-help {
      position: fixed; inset: 0; z-index: 200;
      display: flex; align-items: center; justify-content: center;
      padding: 20px;
    }
    .dash-help__backdrop {
      position: absolute; inset: 0;
      background: rgba(10, 10, 10, 0.6);
      cursor: pointer;
    }
    .dash-help__panel {
      position: relative;
      background: var(--paper);
      max-width: 720px;
      width: 100%;
      max-height: calc(100vh - 40px);
      overflow-y: auto;
      padding: 28px 32px 32px;
      border: 1px solid var(--rule);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
    }
    .dash-help__head {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 18px; padding-bottom: 14px;
      border-bottom: 1px solid var(--rule);
    }
    .dash-help__title {
      font-family: var(--display); font-size: 26px; line-height: 1;
      margin: 0; letter-spacing: -0.005em; text-transform: uppercase;
    }
    .dash-help__close {
      font-family: var(--ui); font-size: 22px; line-height: 1;
      background: transparent; border: 0; color: var(--muted);
      width: 32px; height: 32px; cursor: pointer; padding: 0;
      display: flex; align-items: center; justify-content: center;
      transition: color 180ms;
    }
    .dash-help__close:hover { color: var(--ink); }
    .dash-help__section { margin-bottom: 22px; }
    .dash-help__section:last-child { margin-bottom: 0; }
    .dash-help__h3 {
      font-family: var(--ui); font-size: 11px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--muted); font-weight: 700;
      margin: 0 0 12px;
    }
    .dash-help__kbds, .dash-help__badges {
      margin: 0; padding: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .dash-help__kbd-row, .dash-help__badge-row {
      display: grid; grid-template-columns: 120px 1fr; gap: 14px;
      align-items: baseline;
    }
    .dash-help__kbd-row dt, .dash-help__badge-row dt { margin: 0; }
    .dash-help__kbd-row dd, .dash-help__badge-row dd {
      margin: 0;
      font-family: var(--ui); font-size: 13.5px;
      line-height: 1.5; color: var(--ink);
    }
    .dash-help kbd {
      display: inline-block;
      font-family: var(--ui); font-size: 12px; font-weight: 700;
      background: var(--paper-2); color: var(--ink);
      border: 1px solid var(--rule); padding: 2px 8px;
      min-width: 24px; text-align: center;
    }
    .dash-help__note {
      font-family: var(--ui); font-size: 12px;
      color: var(--muted); margin: 12px 0 0;
      font-style: italic;
    }
    .dash-help__checks {
      list-style: decimal; padding-left: 20px;
      margin: 0; display: flex; flex-direction: column; gap: 10px;
    }
    .dash-help__checks li {
      font-family: var(--ui); font-size: 13.5px;
      line-height: 1.55; color: var(--ink);
    }
    .dash-help__checks strong { color: var(--accent); font-weight: 700; }
    .dash-help__pill {
      font-family: var(--ui); font-size: 10px; letter-spacing: 0.16em;
      font-weight: 700; padding: 3px 9px; text-transform: uppercase;
      display: inline-block;
    }
    .dash-help__pill--pass { background: #0a7a3d; color: white; }
    .dash-help__pill--fail { background: #a82919; color: white; }
    @media (max-width: 600px) {
      .dash-help__panel { padding: 22px; }
      .dash-help__kbd-row, .dash-help__badge-row { grid-template-columns: 88px 1fr; gap: 10px; }
    }
    .dash-head__status {
      display: flex; flex-wrap: wrap; gap: 18px;
      padding-top: 14px; border-top: 1px solid var(--rule);
    }
    .dash-head__status-item {
      font-family: var(--ui); font-size: 11px; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--muted); font-weight: 700;
    }
    .dash-head__status-item span { color: var(--ink); font-size: 14px; margin-right: 4px; }
    .dash-head__status-item--accepted span { color: #0a7a3d; }
    .dash-head__status-item--rejected span { color: #a82919; }

    /* ============ SECTIONS ============ */
    .dash-section { max-width: 1200px; margin: 0 auto 48px; padding: 0 24px; }
    .dash-section__head { margin-bottom: 18px; padding-bottom: 14px; border-bottom: 1px solid var(--rule); }
    .dash-section__eyebrow {
      font-family: var(--ui); font-size: 11px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--accent); margin: 0 0 6px; font-weight: 700;
    }
    .dash-section__title {
      font-family: var(--display); font-size: clamp(24px, 3vw, 32px);
      line-height: 1.05; margin: 0 0 8px; text-transform: uppercase;
    }
    .dash-section__sub { font-family: var(--ui); font-size: 13px; color: var(--muted); margin: 0; max-width: 60ch; }

    /* ============ REVIEW CARDS ============ */
    .dash-queue { display: flex; flex-direction: column; gap: 18px; }
    .cand {
      background: var(--paper); border: 1px solid var(--rule); border-left-width: 4px;
      padding: 20px 22px; transition: opacity 240ms;
    }
    .cand--accepted { border-left-color: #0a7a3d; opacity: 0.6; }
    .cand--rejected { border-left-color: #a82919; opacity: 0.4; }
    .cand--first-to-connect { border-left-color: var(--accent); }
    .cand--underreported { border-left-color: #2c5582; }
    .cand--missing-context { border-left-color: #6b6357; }
    .cand--structural-pattern { border-left-color: var(--ink-2); }

    .cand__head {
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 8px; margin-bottom: 14px;
    }
    .cand__head-left { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .cand__category {
      font-family: var(--ui); font-size: 10px; letter-spacing: 0.18em;
      font-weight: 700; text-transform: uppercase; background: var(--paper-2);
      padding: 4px 10px; color: var(--ink);
    }
    .cand__signal {
      font-family: var(--ui); font-size: 10px; letter-spacing: 0.14em;
      font-weight: 700; padding: 4px 10px; color: white;
    }
    .cand__signal--first-to-connect { background: var(--accent); }
    .cand__signal--underreported { background: #2c5582; }
    .cand__signal--missing-context { background: #6b6357; }
    .cand__signal--structural-pattern { background: var(--ink-2); }
    .cand__score {
      font-family: var(--ui); font-size: 10px; letter-spacing: 0.10em; color: var(--muted);
    }
    .cand__hold-badge {
      font-family: var(--ui); font-size: 10px; letter-spacing: 0.18em;
      font-weight: 700; padding: 3px 9px; text-transform: uppercase;
    }
    .cand__hold-badge--pass { background: #0a7a3d; color: white; }
    .cand__hold-badge--fail { background: #a82919; color: white; }

    .cand__audit-fails {
      background: #fef0ed; border-left: 3px solid #a82919;
      padding: 10px 14px; margin-bottom: 14px;
    }
    .cand__audit-label {
      font-family: var(--ui); font-size: 10px; letter-spacing: 0.18em;
      color: #a82919; font-weight: 700; margin: 0 0 4px;
    }
    .cand__audit-reason {
      font-family: var(--ui); font-size: 13px; color: var(--ink); margin: 0;
    }

    .cand__source { margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid var(--rule); }
    .cand__source-headline {
      font-family: var(--display); font-size: 18px; line-height: 1.25;
      letter-spacing: -0.005em; margin: 0 0 4px;
    }
    .cand__source-meta { font-family: var(--ui); font-size: 12px; color: var(--muted); margin: 0; }
    .cand__source-meta a { color: var(--accent); border-bottom: 1px solid currentColor; }

    .cand__fields { display: flex; flex-direction: column; gap: 10px; margin-bottom: 14px; }
    .cand__field { display: flex; flex-direction: column; gap: 4px; }
    .cand__field-label {
      font-family: var(--ui); font-size: 10px; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--muted); font-weight: 700;
    }
    .cand__field-input {
      font-family: var(--ui); font-size: 14px; line-height: 1.55; color: var(--ink);
      background: var(--paper-2); border: 1px solid var(--rule);
      padding: 8px 12px; width: 100%; resize: vertical;
    }
    .cand__field-input:focus { outline: 2px solid var(--accent); outline-offset: 1px; }
    .cand__field-input--angle { background: rgba(217, 85, 31, 0.08); font-weight: 500; }
    .cand__field-input--long { font-size: 14px; line-height: 1.6; }

    .cand__actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .cand__btn {
      font-family: var(--ui); font-size: 11px; letter-spacing: 0.14em; font-weight: 700;
      text-transform: uppercase; padding: 9px 18px; border: 1px solid var(--ink);
      background: transparent; color: var(--ink); cursor: pointer; transition: background 180ms;
    }
    .cand__btn:hover { background: var(--ink); color: var(--paper); }
    .cand__btn--accept:hover { background: #0a7a3d; border-color: #0a7a3d; }
    .cand__btn--reject:hover { background: #a82919; border-color: #a82919; }
    .cand[data-state=accepted] .cand__btn--accept { background: #0a7a3d; color: white; border-color: #0a7a3d; }
    .cand[data-state=rejected] .cand__btn--reject { background: #a82919; color: white; border-color: #a82919; }

    /* ============ PUBLISH BAR ============ */
    .dash-publish {
      background: var(--ink); color: var(--paper); padding: 28px 0; margin: 0 0 64px;
      position: sticky; bottom: 0; z-index: 50;
    }
    .dash-publish__inner {
      max-width: 1200px; margin: 0 auto; padding: 0 24px;
      display: flex; justify-content: space-between; align-items: center; gap: 24px;
    }
    .dash-publish__label {
      font-family: var(--display); font-size: clamp(20px, 3vw, 28px); margin: 0;
      text-transform: uppercase; letter-spacing: -0.005em;
    }
    .dash-publish__sub { font-family: var(--ui); font-size: 13px; color: rgba(255, 255, 255, 0.6); margin: 4px 0 0; }
    .dash-publish__btn {
      font-family: var(--ui); font-size: 13px; letter-spacing: 0.18em; font-weight: 700;
      background: var(--accent); color: var(--paper); padding: 16px 28px; border: 0; cursor: pointer;
    }
    .dash-publish__btn:hover { background: #e26224; }
    .dash-publish__btn:disabled { background: rgba(255, 255, 255, 0.2); cursor: not-allowed; }

    @media (max-width: 768px) {
      .dash-head__top { flex-direction: column; gap: 12px; }
      .dash-head__timer-wrap { text-align: left; }
      .dash-publish__inner { flex-direction: column; align-items: flex-start; gap: 12px; }
    }
  </style>

  <script is:inline>
    (function () {
      // ============ ELEMENT REFS ============
      const timerEl = document.getElementById('timer');
      const timerBtn = document.getElementById('timerBtn');
      const acceptedEl = document.getElementById('acceptedCount');
      const rejectedEl = document.getElementById('rejectedCount');
      const pendingEl = document.getElementById('pendingCount');
      const publishBtn = document.getElementById('publishBtn');
      const publishMsg = document.getElementById('publishMsg');

      const dateLabelEl = document.getElementById('dateLabel');
      const auditStateEl = document.getElementById('auditState');
      const itemCountHead = document.getElementById('itemCountHead');

      const queueStatus = document.getElementById('queueStatus');
      const reviewSection = document.getElementById('reviewSection');
      const publishBar = document.getElementById('publishBar');
      const reviewQueue = document.getElementById('reviewQueue');

      const SIGNALS = ['first-to-connect', 'underreported', 'missing-context', 'structural-pattern'];
      const CHECK_LABELS = {
        check_1_recap: 'Recap',
        check_2_angle: 'Angle',
        check_3_specificity: 'Specificity',
        check_4_word_count: 'Word count',
        check_5_voice: 'Voice',
      };

      // Normalized items keyed by id, so publish can rebuild the full payload
      // (static source fields from here, edited text fields from the DOM).
      const itemsById = {};

      // Live card node list, repopulated after each render.
      let cards = [];
      let activeIdx = 0;

      // Publish context (the date being reviewed).
      let reviewDate = new Date().toISOString().slice(0, 10);

      // ============ TIMER ============
      let startedAt = null;
      let tickHandle = null;

      function fmtTime(seconds) {
        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
        const s = (seconds % 60).toString().padStart(2, '0');
        return m + ':' + s;
      }
      function tick() {
        if (!startedAt) return;
        const elapsed = Math.floor((Date.now() - startedAt) / 1000);
        timerEl.textContent = fmtTime(elapsed);
        if (elapsed > 10 * 60) timerEl.classList.add('over');
      }
      function startTimer() {
        if (startedAt) return;
        startedAt = Date.now();
        timerBtn.textContent = 'RUNNING';
        timerBtn.disabled = true;
        tickHandle = setInterval(tick, 1000);
        tick();
      }
      function startTimerIfNeeded() {
        if (!startedAt) startTimer();
      }
      timerBtn.addEventListener('click', startTimer);

      // ============ DOM HELPERS ============
      // Build via createElement + textContent so fetched RSS/AI text can never
      // inject markup into the internal dashboard.
      function el(tag, cls, text) {
        const n = document.createElement(tag);
        if (cls) n.className = cls;
        if (text != null) n.textContent = text;
        return n;
      }
      function safeSignal(s) {
        return SIGNALS.indexOf(s) >= 0 ? s : 'underreported';
      }

      // ============ NORMALIZE ============
      // /api/brief/staged returns AuditedItem[] (nested scoring/draft/audit).
      // Flatten to the shape the cards render. Items without an audit block were
      // dropped before the auditor and are filtered out before this runs.
      function normalize(item) {
        const draft = item.draft || {};
        const scoring = item.scoring || {};
        const audit = item.audit || {};
        const failedChecks = [];
        Object.keys(CHECK_LABELS).forEach((k) => {
          if (audit[k] === 'fail') failedChecks.push(CHECK_LABELS[k]);
        });
        return {
          id: item.id,
          category: item.category || 'POLITICS',
          signal: safeSignal(draft.brief_signal),
          source_headline: item.original_headline || '(no headline)',
          source_outlet: item.source_outlet || '',
          source_byline: item.source_byline || 'Staff',
          source_url: item.source_url || '#',
          source_date: (item.published_at || '').slice(0, 10),
          composite: typeof scoring.composite === 'number' ? scoring.composite : 0,
          uniqueness: typeof scoring.uniqueness === 'number' ? scoring.uniqueness : 0,
          angle_statement: draft.angle_statement || '',
          tldr: draft.tldr || '',
          editor_note: draft.editor_note || '',
          what_to_watch: draft.what_to_watch || '',
          audit_pass: !!audit.audit_pass,
          failed_checks: failedChecks,
          fail_reasons: Array.isArray(audit.fail_reasons) ? audit.fail_reasons : [],
        };
      }

      // ============ CARD RENDERER ============
      function fieldEl(label, value, field, rows, inputCls) {
        const wrap = el('label', 'cand__field');
        wrap.appendChild(el('span', 'cand__field-label', label));
        const ta = document.createElement('textarea');
        ta.className = inputCls;
        ta.rows = rows;
        ta.dataset.field = field;
        ta.value = value || '';
        wrap.appendChild(ta);
        return wrap;
      }

      function renderCard(c) {
        const sig = c.signal;
        const article = el('article', 'cand cand--' + sig);
        article.dataset.id = c.id;

        const head = el('header', 'cand__head');
        const left = el('div', 'cand__head-left');
        left.appendChild(el('span', 'cand__category', c.category));
        left.appendChild(el('span', 'cand__signal cand__signal--' + sig, sig.replace(/-/g, ' ').toUpperCase()));
        left.appendChild(el('span', 'cand__score', 'COMPOSITE ' + c.composite.toFixed(1) + ' · UNIQUENESS ' + c.uniqueness));
        head.appendChild(left);
        const right = el('div', 'cand__head-right');
        right.appendChild(
          c.audit_pass
            ? el('span', 'cand__hold-badge cand__hold-badge--pass', 'AUDIT PASSED · 5/5')
            : el('span', 'cand__hold-badge cand__hold-badge--fail', 'AUDIT FLAGGED · ' + c.failed_checks.length + ' CHECK' + (c.failed_checks.length === 1 ? '' : 'S'))
        );
        head.appendChild(right);
        article.appendChild(head);

        if (!c.audit_pass && (c.failed_checks.length > 0 || c.fail_reasons.length > 0)) {
          const fails = el('div', 'cand__audit-fails');
          const label = c.failed_checks.length > 0
            ? 'AUDITOR FLAGGED: ' + c.failed_checks.join(', ').toUpperCase()
            : 'AUDITOR REASONS';
          fails.appendChild(el('p', 'cand__audit-label', label));
          c.fail_reasons.forEach((r) => fails.appendChild(el('p', 'cand__audit-reason', r)));
          article.appendChild(fails);
        }

        const source = el('div', 'cand__source');
        source.appendChild(el('p', 'cand__source-headline', c.source_headline));
        const meta = el('p', 'cand__source-meta');
        const a = el('a', null, c.source_outlet);
        a.href = c.source_url;
        a.rel = 'noopener noreferrer';
        a.target = '_blank';
        meta.appendChild(a);
        meta.appendChild(document.createTextNode(' · ' + c.source_byline + ' · ' + c.source_date));
        source.appendChild(meta);
        article.appendChild(source);

        const fields = el('div', 'cand__fields');
        fields.appendChild(fieldEl('Angle statement', c.angle_statement, 'angle', 2, 'cand__field-input cand__field-input--angle'));
        fields.appendChild(fieldEl('TLDR', c.tldr, 'tldr', 3, 'cand__field-input'));
        fields.appendChild(fieldEl("Editor's note", c.editor_note, 'note', 7, 'cand__field-input cand__field-input--long'));
        fields.appendChild(fieldEl('What to watch', c.what_to_watch, 'watch', 2, 'cand__field-input'));
        article.appendChild(fields);

        const actions = el('div', 'cand__actions');
        const accept = el('button', 'cand__btn cand__btn--accept', 'Accept (A)');
        accept.type = 'button';
        accept.dataset.action = 'accept';
        accept.dataset.id = c.id;
        const reject = el('button', 'cand__btn cand__btn--reject', 'Reject (R)');
        reject.type = 'button';
        reject.dataset.action = 'reject';
        reject.dataset.id = c.id;
        actions.appendChild(accept);
        actions.appendChild(reject);
        article.appendChild(actions);

        return article;
      }

      // ============ STATUS / STATE ============
      function recomputeStatus() {
        let accepted = 0, rejected = 0, pending = 0;
        cards.forEach((c) => {
          const s = c.dataset.state || 'pending';
          if (s === 'accepted') accepted++;
          else if (s === 'rejected') rejected++;
          else pending++;
        });
        acceptedEl.textContent = accepted;
        rejectedEl.textContent = rejected;
        pendingEl.textContent = pending;

        if (cards.length === 0) {
          publishBtn.disabled = true;
          publishMsg.textContent = 'No items to review.';
          return;
        }

        if (pending === 0) {
          publishBtn.disabled = accepted === 0;
          if (accepted === 0) {
            publishMsg.textContent = 'All ' + rejected + ' items rejected. Nothing to publish.';
          } else {
            publishMsg.textContent = accepted + ' accepted, ' + rejected + ' rejected, 0 pending. Publish the ' + accepted + ' accepted ' + (accepted === 1 ? 'item' : 'items') + '.';
          }
        } else {
          publishBtn.disabled = true;
          publishMsg.textContent = accepted + ' accepted, ' + rejected + ' rejected, ' + pending + ' pending. Decide every item to enable publish.';
        }
      }

      function showBanner(text, isError) {
        queueStatus.textContent = text;
        queueStatus.classList.toggle('dash-banner--error', !!isError);
        queueStatus.hidden = false;
        reviewSection.hidden = true;
        publishBar.hidden = true;
      }
      function showLoaded() {
        queueStatus.hidden = true;
        reviewSection.hidden = false;
        publishBar.hidden = false;
      }

      // ============ EVENT WIRING (post-render) ============
      function wireEvents() {
        cards = Array.prototype.slice.call(reviewQueue.querySelectorAll('.cand'));
        activeIdx = 0;

        cards.forEach((card, idx) => {
          card.querySelectorAll('.cand__btn').forEach((btn) => {
            btn.addEventListener('click', () => {
              startTimerIfNeeded();
              const action = btn.dataset.action;
              card.dataset.state = action === 'accept' ? 'accepted' : 'rejected';
              card.classList.remove('cand--accepted', 'cand--rejected');
              card.classList.add('cand--' + card.dataset.state);
              recomputeStatus();
              // Auto-scroll to next pending card
              setTimeout(() => {
                for (let i = idx + 1; i < cards.length; i++) {
                  if (!cards[i].dataset.state) {
                    cards[i].scrollIntoView({ behavior: 'smooth', block: 'center' });
                    activeIdx = i;
                    return;
                  }
                }
              }, 200);
            });
          });
          card.querySelectorAll('textarea').forEach((ta) => {
            ta.addEventListener('focus', startTimerIfNeeded);
          });
        });

        recomputeStatus();
      }

      // ============ RENDER ============
      function render(items) {
        const mapped = (items || []).filter((i) => i && i.audit).map(normalize);

        reviewQueue.innerHTML = '';
        Object.keys(itemsById).forEach((k) => delete itemsById[k]);
        mapped.forEach((c) => {
          itemsById[c.id] = c;
          reviewQueue.appendChild(renderCard(c));
        });

        itemCountHead.textContent = mapped.length;
        auditStateEl.textContent = mapped.length > 0 ? 'DRAFTED · AWAITING REVIEW' : 'NO ITEMS';

        if (mapped.length === 0) {
          showBanner('No staged queue for this date yet. The Cowork brief-daily task drafts and stages items each morning; check back after it runs, or pass ?date=YYYY-MM-DD to review another day.', false);
          return;
        }
        showLoaded();
        wireEvents();
      }

      // ============ HELP MODAL ============
      const helpModal = document.getElementById('helpModal');
      const helpBtn = document.getElementById('helpBtn');
      const helpClose = document.getElementById('helpClose');
      const helpBackdrop = document.getElementById('helpBackdrop');
      let lastFocus = null;

      function openHelp() {
        if (!helpModal || !helpModal.hidden) return;
        lastFocus = document.activeElement;
        helpModal.hidden = false;
        if (helpClose) helpClose.focus();
      }
      function closeHelp() {
        if (!helpModal || helpModal.hidden) return;
        helpModal.hidden = true;
        if (lastFocus && lastFocus.focus) lastFocus.focus();
      }
      if (helpBtn) helpBtn.addEventListener('click', openHelp);
      if (helpClose) helpClose.addEventListener('click', closeHelp);
      if (helpBackdrop) helpBackdrop.addEventListener('click', closeHelp);

      // ============ KEYBOARD SHORTCUTS ============
      document.addEventListener('keydown', (e) => {
        if (e.target.tagName === 'TEXTAREA' || e.target.tagName === 'INPUT') return;
        if (e.metaKey || e.ctrlKey || e.altKey) return;
        const key = e.key.toLowerCase();
        const helpOpen = helpModal && !helpModal.hidden;
        if (key === 'escape') {
          e.preventDefault();
          closeHelp();
          return;
        }
        if (key === '?' || (e.shiftKey && key === '/')) {
          e.preventDefault();
          if (helpOpen) closeHelp();
          else openHelp();
          return;
        }
        if (helpOpen) return; // swallow other shortcuts while help is open
        if (!cards.length) return; // nothing to drive until the queue renders
        if (key === 'a' || key === 'r') {
          e.preventDefault();
          startTimerIfNeeded();
          const card = cards[activeIdx];
          if (!card || card.dataset.state) return;
          const btn = card.querySelector(key === 'a' ? '.cand__btn--accept' : '.cand__btn--reject');
          if (btn) btn.click();
        } else if (key === 'j' || key === 'arrowdown') {
          e.preventDefault();
          activeIdx = Math.min(activeIdx + 1, cards.length - 1);
          cards[activeIdx].scrollIntoView({ behavior: 'smooth', block: 'center' });
        } else if (key === 'k' || key === 'arrowup') {
          e.preventDefault();
          activeIdx = Math.max(activeIdx - 1, 0);
          cards[activeIdx].scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });

      // ============ PUBLISH ============
      publishBtn.addEventListener('click', async () => {
        if (publishBtn.disabled) return;
        clearInterval(tickHandle);
        const elapsed = startedAt ? Math.floor((Date.now() - startedAt) / 1000) : 0;

        // Gather accepted items as the flat PublishItemInput shape the endpoint
        // expects. Static source fields come from itemsById; the four editable
        // text fields come from the card's current textarea values.
        const items = [];
        cards.forEach((card) => {
          if (card.dataset.state !== 'accepted') return;
          const base = itemsById[card.dataset.id];
          if (!base) return;
          const edits = {};
          card.querySelectorAll('textarea').forEach((ta) => {
            const f = ta.dataset.field;
            if (f === 'angle') edits.angle_statement = ta.value;
            else if (f === 'tldr') edits.tldr = ta.value;
            else if (f === 'note') edits.editor_note = ta.value;
            else if (f === 'watch') edits.what_to_watch = ta.value;
          });
          items.push({
            id: base.id,
            category: base.category,
            signal: base.signal,
            source_headline: base.source_headline,
            source_outlet: base.source_outlet,
            source_byline: base.source_byline,
            source_url: base.source_url,
            source_date: base.source_date,
            composite_score: base.composite,
            uniqueness_score: base.uniqueness,
            angle_statement: edits.angle_statement != null ? edits.angle_statement : base.angle_statement,
            tldr: edits.tldr != null ? edits.tldr : base.tldr,
            editor_note: edits.editor_note != null ? edits.editor_note : base.editor_note,
            what_to_watch: edits.what_to_watch != null ? edits.what_to_watch : base.what_to_watch,
          });
        });

        if (items.length === 0) {
          publishMsg.textContent = 'No accepted items to publish.';
          return;
        }

        const payload = {
          date: reviewDate,
          editor: 'Eric',
          items: items,
        };

        publishBtn.textContent = 'PUBLISHING…';
        publishBtn.disabled = true;
        publishMsg.textContent = 'Sending ' + items.length + ' accepted items to /api/brief/publish…';

        try {
          const resp = await fetch('/api/brief/publish', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify(payload),
          });

          if (resp.ok) {
            const data = await resp.json();
            publishBtn.textContent = 'PUBLISHED · ' + data.date;
            publishMsg.textContent = 'Live publish OK. Edition ' + (data.edition || '?') + ', ' + (data.items_accepted || items.length) + ' items shipped' + (data.committed ? ' (committed to main)' : ' (written locally, dev mode)') + '. Review time: ' + fmtTime(elapsed) + '.';
          } else if (resp.status === 404 || resp.status === 405) {
            // API not deployed yet: fall back to simulation
            publishBtn.textContent = 'PUBLISHED · SIMULATED';
            publishMsg.textContent = 'Simulation mode (no /api/brief/publish endpoint). ' + items.length + ' items would publish. Review time: ' + fmtTime(elapsed) + '.';
          } else {
            const err = await resp.text();
            publishBtn.textContent = 'PUBLISH FAILED';
            publishBtn.disabled = false;
            publishMsg.textContent = 'Publish error: HTTP ' + resp.status + '. ' + err.slice(0, 160);
          }
        } catch (e) {
          // Network error: assume API isn't available, fall back to simulation
          publishBtn.textContent = 'PUBLISHED · SIMULATED';
          publishMsg.textContent = 'Simulation mode (API unreachable). ' + items.length + ' items would publish. Review time: ' + fmtTime(elapsed) + '.';
        }
      });

      // ============ BOOT: FETCH TODAY'S QUEUE ============
      async function boot() {
        const today = new Date().toISOString().slice(0, 10);
        // Allow ?date=YYYY-MM-DD override for reviewing a different day.
        const params = new URLSearchParams(window.location.search);
        const date = params.get('date') || today;
        reviewDate = date;

        dateLabelEl.textContent = new Date(date + 'T12:00:00').toLocaleDateString('en-US', {
          weekday: 'long', month: 'long', day: 'numeric',
        }).toUpperCase();
        auditStateEl.textContent = 'FETCHING QUEUE';
        showBanner('Loading the staged queue for ' + date + '…', false);

        try {
          // No bearer token from the browser: the dashboard is gated by Vercel
          // deployment protection at the platform level, whose auth cookie rides
          // on this same-origin request. DASHBOARD_TOKEN gates direct API hits.
          const resp = await fetch('/api/brief/staged?date=' + encodeURIComponent(date), {
            credentials: 'same-origin',
            headers: { 'Accept': 'application/json' },
          });
          if (!resp.ok) {
            auditStateEl.textContent = 'ERROR';
            showBanner('Could not load the queue (HTTP ' + resp.status + '). If this is a 401, open the dashboard through Vercel deployment protection so the auth cookie is present.', true);
            return;
          }
          const data = await resp.json();
          render(data.items || []);
        } catch (e) {
          auditStateEl.textContent = 'ERROR';
          showBanner('Could not reach /api/brief/staged: ' + (e && e.message ? e.message : e), true);
        }
      }

      boot();
    })();
  </script>
</ExhibitionLayout>
