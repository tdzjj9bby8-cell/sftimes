---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';

const spots = [
  { n: '01', kicker: 'A BENCH · PRESIDIO', name: 'THE FOG BENCH ABOVE LOBOS CREEK', what: 'Concrete bench, no plaque, facing west. The fog rolls in from the right at 4:40pm most summer days. You hear the creek before you see it.', how: 'Park at baker beach lot 3, walk south 8 minutes, take the unsigned trail at the cypress stand.' },
  { n: '02', kicker: 'A BOOKSTORE · RICHMOND', name: 'THE BASEMENT AT GREEN APPLE AFTER 9PM', what: "Everyone knows the upstairs. The basement is quieter. The annex behind the staircase has the only copies of Robert Hass's first chapbook anywhere in the city, last we checked.", how: 'Open until 10:30 wed to sat. Ask for nobody, just walk down.' },
  { n: '03', kicker: 'A KITCHEN · EXCELSIOR', name: "THE BACK COUNTER AT MITCHELL'S, WEEKDAY AFTERNOON", what: "The line moves. The back of the freezer case has the seasonal flavors they don't list on the menu. Ube macapuno. Halo halo. Buko pandan if they made it that week.", how: 'Best window tuesday or wednesday, 2 to 4pm. Ask what is in the back.' },
  { n: '04', kicker: 'A STAIRWELL · NORTH BEACH', name: 'THE FILBERT STEPS AT FIRST LIGHT', what: 'The wild parrots come through around 6:50am most spring mornings. Bring coffee, not a camera. The light through the eucalyptus is the point.', how: 'Park at sansome and filbert. Climb to the second landing, then sit.' },
  { n: '05', kicker: 'A COUNTER · TENDERLOIN', name: 'THE SECOND-FLOOR PHO PLACE ABOVE TURK AND LEAVENWORTH', what: 'No sign. Walk up the unmarked staircase between the laundromat and the corner store. Eight tables. Mrs. Tran has been making the broth here for twenty-three years.', how: 'Cash only. Open 10am to 8pm tues to sat. Order the dac biet, ask for extra basil.' },
  { n: '06', kicker: 'A ROOM · INNER SUNSET', name: 'THE WIN-WIN MART READING ROOM IN THE BACK', what: 'Behind the dry-goods aisle at Win Win Mart is a glass door nobody pushes. Behind it, four chairs and a folding table where the owners let neighborhood kids do homework after school. They will pour you tea if you ask. They will not charge you. The room has been there since 2011.', how: 'Open weekdays 3 to 7pm. Bring something to read. Do not bring a laptop with a camera.' },
  { n: '07', kicker: 'A WALL · BERNAL HEIGHTS', name: 'THE SUTRO-VIEW WALL ON BOCANA STREET', what: 'A retaining wall on the uphill side of the 600 block. Three feet wide, faces northeast. The whole city sits in the gap between you and Sutro Tower, the Ferry Building on the right, downtown straight ahead. The locals know to be there at 5:55pm on a clear day. It is the only stretch of unfenced wall on the block, easy to miss.', how: 'Park at Bocana and Coleridge, walk uphill until the sidewalk widens. Look for the cypress that leans east.' },
  { n: '08', kicker: 'A CORNER · MISSION', name: 'THE LATE-NIGHT GIBRALTAR AT THE BACK BAR OF TARTINE MANUFACTORY', what: 'The bakery closes at 9. The back bar stays open until 11 on Thursdays and Fridays. The espresso machine is run by a person who used to pull in Trieste. Order the gibraltar and a fougasse. Watch the kitchen pack down for the next morning. The lighting is what you would write about.', how: 'Walk in after 9pm thursday or friday. Sit at the counter facing the open kitchen. Do not order food, order coffee.' },
  { n: '09', kicker: 'A TUNNEL · GLEN PARK', name: 'THE CREEK PATH UNDER DIAMOND STREET AT GLEN CANYON', what: 'A footpath enters Glen Canyon Park where Bosworth meets Lippard, dips under the Diamond Street bridge, and follows the creek for nine minutes. The acoustics under the bridge are the point. Singers practice there. So do high schoolers learning trumpet. Most people walking the park route never see it.', how: 'Enter the park at the Bosworth-Lippard kiosk. Take the lower trail right, not left. The bridge is the first one you cross.' },
  { n: '10', kicker: 'A WINDOW · CHINATOWN', name: 'THE THIRD-FLOOR HERBALIST ABOVE STOCKTON', what: 'A herbalist whose name is on the door in Cantonese but not in English. Three small rooms above a poultry market. The owner consults in Cantonese, Mandarin, and a working English. He does not advertise. He has been there since 1991. His longtime patients bring their adult children for first visits.', how: 'Building entrance is a brass door beside the poultry shop on Stockton between Jackson and Pacific. Walk up two flights. The door at the top of the stairs on the left. Bring a translator if you do not have a referral.' },
  { n: '11', kicker: 'A ROW · SOMA', name: 'THE EAST-FACING BENCHES AT SOMA WEST DOG PARK BEFORE 7AM', what: 'Four benches along the east fence catch first light. The 6am regulars are mostly older Filipino aunties with rescues. They will not bother you. They will quietly judge your dog. The coffee cart across the street opens at 6:45.', how: 'Enter the park from 14th Street side. Walk to the east fence. The benches are the four nearest the gate. Arrive 6:30 to get one.' },
  { n: '12', kicker: 'A SHELF · OUTER SUNSET', name: 'THE COMMUNITY SHELF AT THE NORIEGA LAUNDROMAT', what: 'A bookshelf at the back of the laundromat on Noriega between 32nd and 33rd. Donated books, no checkout system. Take one, leave one. Or do not. Quiet hours are tuesday and wednesday after 7pm. Two chairs and a window. The owner makes a pot of barley tea on cold days.', how: 'The laundromat with the green awning. Two doors down from the pho place. Wash your clothes or do not, the shelf is open to anyone walking in.' },
];
---
<ExhibitionLayout
  title="UNPUBLISHED · The Keepers · SF Times"
  description="Editor-vetted field notes on the corners of San Francisco worth holding."
  active="hidden-spots"
>
  <ExhibitionMasthead
    slot="masthead"
    title="UNPUBLISHED"
    subscript={`№${spots.length} PLACES`}
    cutouts={[]}
  />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">A WORKING LIST · UPDATED QUARTERLY · NO PAID PLACEMENTS</p>
    <h1 class="ex-prose__title">{spots.length} PLACES<br>NOBODY TELLS<br>YOU ABOUT.</h1>
    <p>No paid placements, no tourist boards, no influencer tags. Things our writers actually go to when they want to be left alone. Don't geotag. Don't review-bomb. Don't bring a film crew.</p>
  </article>

  <section class="hs-list">
    {spots.map((s) => (
      <article class="hs-row">
        <div class="hs-row__num">{s.n}</div>
        <div class="hs-row__body">
          <p class="hs-row__kicker">{s.kicker}</p>
          <h3 class="hs-row__name">{s.name}</h3>
          <p class="hs-row__what">{s.what}</p>
          <p class="hs-row__how"><strong>HOW TO GET THERE.</strong> {s.how}</p>
        </div>
      </article>
    ))}
  </section>

  <a href="/submit" class="ex-colmark__link">
    <section class="ex-colmark">
      <h2 class="ex-colmark__text">SEND A SPOT →</h2>
    </section>
  </a>

  <style>
    .hs-list { padding: 0 12px 48px; border-top: 1px solid var(--rule); }
    .hs-row {
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: 24px;
      padding: 36px 0;
      border-bottom: 1px solid var(--rule);
    }
    .hs-row__num {
      font-family: var(--display);
      font-size: clamp(40px, 5vw, 64px);
      line-height: 0.9;
      color: var(--ink);
    }
    .hs-row__kicker { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0 0 8px; }
    .hs-row__name {
      font-family: var(--display);
      font-size: clamp(22px, 3vw, 36px);
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: -0.005em;
      margin: 0 0 16px;
    }
    .hs-row__what { font-size: 16px; line-height: 1.55; color: var(--ink); margin: 0 0 12px; max-width: 56ch; }
    .hs-row__how { font-size: 13px; line-height: 1.5; color: var(--muted); margin: 0; max-width: 56ch; }
    .hs-row__how strong { color: var(--ink); font-weight: 600; letter-spacing: 0.06em; }
    @media (max-width: 640px) {
      .hs-row { grid-template-columns: 1fr; gap: 12px; }
      .hs-row__num { font-size: 32px; }
    }
  </style>
</ExhibitionLayout>
