---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Placeholder from '../../components/Placeholder.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const cats = await getCollection('best-of');
  // Stable sequential numbering by alphabetical slug, so a fresh category
  // dropping later gets a meaningful number rather than a slug-prefix glyph.
  const sorted = [...cats].sort((a, b) =>
    a.data.url_slug.localeCompare(b.data.url_slug)
  );
  return cats.map((c) => ({
    params: { slug: c.data.url_slug },
    props: {
      category: c,
      number: sorted.findIndex((x) => x.data.url_slug === c.data.url_slug) + 1,
    },
  }));
}

const { category, number } = Astro.props;
const { data } = category;
const { Content } = await category.render();
const stampNum = String(number).padStart(2, '0');

const refreshDate = data.last_refreshed
  .toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  .toLowerCase();
// Quarterly cadence: next drop is roughly 3 months after the last refresh.
const nextDrop = new Date(data.last_refreshed);
nextDrop.setMonth(nextDrop.getMonth() + 3);
const nextDropDate = nextDrop
  .toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  .toLowerCase();
const editorLower = data.editor.toLowerCase();
const titleLower = data.title.toLowerCase().replace(/^best /, '');
---

<BaseLayout
  title={`${data.title} — the keepers.`}
  description={data.intro || `Best of: ${data.title.toLowerCase()}.`}
  canonical={`https://sftimes.com/best-of/${data.url_slug}`}
  headerVariant="transparent"
  current="best of"
>

  <!-- HERO. Category photo full-bleed, headline overlaid. -->
  <section class="bo-hero">
    <div class="bo-hero__media">
      <Placeholder
        alt={data.hero_alt}
        filenameHint={data.hero_filename_hint}
        aspect="21:9"
        showLabel={true}
        priority={true}
      />
      <div class="bo-hero__veil" aria-hidden="true"></div>
    </div>
    <span class="bo-hero__stamp">a keepers best-of · №{stampNum}</span>
    <div class="bo-hero__overlay container">
      <p class="bo-hero__eyebrow">best of · refreshed {refreshDate}</p>
      <h1 class="bo-hero__title">{titleLower}.</h1>
    </div>
  </section>

  <!-- Editor block on paper -->
  <section class="bo-meta container">
    <div class="bo-meta__inner">
      <p class="bo-meta__editor">edited by <strong>{editorLower}</strong></p>
      {data.intro && <p class="bo-meta__intro">{data.intro}</p>}
      <div class="bo-meta__firewall">
        <p>
          Every entry is named by the editor above. No affiliate links. No credit-card-partner inventory.
          Promoted entries appear with a labeled badge. <a href="/standards">our standards →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- LIST. Empty state for now — real entries land in v1.1. -->
  <section class="bo-list container">
    <div class="bo-list__head">
      <h2 class="bo-list__title">the list.</h2>
      <span class="ui-label">in progress · drops {nextDropDate}</span>
    </div>

    <div class="bo-empty">
      <p class="bo-empty__line">
        <em>{editorLower}</em> is finishing the field work on this one.
      </p>
      <p class="bo-empty__sub">
        Picks land with photos, addresses, what to order, who runs it. No screenshots, no scraped reviews, no AI bylines.
        Reader tips are welcome and credited.
      </p>
      <p class="bo-empty__when">
        expected drop · <strong>{nextDropDate}</strong>
      </p>
      <div class="bo-empty__ctas">
        <a class="bo-empty__cta" href="/submit">send a pick →</a>
        <a class="bo-empty__cta-ghost" href="/support">know when it lands</a>
      </div>
    </div>

    {/* Long-form intro markdown if present */}
    <div class="bo-body">
      <Content />
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO — same full-bleed pattern as homepage */
  .bo-hero {
    position: relative;
    height: 72vh;
    min-height: 540px;
    max-height: 760px;
    overflow: hidden;
    background: var(--ink);
    isolation: isolate;
  }
  .bo-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .bo-hero__media :global(.placeholder),
  .bo-hero__media :global(.real-image),
  .bo-hero__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: auto !important;
    display: block;
  }
  .bo-hero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.7) 0%,
      rgba(0,0,0,0.35) 35%,
      rgba(0,0,0,0.05) 65%,
      rgba(0,0,0,0.25) 100%
    );
    pointer-events: none;
  }
  .bo-hero__stamp {
    position: absolute;
    top: calc(var(--s-9) + var(--s-2));
    right: var(--gutter);
    z-index: 3;
    border: 1px solid rgba(244,241,234,0.55);
    padding: var(--s-2) var(--s-3);
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    color: var(--bg);
  }
  .bo-hero__overlay {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    z-index: 2;
    padding-bottom: var(--s-9);
    color: var(--bg);
  }
  .bo-hero__eyebrow {
    color: rgba(244,241,234,0.78);
    margin: 0 0 var(--s-4);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
  }
  .bo-hero__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.022em;
    margin: 0;
    max-width: 18ch;
    color: var(--bg);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }

  /* META block */
  .bo-meta { padding-block: var(--s-7); border-bottom: 1px solid var(--rule); }
  .bo-meta__inner { max-width: 720px; }
  .bo-meta__editor {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    color: var(--fog);
    margin: 0 0 var(--s-4);
  }
  .bo-meta__editor strong { color: var(--ink); font-weight: 500; }
  .bo-meta__intro {
    font-family: var(--font-body);
    font-size: 1.25rem;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0 0 var(--s-5);
  }
  .bo-meta__firewall {
    padding: var(--s-4) var(--s-5);
    background: var(--paper);
    border-left: 2px solid var(--terracotta);
    font-size: 0.9375rem;
    color: var(--ink-soft);
  }
  .bo-meta__firewall a { color: var(--terracotta); border-bottom: 1px solid currentColor; padding-bottom: 1px; }

  /* LIST */
  .bo-list { padding-block: var(--s-8); }
  .bo-list__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-bottom: var(--s-3);
    margin-bottom: var(--s-7);
    border-bottom: 1px solid var(--rule);
  }
  .bo-list__title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 0;
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }

  /* EMPTY STATE — replaces the neon-green entry placeholders */
  .bo-empty {
    padding: var(--s-8) var(--s-6);
    background: var(--paper);
    text-align: center;
  }
  .bo-empty__line {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.3;
    margin: 0 0 var(--s-3);
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .bo-empty__line em {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .bo-empty__sub {
    font-family: var(--font-body);
    color: var(--ink-soft);
    max-width: 48ch;
    margin: 0 auto var(--s-5);
    line-height: 1.5;
  }
  .bo-empty__when {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    color: var(--fog);
    margin: 0 0 var(--s-5);
  }
  .bo-empty__when strong { color: var(--ink); font-weight: 500; }
  .bo-empty__ctas {
    display: flex;
    gap: var(--s-3);
    justify-content: center;
    flex-wrap: wrap;
  }
  .bo-empty__cta {
    display: inline-block;
    background: var(--ink);
    color: var(--bg);
    padding: var(--s-3) var(--s-5);
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    transition: background var(--t-fast) var(--ease-out);
  }
  .bo-empty__cta:hover { background: var(--terracotta); }
  .bo-empty__cta-ghost {
    display: inline-block;
    background: transparent;
    color: var(--ink);
    padding: var(--s-3) var(--s-5);
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    letter-spacing: 0.14em;
    border: 1px solid var(--ink);
    transition: background var(--t-fast) var(--ease-out), color var(--t-fast) var(--ease-out);
  }
  .bo-empty__cta-ghost:hover {
    background: var(--ink);
    color: var(--bg);
  }

  /* Optional markdown body */
  .bo-body { margin-top: var(--s-7); color: var(--ink-soft); max-width: 680px; }
  .bo-body:empty { display: none; }

  @media (max-width: 880px) {
    .bo-hero { height: 64vh; }
    .bo-hero__stamp { top: calc(var(--s-8) + var(--s-2)); right: var(--s-4); padding: 5px 9px; font-size: 0.625rem; }
    .bo-hero__overlay { padding-bottom: var(--s-7); }
    .bo-empty { padding: var(--s-6) var(--s-4); }
  }
</style>
