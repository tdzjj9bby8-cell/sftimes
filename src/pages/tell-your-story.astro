---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';
---
<ExhibitionLayout
  title="TELL US YOUR STORY · The Keepers · SF Times"
  description="Business owners: the deep-dive submission form for editorial coverage. 19 questions, 20-30 minutes, autosaves as you type."
  active="home"
>
  <meta name="robots" content="noindex, nofollow" slot="head" />
  <ExhibitionMasthead slot="masthead" title="TELL US YOUR STORY" subscript="BUSINESS OWNERS" cutouts={[]} />

  <!-- STICKY PROGRESS BAR -->
  <div class="story-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
    <span class="story-progress__label" id="storyProgressLabel">0% COMPLETE</span>
    <div class="story-progress__bar"><div class="story-progress__fill" id="storyProgressFill"></div></div>
    <span class="story-progress__save" id="storyProgressSave">UNSAVED</span>
  </div>

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">DEEP DIVE · 19 QUESTIONS · 20-30 MINUTES · AUTOSAVES</p>
    <h1 class="ex-prose__title">TELL US YOUR STORY.</h1>
    <p>We are looking for the real story behind your business. Not the elevator pitch. The moments that made you, the people who shaped you, the city you are building something in. Take your time. Write honestly. Your answers save automatically.</p>

    <div class="story-meta">
      <div class="story-meta__item"><strong>20-30</strong><span>MINUTES</span></div>
      <div class="story-meta__item"><strong>19</strong><span>QUESTIONS</span></div>
      <div class="story-meta__item"><strong>10</strong><span>REQUIRED</span></div>
      <div class="story-meta__item"><strong>AUTO</strong><span>SAVES</span></div>
    </div>
  </article>

  <!-- EDITORIAL FIREWALL NOTE -->
  <section class="story-firewall-note">
    <p class="story-firewall-note__label">EDITORIAL FIREWALL · WHAT HAPPENS WITH YOUR ANSWERS</p>
    <p>The editor reads every submission. If your story is a fit, we follow up with a reporter assignment. We do not guarantee publication, we do not sell your responses, and we do not write puff pieces. What you tell us shapes the angle, but the editor owns the final words.</p>
  </section>

  <form id="storyForm" novalidate class="story-form">

    <!-- SECTION 1: BASICS -->
    <div class="story-section" id="s1">
      <div class="story-section__head">
        <h2 class="story-section__title">About You</h2>
        <span class="story-section__num">SECTION 1 / 7</span>
      </div>

      <div class="story-two-col">
        <div class="story-q">
          <label class="story-q__label" for="name">Your Name <span class="story-q__required">*</span></label>
          <input type="text" id="name" name="name" placeholder="Full name" required />
        </div>
        <div class="story-q">
          <label class="story-q__label" for="business">Business Name <span class="story-q__required">*</span></label>
          <input type="text" id="business" name="business" placeholder="As it appears publicly" required />
        </div>
      </div>

      <div class="story-two-col">
        <div class="story-q">
          <label class="story-q__label" for="neighborhood">Neighborhood or City <span class="story-q__required">*</span></label>
          <input type="text" id="neighborhood" name="neighborhood" placeholder="e.g. Mission, Sunnyvale, Outer Richmond" required />
        </div>
        <div class="story-q">
          <label class="story-q__label" for="email">Email <span class="story-q__required">*</span></label>
          <input type="email" id="email" name="email" placeholder="For follow-up questions only" required />
        </div>
      </div>

      <div class="story-two-col">
        <div class="story-q">
          <label class="story-q__label" for="phone">Phone <span class="story-q__optional">OPTIONAL</span></label>
          <input type="tel" id="phone" name="phone" placeholder="If easier than email" />
        </div>
        <div class="story-q">
          <label class="story-q__label" for="website">Website or Instagram <span class="story-q__optional">OPTIONAL</span></label>
          <input type="url" id="website" name="website" placeholder="https:// or @handle" />
        </div>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="what">What does your business do, in one or two sentences? <span class="story-q__required">*</span></label>
        <p class="story-q__hint">Not the tagline. Tell us plainly.</p>
        <textarea id="what" name="what" data-min="50" placeholder="We…" required></textarea>
        <div class="story-q__count"><span></span><span class="story-q__count-bar" data-counter="what">0 characters · aim for 50+</span></div>
      </div>
    </div>

    <!-- SECTION 2: ORIGIN -->
    <div class="story-section" id="s2">
      <div class="story-section__head">
        <h2 class="story-section__title">The Origin</h2>
        <span class="story-section__num">SECTION 2 / 7</span>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="origin1">What were you doing the moment you decided to start this business? <span class="story-q__required">*</span></label>
        <p class="story-q__hint">Not the business plan version. The real moment.</p>
        <textarea id="origin1" name="origin1" data-min="200" placeholder="Write here…" required></textarea>
        <div class="story-q__count"><span></span><span class="story-q__count-bar" data-counter="origin1">0 characters · aim for 200+</span></div>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="origin2">What did your life look like before this, and what were you willing to give up to make it happen? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="origin2" name="origin2" placeholder="Write here…"></textarea>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="origin3">Was there a person, place, or experience that planted the seed for what you built? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="origin3" name="origin3" placeholder="Write here…"></textarea>
      </div>
    </div>

    <!-- SECTION 3: HARD PART -->
    <div class="story-section" id="s3">
      <div class="story-section__head">
        <h2 class="story-section__title">The Hard Part</h2>
        <span class="story-section__num">SECTION 3 / 7</span>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="hard1">What is the hardest thing you have ever had to do as a business owner that nobody saw? <span class="story-q__required">*</span></label>
        <textarea id="hard1" name="hard1" data-min="200" placeholder="Write here…" required></textarea>
        <div class="story-q__count"><span></span><span class="story-q__count-bar" data-counter="hard1">0 characters · aim for 200+</span></div>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="hard2">Was there a moment you almost walked away? What kept you going? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="hard2" name="hard2" placeholder="Write here…"></textarea>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="hard3">What did failure teach you that success never could? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="hard3" name="hard3" placeholder="Write here…"></textarea>
      </div>
    </div>

    <!-- SECTION 4: PEOPLE -->
    <div class="story-section" id="s4">
      <div class="story-section__head">
        <h2 class="story-section__title">The People</h2>
        <span class="story-section__num">SECTION 4 / 7</span>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="ppl1">Who believed in you before you believed in yourself? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="ppl1" name="ppl1" placeholder="Write here…"></textarea>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="ppl2">How has owning this business changed the way you see people? <span class="story-q__optional">OPTIONAL</span></label>
        <p class="story-q__hint">Customers, employees, strangers.</p>
        <textarea id="ppl2" name="ppl2" placeholder="Write here…"></textarea>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="ppl3">Is there a customer story that has stayed with you? One you still think about? <span class="story-q__required">*</span></label>
        <textarea id="ppl3" name="ppl3" data-min="200" placeholder="Write here…" required></textarea>
        <div class="story-q__count"><span></span><span class="story-q__count-bar" data-counter="ppl3">0 characters · aim for 200+</span></div>
      </div>
    </div>

    <!-- SECTION 5: COMMUNITY -->
    <div class="story-section" id="s5">
      <div class="story-section__head">
        <h2 class="story-section__title">The Community</h2>
        <span class="story-section__num">SECTION 5 / 7</span>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="com1">What does this neighborhood or city mean to you, and what do you hope your business gives back? <span class="story-q__required">*</span></label>
        <textarea id="com1" name="com1" data-min="150" placeholder="Write here…" required></textarea>
        <div class="story-q__count"><span></span><span class="story-q__count-bar" data-counter="com1">0 characters · aim for 150+</span></div>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="com2">If your business disappeared tomorrow, what would people miss most? What would you want them to miss? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="com2" name="com2" placeholder="Write here…"></textarea>
      </div>
    </div>

    <!-- SECTION 6: FUTURE -->
    <div class="story-section" id="s6">
      <div class="story-section__head">
        <h2 class="story-section__title">The Future</h2>
        <span class="story-section__num">SECTION 6 / 7</span>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="fut1">What are you still figuring out? <span class="story-q__required">*</span></label>
        <textarea id="fut1" name="fut1" data-min="100" placeholder="Write here…" required></textarea>
        <div class="story-q__count"><span></span><span class="story-q__count-bar" data-counter="fut1">0 characters · aim for 100+</span></div>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="fut2">What do you want to be true about your business ten years from now that is not true today? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="fut2" name="fut2" placeholder="Write here…"></textarea>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="fut3">What would you tell someone standing exactly where you were when you started? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="fut3" name="fut3" placeholder="Write here…"></textarea>
      </div>
    </div>

    <!-- SECTION 7: PERSONAL -->
    <div class="story-section" id="s7">
      <div class="story-section__head">
        <h2 class="story-section__title">The Personal</h2>
        <span class="story-section__num">SECTION 7 / 7</span>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="per1">What does a normal Tuesday look like for you, honestly? <span class="story-q__required">*</span></label>
        <textarea id="per1" name="per1" data-min="150" placeholder="Write here…" required></textarea>
        <div class="story-q__count"><span></span><span class="story-q__count-bar" data-counter="per1">0 characters · aim for 150+</span></div>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="per2">What does success feel like on a quiet day, not a big win day? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="per2" name="per2" placeholder="Write here…"></textarea>
      </div>

      <div class="story-q">
        <label class="story-q__label" for="per3">Is there something about you most people would never guess just from walking into your business? <span class="story-q__optional">OPTIONAL</span></label>
        <textarea id="per3" name="per3" placeholder="Write here…"></textarea>
      </div>
    </div>

    <!-- SUBMIT -->
    <div class="story-submit">
      <h2 class="story-submit__title">When You're Ready</h2>
      <p class="story-submit__steps">The editor reviews every submission within 7 days. If your story is a fit, you will hear from us with a follow-up call or a reporter assignment. If we cannot run it, we will tell you why and (when we can) point you somewhere that might. Either way, you get a real response from a real person.</p>
      <div class="story-submit__row">
        <button type="submit" class="story-submit__btn" id="storyBtn">SUBMIT YOUR STORY</button>
        <span class="story-submit__aux">Or save and come back later. <a href="javascript:location.reload()">Clear and start over →</a></span>
      </div>
    </div>

  </form>

  <!-- CONFIRMATION OVERLAY -->
  <div class="story-confirm" id="storyConfirm" role="dialog" aria-modal="true">
    <div class="story-confirm__title">Thank You.<br>We Will Read Every Word.</div>
    <p class="story-confirm__body">Your submission landed safely. The editor reads every one of these personally. We treat your answers as the start of a conversation, not a lead form.</p>
    <div class="story-confirm__steps">
      <ol>
        <li>The editor reads your full submission within 7 days.</li>
        <li>If your story is a fit, you get an email or call to set up a reporter assignment.</li>
        <li>If it is not a fit, you get an honest reply explaining why.</li>
      </ol>
    </div>
    <a href="/" class="story-confirm__again">RETURN TO SF TIMES →</a>
  </div>

  <style>
    /* STICKY PROGRESS BAR */
    .story-progress {
      position: sticky;
      top: 0;
      z-index: 50;
      background: var(--paper);
      border-bottom: 1px solid var(--rule);
      padding: 14px 24px;
      display: flex;
      align-items: center;
      gap: 18px;
      margin: 0 -12px;
    }
    .story-progress__bar { flex: 1; height: 4px; background: var(--paper-2); border-radius: 2px; overflow: hidden; }
    .story-progress__fill { height: 100%; width: 0; background: var(--accent); transition: width 250ms ease; }
    .story-progress__label, .story-progress__save { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); white-space: nowrap; }
    .story-progress__save.is-saved { color: var(--accent); }

    /* META BAR */
    .story-meta { display: flex; gap: 24px; margin: 28px 0 0; flex-wrap: wrap; }
    .story-meta__item { display: flex; flex-direction: column; gap: 4px; }
    .story-meta__item strong { font-family: var(--display); font-size: 24px; color: var(--ink); letter-spacing: -0.005em; }
    .story-meta__item span { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }

    /* FIREWALL */
    .story-firewall-note {
      background: var(--paper-2);
      border-left: 3px solid var(--ink);
      padding: 20px 24px;
      max-width: 880px;
      margin: 0 auto 48px;
      font-size: 14px;
      line-height: 1.6;
    }
    .story-firewall-note__label { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0 0 10px; font-weight: 600; }
    .story-firewall-note p { margin: 0; max-width: 60ch; }

    /* FORM */
    .story-form { max-width: 880px; margin: 0 auto; padding: 0 12px 64px; }
    .story-section { margin-bottom: 48px; scroll-margin-top: 80px; }
    .story-section__head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 24px;
      padding-bottom: 14px;
      border-bottom: 1px solid var(--rule);
    }
    .story-section__title { font-family: var(--display); font-size: clamp(22px, 2.4vw, 30px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; }
    .story-section__num { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); }

    .story-q { margin-bottom: 28px; }
    .story-q__label { display: block; font-size: 16px; line-height: 1.5; margin-bottom: 8px; color: var(--ink); font-weight: 500; }
    .story-q__required { color: var(--accent); margin-left: 4px; font-weight: 700; }
    .story-q__optional { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin-left: 8px; font-weight: 400; }
    .story-q__hint { font-size: 13px; line-height: 1.5; color: var(--muted); margin-bottom: 10px; font-style: italic; }
    .story-q input[type="text"], .story-q input[type="email"], .story-q input[type="tel"], .story-q input[type="url"] {
      width: 100%; padding: 12px 16px; border: 1px solid var(--rule); background: var(--paper);
      font-family: var(--ui); font-size: 15px; color: var(--ink); border-radius: 0; transition: border-color 200ms;
    }
    .story-q textarea {
      width: 100%; padding: 14px 16px; border: 1px solid var(--rule); background: var(--paper);
      font-family: var(--ui); font-size: 15px; color: var(--ink); resize: vertical; min-height: 120px;
      line-height: 1.65; transition: border-color 200ms; border-radius: 0;
    }
    .story-q input:focus, .story-q textarea:focus { outline: none; border-color: var(--ink); }
    .story-q__count { display: flex; justify-content: space-between; margin-top: 6px; font-size: 11px; color: var(--muted); }
    .story-q__count-bar.is-ready { color: var(--accent); }

    .story-two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 600px) { .story-two-col { grid-template-columns: 1fr; } }

    /* SUBMIT */
    .story-submit { margin-top: 56px; padding-top: 40px; border-top: 1px solid var(--rule); }
    .story-submit__title { font-family: var(--display); font-size: clamp(22px, 2.4vw, 30px); text-transform: uppercase; margin-bottom: 14px; }
    .story-submit__steps { font-size: 14px; line-height: 1.7; color: var(--ink); margin-bottom: 28px; max-width: 60ch; }
    .story-submit__row { display: flex; align-items: center; gap: 18px; flex-wrap: wrap; }
    .story-submit__btn {
      background: var(--ink); color: var(--paper); padding: 18px 36px; font-family: var(--ui);
      font-weight: 600; font-size: 12px; letter-spacing: 0.16em; text-transform: uppercase;
      transition: background 200ms; cursor: pointer; border: 0;
    }
    .story-submit__btn:hover { background: var(--accent); }
    .story-submit__btn:disabled { background: var(--rule); cursor: not-allowed; opacity: 0.7; }
    .story-submit__aux { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); }
    .story-submit__aux a { color: var(--ink); border-bottom: 1px solid currentColor; padding-bottom: 1px; }

    /* CONFIRM OVERLAY */
    .story-confirm {
      position: fixed; inset: 0; background: var(--paper);
      display: none; flex-direction: column; align-items: center; justify-content: center;
      padding: 24px; z-index: 100; text-align: center;
    }
    .story-confirm.is-on { display: flex; }
    .story-confirm__title { font-family: var(--display); font-size: clamp(48px, 8vw, 96px); line-height: 0.95; text-transform: uppercase; letter-spacing: -0.01em; margin-bottom: 24px; max-width: 18ch; }
    .story-confirm__body { font-size: 17px; line-height: 1.7; max-width: 52ch; color: var(--ink); margin-bottom: 28px; }
    .story-confirm__steps { max-width: 56ch; text-align: left; background: var(--paper-2); border-left: 3px solid var(--ink); padding: 24px 28px; margin-bottom: 32px; counter-reset: step; }
    .story-confirm__steps ol { padding: 0; margin: 0; list-style: none; }
    .story-confirm__steps li { padding: 8px 0 8px 32px; position: relative; font-size: 15px; line-height: 1.6; }
    .story-confirm__steps li::before {
      content: counter(step); counter-increment: step;
      position: absolute; left: 0; top: 8px; font-family: var(--display); font-size: 18px; color: var(--accent);
    }
    .story-confirm__again { font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink); border-bottom: 1px solid currentColor; padding-bottom: 2px; text-decoration: none; }
  </style>

  <script is:inline>
    (function () {
      const STORAGE_KEY = 'sftimes-story-draft-v1';
      const form = document.getElementById('storyForm');
      if (!form) return;
      const fields = form.querySelectorAll('input, textarea');
      const requiredFields = form.querySelectorAll('[required]');
      const fill = document.getElementById('storyProgressFill');
      const label = document.getElementById('storyProgressLabel');
      const saveLabel = document.getElementById('storyProgressSave');
      const progressEl = document.querySelector('.story-progress');

      let saveTimer;
      function save() {
        const data = {};
        fields.forEach((f) => { data[f.name] = f.value; });
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
          saveLabel.textContent = 'SAVED ' + new Date().toLocaleTimeString([], { hour: 'numeric', minute: '2-digit' });
          saveLabel.classList.add('is-saved');
        } catch (_) {}
      }
      function restore() {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return;
          const data = JSON.parse(raw);
          fields.forEach((f) => { if (data[f.name]) f.value = data[f.name]; });
          updateProgress();
          updateAllCounters();
        } catch (_) {}
      }

      function updateProgress() {
        let filled = 0;
        requiredFields.forEach((f) => {
          const min = parseInt(f.dataset.min || '1', 10);
          if (f.type === 'email') {
            if (/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(f.value)) filled++;
          } else if (f.value.trim().length >= min) {
            filled++;
          }
        });
        const pct = Math.round((filled / requiredFields.length) * 100);
        fill.style.width = pct + '%';
        label.textContent = pct + '% COMPLETE';
        progressEl.setAttribute('aria-valuenow', pct);
      }

      function updateCounter(field) {
        const counter = document.querySelector('[data-counter="' + field.id + '"]');
        if (!counter) return;
        const len = field.value.trim().length;
        const min = parseInt(field.dataset.min || '0', 10);
        if (min > 0) {
          counter.textContent = len + ' characters · ' + (len >= min ? 'looks good' : 'aim for ' + min + '+');
          counter.classList.toggle('is-ready', len >= min);
        }
      }
      function updateAllCounters() { document.querySelectorAll('textarea[data-min]').forEach(updateCounter); }

      fields.forEach((f) => {
        f.addEventListener('input', () => {
          clearTimeout(saveTimer);
          saveLabel.textContent = 'SAVING…';
          saveLabel.classList.remove('is-saved');
          saveTimer = setTimeout(save, 600);
          updateProgress();
          if (f.dataset.min) updateCounter(f);
        });
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const missing = [];
        requiredFields.forEach((f) => {
          const min = parseInt(f.dataset.min || '1', 10);
          if (f.type === 'email') {
            if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(f.value)) missing.push(f);
          } else if (f.value.trim().length < min) {
            missing.push(f);
          }
        });
        if (missing.length > 0) {
          missing[0].focus();
          missing[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
          alert('Please complete ' + missing.length + ' more required field' + (missing.length === 1 ? '' : 's') + ' before submitting.');
          return;
        }
        save();
        document.getElementById('storyConfirm').classList.add('is-on');
      });

      restore();
      updateProgress();
    })();
  </script>
</ExhibitionLayout>
