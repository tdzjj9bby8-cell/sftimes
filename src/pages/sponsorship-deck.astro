---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';

const totalIssues = 57;
---
<ExhibitionLayout
  title="SPONSORSHIP DECK · SF Times · The Keepers"
  description="60-second overview of partnership opportunities with SF Times. Reader-funded, no banner ads, editorial firewall. Pre-launch projections inside."
  active="support"
>
  <meta name="robots" content="noindex, nofollow" slot="head" />

  <!-- COVER PAGE -->
  <section class="deck-page deck-page--cover">
    <div class="deck-page__inner">
      <p class="deck__eyebrow">SPONSORSHIP DECK · 2026</p>
      <h1 class="deck__brand">SF TIMES</h1>
      <p class="deck__sub">THE KEEPERS</p>
      <p class="deck__tagline">One San Francisco profile, every Saturday morning.<br>Reader-funded. Zero banner ads.</p>
      <div class="deck__cover-meta">
        <div><span>0</span><p>BANNER ADS, EVER</p></div>
        <div><span>$0</span><p>PAYWALL, NEVER</p></div>
        <div><span>100%</span><p>HUMAN BYLINES</p></div>
      </div>
      <p class="deck__cover-foot">Prepared for prospective partners · 60-second read · <a href="mailto:eric@sftimes.com">eric@sftimes.com</a></p>
    </div>
  </section>

  <!-- WHAT WE ARE -->
  <section class="deck-page">
    <div class="deck-page__inner">
      <p class="deck__eyebrow">WHAT WE ARE · ONE PARAGRAPH</p>
      <h2 class="deck__h2">A weekly San Francisco profile publication.<br>Built on five rules.</h2>
      <p class="deck__lede">SF Times publishes one profile every Saturday morning. The subject is always a person holding something the city would lose without them. A recipe. A routine. A room. A record. A refusal. The publication is reader-funded. No banner ads. No tracking pixels. No paywall. No AI bylines. Every word is written by a named human, edited by a named editor, and stamped with the same five rules at the bottom of every issue.</p>

      <div class="deck__rules">
        <div class="deck__rule"><span class="deck__rule-num">01</span><strong>Named bylines, always.</strong></div>
        <div class="deck__rule"><span class="deck__rule-num">02</span><strong>One thing per page.</strong></div>
        <div class="deck__rule"><span class="deck__rule-num">03</span><strong>Specificity over abstraction.</strong></div>
        <div class="deck__rule"><span class="deck__rule-num">04</span><strong>Editorial firewall.</strong></div>
        <div class="deck__rule"><span class="deck__rule-num">05</span><strong>Protect the small.</strong></div>
      </div>
    </div>
  </section>

  <!-- THE AUDIENCE -->
  <section class="deck-page">
    <div class="deck-page__inner">
      <p class="deck__eyebrow">THE AUDIENCE · WHO OPENS THE SATURDAY LETTER</p>
      <h2 class="deck__h2">A San Francisco reader, every Saturday morning.</h2>

      <p class="deck__lede">Pre-launch. Audience numbers (subscriber count, open rate, Bay Area percentage, time-on-article, quarterly growth) are not published until the publication has audited weekly performance to report. What we will say up front: every subscriber is opt-in, every email is plain text, every byline is a named human, every issue is one San Francisco profile. The first audited reach report follows twelve consecutive weeks of Saturday shipping.</p>

      <div class="deck__metrics">
        <div class="deck__metric"><span>0</span><p>BANNER ADS, EVER</p></div>
        <div class="deck__metric"><span>$0</span><p>PAYWALL, NEVER</p></div>
        <div class="deck__metric"><span>0</span><p>TRACKING PIXELS</p></div>
        <div class="deck__metric"><span>100%</span><p>HUMAN BYLINES</p></div>
        <div class="deck__metric"><span>1</span><p>EDITOR FOR NOW</p></div>
        <div class="deck__metric"><span>2</span><p>OPEN MASTHEAD BEATS</p></div>
      </div>

      <p class="deck__caption">Structural facts above are real and verifiable on the site itself.</p>
    </div>
  </section>

  <!-- THREE WAYS IN -->
  <section class="deck-page">
    <div class="deck-page__inner">
      <p class="deck__eyebrow">THREE WAYS TO PARTNER · NINE PACKAGES</p>
      <h2 class="deck__h2">From $149 a Saturday to $18,000 a year.</h2>

      <div class="deck__tiers">
        <div class="deck__tier">
          <p class="deck__tier-label">SATURDAY UNDERWRITING</p>
          <p class="deck__tier-copy">Text-only sponsor credits on a single Saturday issue. The lightest commitment in the room.</p>
          <ul class="deck__tier-list">
            <li><strong>The Classified</strong>: $149 / saturday</li>
            <li><strong>The Patron</strong>: $400 / saturday</li>
            <li><strong>The Co-Presented</strong>: $900 / saturday</li>
          </ul>
        </div>

        <div class="deck__tier deck__tier--featured">
          <p class="deck__tier-badge">MOST CHOSEN</p>
          <p class="deck__tier-label">SPONSORED ARTICLES</p>
          <p class="deck__tier-copy">Editor-written feature about your business, lives forever, DoFollow backlink, full editorial firewall disclosure.</p>
          <ul class="deck__tier-list">
            <li><strong>The Profile</strong>: $1,500</li>
            <li><strong>The Feature</strong>: $2,800</li>
            <li><strong>The Bespoke</strong>: $5,500</li>
          </ul>
        </div>

        <div class="deck__tier">
          <p class="deck__tier-label">ONGOING PARTNERSHIPS</p>
          <p class="deck__tier-copy">For partners who want presence over time. Locked rates, named on the supporters wall, multi-issue commitment.</p>
          <ul class="deck__tier-list">
            <li><strong>The Quarterly</strong>: $1,400 / 4 sats</li>
            <li><strong>The Founding Bundle</strong>: $2,800</li>
            <li><strong>The Pillar</strong>: $18,000 / year</li>
          </ul>
        </div>
      </div>

      <p class="deck__caption">All starting prices above are floors. Final scope is negotiated on the intro call. Founding Bundle slots open: 5 of 24. Pillar slots open: 3 of 3 for 2026.</p>
    </div>
  </section>

  <!-- HOW IT APPEARS -->
  <section class="deck-page">
    <div class="deck-page__inner">
      <p class="deck__eyebrow">WHAT IT LOOKS LIKE LIVE · NEVER A BANNER</p>
      <h2 class="deck__h2">Editorial style. Always labeled. Never disguised.</h2>

      <div class="deck__mocks">

        <div class="deck__mock">
          <p class="deck__mock-label">THE PROFILE · ARTICLE</p>
          <div class="deck__mock-body deck__mock-body--article">
            <p class="deck__mock-eyebrow">ISSUE №46 · BY ERIC · IN COLLABORATION WITH <strong>YOUR BUSINESS</strong></p>
            <p class="deck__mock-title">YOUR STORY, IN OUR VOICE.</p>
            <p class="deck__mock-deck">1,200-word feature. DoFollow backlink. Lives at sftimes.com forever. Promoted in one Saturday letter.</p>
            <p class="deck__mock-firewall">EDITORIAL FIREWALL: SPONSOR APPROVED FACTS, NOT ANGLE. EDITOR WROTE EVERY WORD.</p>
          </div>
        </div>

        <div class="deck__mock">
          <p class="deck__mock-label">THE PATRON · NEWSLETTER CLOSE</p>
          <div class="deck__mock-body deck__mock-body--patron">
            <p class="deck__mock-patron-text">· TODAY'S LETTER IS SUPPORTED BY ·</p>
            <p class="deck__mock-patron-name">YOUR BUSINESS</p>
            <p class="deck__mock-patron-line">One line of your tagline. Editor-written, never the marketing version.</p>
          </div>
        </div>

        <div class="deck__mock">
          <p class="deck__mock-label">THE PILLAR · MASTHEAD CREDIT</p>
          <div class="deck__mock-body deck__mock-body--pillar">
            <p class="deck__mock-pillar-mast">THE KEEPERS</p>
            <p class="deck__mock-pillar-sub">SF TIMES</p>
            <p class="deck__mock-pillar-credit">FOUNDING UNDERWRITER · <strong>YOUR NAME</strong></p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="deck-page">
    <div class="deck-page__inner">
      <p class="deck__eyebrow">WHY THIS WORKS · FIVE REASONS</p>
      <h2 class="deck__h2">What you cannot buy on a banner ad.</h2>

      <ol class="deck__reasons">
        <li><strong>Trust transfer.</strong> Readers do not skim past sponsored credits the way they skim past banner ads. They read them because we wrote them. The firewall is the product.</li>
        <li><strong>Forever SEO asset.</strong> Sponsored articles live at a real URL on a real publication. DoFollow backlink. Indexed by Google. They keep working ten years from now.</li>
        <li><strong>Local intent.</strong> The publication is built for Bay Area readers, not a national list. Audience composition will be reported once the first audit cycle clears.</li>
        <li><strong>Reader-funded credibility.</strong> Subscribers pay attention to a publication they pay for. Engagement compounds. Open rates do not erode the way ad-supported newsletters' do.</li>
        <li><strong>Capped inventory.</strong> One Co-Presented per Saturday. Four Patrons per month. Six Classifieds per issue. You are not buying into a flood. You are buying scarcity.</li>
      </ol>
    </div>
  </section>

  <!-- THE EDITOR -->
  <section class="deck-page">
    <div class="deck-page__inner deck-page__inner--quote">
      <p class="deck__eyebrow">FROM THE EDITOR</p>
      <div class="deck__editor-note">
        <p>The editor picks every sponsor personally. If a business does not pass the bar we hold our bylines to, the answer is no on the intro call and the conversation ends there.</p>
        <p>The bar: the business treats its people well, it is specific about what it does, and its story would make a Saturday letter readers actually want to open. If the answer to any of those is unclear, the editor declines.</p>
        <p class="deck__editor-sign">Eric, founder and editor. SF Times.</p>
      </div>
    </div>
  </section>

  <!-- NEXT STEPS -->
  <section class="deck-page deck-page--cta">
    <div class="deck-page__inner">
      <p class="deck__eyebrow">NEXT STEPS · 15-MINUTE INTRO CALL</p>
      <h2 class="deck__h2">Let us talk.</h2>
      <p class="deck__cta-body">Two business days for a reply. Fifteen minutes for the intro call. Forty-eight hours to confirm a Saturday slot. The intro call is no-obligation. If your story is not a fit, we will tell you why and (when we can) refer you to honest alternatives.</p>

      <div class="deck__contact-row">
        <div class="deck__contact">
          <p class="deck__contact-label">EMAIL</p>
          <p class="deck__contact-val">eric@sftimes.com</p>
        </div>
        <div class="deck__contact">
          <p class="deck__contact-label">PHONE / TEXT</p>
          <p class="deck__contact-val">707·718·3579</p>
        </div>
        <div class="deck__contact">
          <p class="deck__contact-label">WEB</p>
          <p class="deck__contact-val">sftimes.com/partners</p>
        </div>
      </div>

      <p class="deck__cover-foot">SF Times · The Keepers · San Francisco, CA · 2026 sponsorship deck</p>
    </div>
  </section>

  <!-- VIEWER CONTROLS (not printed) -->
  <div class="deck-controls">
    <p>This page is print-optimized. To save as a PDF: use your browser's "Save as PDF" option in the print dialog.</p>
    <button onclick="window.print()">SAVE AS PDF →</button>
  </div>

  <style>
    /* =========================================================
       DECK LAYOUT: single-scroll on screen, page-per-section in print
       ========================================================= */

    /* Each section becomes one PDF page in print */
    .deck-page {
      max-width: 880px;
      margin: 48px auto;
      padding: 56px 48px;
      background: var(--paper);
      border: 1px solid var(--rule);
      page-break-after: always;
      break-after: page;
      min-height: 540px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .deck-page__inner { display: flex; flex-direction: column; }
    .deck-page__inner--quote { justify-content: center; min-height: 360px; }

    /* Cover page distinct treatment */
    .deck-page--cover {
      background: var(--ink);
      color: var(--paper);
      border-color: var(--ink);
      align-items: center;
      text-align: center;
    }
    .deck-page--cover .deck__eyebrow { color: rgba(244,241,234,0.6); }
    .deck-page--cover .deck__cover-foot { color: rgba(244,241,234,0.7); }
    .deck-page--cover .deck__cover-foot a { color: var(--paper); border-bottom: 1px solid currentColor; padding-bottom: 1px; }

    .deck__brand {
      font-family: var(--display);
      font-size: clamp(72px, 12vw, 144px);
      line-height: 0.95;
      letter-spacing: -0.01em;
      margin: 12px 0 4px;
      color: var(--paper);
    }
    .deck__sub {
      font-family: var(--display);
      font-size: clamp(16px, 2vw, 24px);
      letter-spacing: 0.08em;
      transform: skewX(-10deg);
      display: inline-block;
      margin: 0 0 32px;
      color: rgba(244,241,234,0.8);
    }
    .deck__tagline {
      font-size: clamp(18px, 2.2vw, 24px);
      line-height: 1.4;
      max-width: 50ch;
      margin: 0 auto 40px;
      color: rgba(244,241,234,0.85);
    }
    .deck__cover-meta {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
      margin: 0 0 36px;
      max-width: 640px;
    }
    .deck__cover-meta > div { text-align: center; }
    .deck__cover-meta span {
      font-family: var(--display);
      font-size: clamp(36px, 5vw, 56px);
      line-height: 1;
      color: var(--paper);
      display: block;
    }
    .deck__cover-meta p {
      font-size: 11px;
      letter-spacing: 0.18em;
      color: rgba(244,241,234,0.7);
      margin: 8px 0 0;
      text-transform: uppercase;
    }
    .deck__cover-foot { font-size: 12px; margin: 0; }

    /* Common deck elements */
    .deck__eyebrow {
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 700;
      margin: 0 0 18px;
    }
    .deck__h2 {
      font-family: var(--display);
      font-size: clamp(32px, 4.6vw, 56px);
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: -0.005em;
      margin: 0 0 28px;
      max-width: 18ch;
    }
    .deck__lede {
      font-size: clamp(15px, 1.4vw, 18px);
      line-height: 1.7;
      max-width: 64ch;
      margin: 0 0 32px;
    }
    .deck__caption {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.6;
      max-width: 64ch;
      margin: 24px 0 0;
      font-style: italic;
    }

    /* Five rules grid */
    .deck__rules {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 14px;
      margin-top: 8px;
    }
    @media (max-width: 720px) { .deck__rules { grid-template-columns: repeat(2, 1fr); } }
    .deck__rule {
      padding: 18px 16px;
      border: 1px solid var(--rule);
      background: var(--paper-2);
    }
    .deck__rule-num {
      font-family: var(--display);
      font-size: 22px;
      color: var(--accent);
      letter-spacing: -0.005em;
      display: block;
      margin-bottom: 6px;
    }
    .deck__rule strong {
      font-size: 12px;
      line-height: 1.4;
      display: block;
    }

    /* Metrics block */
    .deck__metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px 32px;
      padding: 24px 0;
      border-block: 1px solid var(--rule);
      margin: 0;
    }
    @media (max-width: 720px) { .deck__metrics { grid-template-columns: repeat(2, 1fr); } }
    .deck__metric span {
      font-family: var(--display);
      font-size: clamp(32px, 4vw, 48px);
      line-height: 1;
      display: block;
    }
    .deck__metric p {
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 6px 0 0;
    }

    /* Tier grid */
    .deck__tiers {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin: 0;
    }
    @media (max-width: 880px) { .deck__tiers { grid-template-columns: 1fr; } }
    .deck__tier {
      padding: 24px 22px;
      border: 1px solid var(--rule);
      background: var(--paper);
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .deck__tier--featured { background: var(--ink); color: var(--paper); border-color: var(--ink); }
    .deck__tier--featured .deck__tier-label,
    .deck__tier--featured .deck__tier-copy,
    .deck__tier--featured .deck__tier-list { color: rgba(244,241,234,0.9); }
    .deck__tier-badge {
      position: absolute;
      top: -10px;
      left: 16px;
      background: var(--paper);
      color: var(--ink);
      padding: 4px 10px;
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 700;
      margin: 0;
    }
    .deck__tier-label {
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 700;
      margin: 0;
    }
    .deck__tier-copy { font-size: 13px; line-height: 1.5; margin: 0; }
    .deck__tier-list {
      list-style: none;
      padding: 14px 0 0;
      margin: 0;
      border-top: 1px solid currentColor;
    }
    .deck__tier-list li {
      font-size: 13px;
      line-height: 1.6;
      padding: 4px 0;
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }
    .deck__tier-list li strong { font-weight: 600; }

    /* Mockups */
    .deck__mocks {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 14px;
      margin: 0;
    }
    @media (max-width: 880px) { .deck__mocks { grid-template-columns: 1fr; } }
    .deck__mock-label {
      font-size: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 700;
      margin: 0 0 10px;
    }
    .deck__mock-body {
      padding: 22px 22px;
      background: var(--paper);
      border: 1px solid var(--rule);
      min-height: 220px;
    }
    .deck__mock-body--article { padding: 28px 26px; }
    .deck__mock-eyebrow { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0 0 14px; }
    .deck__mock-eyebrow strong { color: var(--ink); }
    .deck__mock-title { font-family: var(--display); font-size: 22px; line-height: 1.1; text-transform: uppercase; margin: 0 0 12px; }
    .deck__mock-deck { font-size: 13px; line-height: 1.5; margin: 0 0 16px; }
    .deck__mock-firewall { font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0; padding-top: 12px; border-top: 1px solid var(--rule); }

    .deck__mock-body--patron, .deck__mock-body--pillar {
      text-align: center;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .deck__mock-patron-text { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0 0 10px; }
    .deck__mock-patron-name { font-family: var(--display); font-size: 22px; letter-spacing: -0.005em; margin: 0 0 8px; }
    .deck__mock-patron-line { font-size: 12px; color: var(--muted); margin: 0; font-style: italic; }
    .deck__mock-pillar-mast { font-family: var(--display); font-size: 32px; line-height: 1; text-transform: uppercase; margin: 0 0 4px; letter-spacing: -0.005em; }
    .deck__mock-pillar-sub { font-family: var(--display); font-size: 12px; letter-spacing: 0.06em; transform: skewX(-10deg); display: inline-block; margin: 0 0 16px; color: var(--muted); }
    .deck__mock-pillar-credit { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0; padding-top: 12px; border-top: 1px solid var(--rule); }
    .deck__mock-pillar-credit strong { color: var(--ink); }

    /* Five reasons */
    .deck__reasons {
      list-style: none;
      padding: 0;
      margin: 0;
      counter-reset: reason;
    }
    .deck__reasons li {
      counter-increment: reason;
      padding: 14px 0 14px 56px;
      position: relative;
      font-size: 15px;
      line-height: 1.6;
      border-bottom: 1px solid var(--rule);
    }
    .deck__reasons li:last-child { border-bottom: 0; }
    .deck__reasons li::before {
      content: '0' counter(reason);
      position: absolute;
      left: 0;
      top: 16px;
      font-family: var(--display);
      font-size: 28px;
      color: var(--accent);
      letter-spacing: -0.005em;
    }
    .deck__reasons strong { font-weight: 600; }

    /* Editor quote */
    .deck__quote {
      margin: 0;
      padding: 32px 0 0;
    }
    .deck__quote p {
      font-family: var(--display);
      font-size: clamp(22px, 3vw, 32px);
      line-height: 1.25;
      letter-spacing: -0.005em;
      margin: 0 0 18px;
      max-width: 36ch;
    }
    .deck__quote cite {
      font-size: 12px;
      letter-spacing: 0.14em;
      color: var(--muted);
      font-style: normal;
      text-transform: uppercase;
    }
    .deck__editor-note {
      max-width: 56ch;
    }
    .deck__editor-note p {
      font-family: var(--display);
      font-size: clamp(20px, 2.6vw, 28px);
      line-height: 1.3;
      letter-spacing: -0.005em;
      margin: 0 0 18px;
    }
    .deck__editor-sign {
      font-family: var(--display) !important;
      font-size: 14px !important;
      letter-spacing: 0.06em;
      color: var(--muted);
      text-transform: none;
      margin-top: 8px !important;
    }

    /* CTA page */
    .deck-page--cta { background: var(--ink); color: var(--paper); border-color: var(--ink); }
    .deck-page--cta .deck__eyebrow { color: rgba(244,241,234,0.6); }
    .deck-page--cta .deck__h2 { color: var(--paper); }
    .deck__cta-body {
      font-size: 16px;
      line-height: 1.7;
      max-width: 56ch;
      margin: 0 0 36px;
      color: rgba(244,241,234,0.85);
    }
    .deck__contact-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin: 0 0 32px;
    }
    @media (max-width: 720px) { .deck__contact-row { grid-template-columns: 1fr; } }
    .deck__contact {
      padding: 18px 20px;
      border: 1px solid rgba(244,241,234,0.3);
    }
    .deck__contact-label { font-size: 10px; letter-spacing: 0.18em; color: rgba(244,241,234,0.6); margin: 0 0 6px; text-transform: uppercase; }
    .deck__contact-val { font-family: var(--display); font-size: clamp(18px, 2vw, 26px); letter-spacing: -0.005em; margin: 0; color: var(--paper); }
    .deck-page--cta .deck__cover-foot { color: rgba(244,241,234,0.6); }

    /* Viewer controls */
    .deck-controls {
      max-width: 880px;
      margin: 24px auto 64px;
      padding: 24px 36px;
      text-align: center;
      border: 1px dashed var(--rule);
      background: var(--paper-2);
    }
    .deck-controls p {
      font-size: 12px;
      color: var(--muted);
      margin: 0 0 14px;
    }
    .deck-controls button {
      background: var(--ink);
      color: var(--paper);
      padding: 14px 28px;
      font-family: var(--ui);
      font-weight: 600;
