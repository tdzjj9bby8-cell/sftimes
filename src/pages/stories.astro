---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';
import AuthorAvatar from '../components/AuthorAvatar.astro';
import { getCollection } from 'astro:content';

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);
const cutoutSrc = (s: any) => `/${s.data.hero_filename_hint.replace(/\.[^.]+$/, '')}.jpg`;
---
<ExhibitionLayout
  title="FEATURES · The Keepers · SF Times"
  description={`Every story we have published, back to issue one. ${stories.length} saturdays so far.`}
  active="stories"
>
  <ExhibitionMasthead
    slot="masthead"
    title="FEATURES"
    subscript={`№${stories.length} ISSUES`}
    cutouts={[]}
  />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">THE ARCHIVE · {stories.length} SATURDAYS · EVERY KEEPER</p>
    <h1 class="ex-prose__title">EVERY KEEPER<br>WE HAVE EVER HELD.</h1>
    <p>Weekly profiles, back to issue one. One saturday letter at a time, and yes, every single byline is a real human.</p>
  </article>

  <section class="ex-cards ex-cards--3">
    {stories.map((s) => (
      <a class={`ex-card ex-card--text ex-card--keeper-${s.data.keeper_type || 'default'}`} href={`/stories/${s.data.url_slug}`}>
        <span class="ex-card__issue-bg" aria-hidden="true">№{String(s.data.issue).padStart(2, '0')}</span>
        <div class="ex-card__tags">
          {s.data.keeper_type && (
            <span class="ex-card__keeper">{s.data.keeper_type.toUpperCase()}</span>
          )}
          {s.data.neighborhood && (
            <span class="ex-card__neighborhood">{s.data.neighborhood.toUpperCase()}</span>
          )}
        </div>
        <h3 class="ex-card__title">{s.data.title}</h3>
        <p class="ex-card__deck">{s.data.deck.slice(0, 140)}</p>
        <p class="ex-card__meta">
          <AuthorAvatar name={s.data.author} size={20} />
          <span>BY {s.data.author.toUpperCase()} · {s.data.read_minutes}-MIN</span>
        </p>
      </a>
    ))}
  </section>

  <a href="/" class="ex-colmark__link">
    <section class="ex-colmark">
      <h2 class="ex-colmark__text">BACK TO HOME</h2>
    </section>
  </a>
</ExhibitionLayout>
