---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Terms — SF Times" current="terms">
  <div class="container container-narrow page">
    <p class="ui-label">Terms</p>
    <h1>The legal bit.</h1>
    <p>All content on SF Times is © SF Times unless otherwise credited. Photography is © the photographer. Don't repost articles in full. Quote freely with attribution. Hidden Spots are reader-submitted with permission. We reserve the right to edit submissions for clarity and accuracy.</p>
  </div>
</BaseLayout>

<style>
  .page { padding-block: var(--s-9); }
  .page h1 { margin-block: var(--s-3) var(--s-5); }
</style>
