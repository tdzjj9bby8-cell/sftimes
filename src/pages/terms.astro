---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="terms — the keepers." current="terms">
  <div class="container container-narrow page">
    <p class="ui-label">terms</p>
    <h1>the <em>legal</em> bit.</h1>
    <p>All written content is © SF Times unless otherwise credited. Photography is © the photographer. Don't repost articles in full. Quote freely with attribution. Hidden spots are reader-submitted with permission. We reserve the right to edit submissions for clarity and accuracy.</p>
  </div>
</BaseLayout>

<style>
  .page { padding-block: var(--s-9); }
  .page h1 {
    margin-block: var(--s-3) var(--s-5);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .page h1 :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
</style>
