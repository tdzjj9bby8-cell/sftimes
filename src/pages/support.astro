---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';

const tiers = [
  { price: '$5 / MONTH',  name: 'READER+',   what: 'Keeps the lights on. Newsletter. Our thanks, by name, on the supporters page.' },
  { price: '$10 / MONTH', name: 'SUSTAINER', what: 'One hour of student reporting, every month, paid for by you. Plus the keepers-only quarterly note.', featured: true },
  { price: '$25 / MONTH', name: 'PATRON',    what: 'Named in the masthead. The annual print zine, mailed. An open invite to the once-a-year reader dinner.' },
  { price: 'YOU DECIDE',  name: 'CUSTOM',    what: 'One-time or recurring, your number. Helpful if you want to underwrite a single saturday issue.' },
];
const orgs = [
  { n: '01', name: 'SF-MARIN FOOD BANK',     what: 'Feeds 53,000 households a week across SF and Marin.' },
  { n: '02', name: 'LA COCINA',              what: 'Mission incubator for immigrant women food entrepreneurs.' },
  { n: '03', name: '826 VALENCIA',           what: 'Youth writing programs across the city, free, with named tutors.' },
  { n: '04', name: 'LARKIN STREET YOUTH',    what: 'Housing and case work for young people without a bed.' },
  { n: '05', name: 'SELF-HELP FOR ELDERLY',  what: 'Citywide senior services, delivered in English, Cantonese, and Mandarin.' },
];

// ============================================================================
// FOUNDING SUPPORTERS: 15 placeholder Bay Area names generated 2026-06-04 per
// Eric's approved direction ("Generate 15 plausible placeholder names, swap
// real names later"). Replace each name as real supporters confirm. Slots 16+
// are intentionally open for new supporters as they sign up: every pledge
// after the first 15 adds a new row to this list, capped only when Eric
// decides to close the founding-supporter cohort.
// ============================================================================
const founders = [
  { n: '01', name: 'Adrian Park',         hood: 'Inner Sunset' },
  { n: '02', name: 'Mei-Ling Tam',        hood: 'Outer Richmond' },
  { n: '03', name: 'Devon Whitaker',      hood: 'Bernal Heights' },
  { n: '04', name: 'Carolina Velasquez',  hood: 'Mission' },
  { n: '05', name: 'Hiroshi Okada',       hood: 'Japantown' },
  { n: '06', name: 'Aisha Bekele',        hood: 'Fillmore' },
  { n: '07', name: 'Jonathan Bradford',   hood: 'NoPa' },
  { n: '08', name: 'Priya Krishnan',      hood: 'Hayes Valley' },
  { n: '09', name: 'Sebastián Reyes',     hood: 'Excelsior' },
  { n: '10', name: 'Linnea Brunner',      hood: 'Cole Valley' },
  { n: '11', name: 'David Chen',          hood: 'Chinatown' },
  { n: '12', name: 'Sofia Galante',       hood: 'North Beach' },
  { n: '13', name: 'Marcus Joseph',       hood: 'Bayview' },
  { n: '14', name: 'Yael Stein',          hood: 'Glen Park' },
  { n: '15', name: 'Tomás Aguilar',       hood: 'Dogpatch' },
];
---
<ExhibitionLayout
  title="KEEP IT ALIVE · The Keepers · SF Times"
  description="Reader-funded. 75% to operations. 25% to local Bay Area charities. Named, listed, audited."
  active="support"
>
  <ExhibitionMasthead
    slot="masthead"
    title="KEEP IT ALIVE"
    subscript="75 / 25"
    cutouts={[]}
  />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">READER-FUNDED · NO BANNER ADS · NO PAYWALL</p>
    <h1 class="ex-prose__title">YOU READ IT FREE.<br>SOMEONE HAS<br>TO FUND IT.</h1>
    <p>No banner ads, no tracking, no paywall. Just readers who think a saturday letter about the city is worth ten dollars a month. Or twenty-five. Or whatever you decide. Stripe checkout lands before public launch.</p>
    <a class="support-hero-cta" href="mailto:eric@seod.com?subject=keepers%20pledge">PLEDGE TO SUPPORT &rarr;</a>
  </article>

  <section class="tiers">
    {tiers.map((t) => (
      <article class={`tier${t.featured ? ' tier--featured' : ''}`}>
        {t.featured && <span class="tier__badge">MOST CHOSEN</span>}
        <p class="tier__price">{t.price}</p>
        <h3 class="tier__name">{t.name}</h3>
        <p class="tier__what">{t.what}</p>
        <a class="tier__pledge" href={`mailto:eric@seod.com?subject=${encodeURIComponent(t.name)}%20pledge`}>PLEDGE THIS TIER &rarr;</a>
      </article>
    ))}
  </section>

  <a href="/support" class="ex-colmark__link">
    <section class="ex-colmark">
      <h2 class="ex-colmark__text">WHERE THE MONEY GOES</h2>
    </section>
  </a>

  <section class="split">
    <div class="split__row">
      <span class="split__pct">75%</span>
      <div>
        <p class="split__label">OPERATIONS</p>
        <p class="split__detail">Student stipends, editor pay, hosting, photography. The reporting, in other words.</p>
      </div>
    </div>
    <div class="split__row">
      <span class="split__pct">25%</span>
      <div>
        <p class="split__label">LOCAL BAY AREA CHARITIES</p>
        <p class="split__detail">Named below. Audited annually. Reported on the corrections page so you can check our math.</p>
      </div>
    </div>
  </section>

  <a href="#orgs" class="ex-colmark__link">
    <section class="ex-colmark" id="orgs">
      <h2 class="ex-colmark__text">THE FIVE ORGS</h2>
    </section>
  </a>

  <section class="orgs">
    {orgs.map((o) => (
      <article class="org">
        <span class="org__num">{o.n}</span>
        <div>
          <h3 class="org__name">{o.name}</h3>
          <p class="org__what">{o.what}</p>
        </div>
      </article>
    ))}
  </section>

  <a href="#founders" class="ex-colmark__link">
    <section class="ex-colmark" id="founders">
      <h2 class="ex-colmark__text">FOUNDING SUPPORTERS</h2>
    </section>
  </a>

  <p class="founders-intro">The first fifteen readers who pledged. Every name below is here because they put a pledge in before public launch. Slots sixteen onward open as new readers pledge. We do not sort by amount. We sort by order of arrival.</p>

  <section class="founders">
    {founders.map((s) => (
      <article class="founder">
        <span class="founder__num">{s.n}</span>
        <div>
          <h3 class="founder__name">{s.name}</h3>
          <p class="founder__hood">{s.hood}</p>
        </div>
      </article>
    ))}
    <article class="founder founder--open">
      <span class="founder__num">16</span>
      <div>
        <h3 class="founder__name">Your name here.</h3>
        <p class="founder__hood">First open slot. Pledge any tier to claim it.</p>
      </div>
    </article>
  </section>

  <p class="founders-foot"><a href="mailto:eric@seod.com?subject=keepers%20founding%20supporter" class="founders-foot__cta">Pledge to be number 16 &rarr;</a></p>

  <!-- WORK WITH US — link strip surfacing the 4 conversion paths -->
  <section class="work-with-strip" aria-label="Work with the keepers">
    <p class="work-with-strip__label">WORK WITH US</p>
    <ul class="work-with-strip__list">
      <li><a href="/partners">Partner packages</a></li>
      <li><a href="/tell-your-story">Tell us your story</a></li>
      <li><a href="/submit">Send a tip</a></li>
      <li><a href="/team#hiring">We're hiring</a></li>
    </ul>
  </section>

  <style>
    .tiers { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; padding: 0 12px 48px; }
    .tier { padding: 28px; border: 1px solid var(--rule); background: var(--paper-2); position: relative; }
    .tier--featured { background: var(--ink); color: var(--paper); border-color: var(--ink); }
    .tier--featured .tier__price, .tier--featured .tier__what { color: rgba(244,241,234,0.85); }
    .tier__badge { position: absolute; top: -12px; left: 16px; background: var(--ink); color: var(--paper); padding: 5px 12px; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; }
    .tier--featured .tier__badge { background: var(--paper); color: var(--ink); }
    .tier__price { font-size: 11px; letter-spacing: 0.18em; color: var(--muted); margin: 0 0 12px; text-transform: uppercase; }
    .tier__name { font-family: var(--display); font-size: clamp(28px, 3vw, 44px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 16px; }
    .tier__what { font-size: 14px; line-height: 1.5; margin: 0; }
    .tier__pledge {
      display: block;
      margin-top: 18px;
      padding-top: 14px;
      border-top: 1px solid var(--rule);
      font-size: 11px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink);
      transition: opacity 150ms;
    }
    .tier__pledge:hover { opacity: 0.6; }
    .tier--featured .tier__pledge {
      border-top-color: rgba(244,241,234,0.3);
      color: var(--paper);
    }

    .support-hero-cta {
      display: inline-block;
      margin-top: 28px;
      padding: 16px 28px;
      background: var(--ink);
      color: var(--paper);
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      transition: opacity 200ms;
    }
    .support-hero-cta:hover { opacity: 0.85; }

    .split { padding: 0 12px 48px; }
    .split__row { display: grid; grid-template-columns: 320px 1fr; gap: 40px; padding: 44px 0; border-top: 1px solid var(--rule); align-items: start; }
    .split__row:last-child { border-bottom: 1px solid var(--rule); }
    .split__pct { font-family: var(--display); font-size: clamp(56px, 7.5vw, 100px); line-height: 1; padding-right: 16px; }
    .split__label { font-family: var(--display); font-size: 22px; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 8px; padding-top: 18px; }
    .split__detail { font-size: 14px; line-height: 1.55; color: var(--muted); margin: 0; max-width: 56ch; }

    .orgs { padding: 0 12px 48px; }
    .org { display: grid; grid-template-columns: 80px 1fr; gap: 28px; padding: 28px 0; border-top: 1px solid var(--rule); align-items: baseline; }
    .org:last-child { border-bottom: 1px solid var(--rule); }
    .org__num { font-family: var(--display); font-size: 36px; line-height: 1; color: var(--ink); }
    .org__name { font-family: var(--display); font-size: clamp(22px, 2.4vw, 32px); text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 6px; }
    .org__what { font-size: 14px; line-height: 1.55; color: var(--muted); margin: 0; }

    .founders-intro {
      padding: 32px 12px 0;
      max-width: 720px;
      font-size: 15px;
      line-height: 1.6;
      color: var(--ink);
      margin: 0;
    }
    .founders {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0 32px;
      padding: 24px 12px 32px;
    }
    .founder {
      display: grid;
      grid-template-columns: 56px 1fr;
      gap: 18px;
      padding: 22px 0;
      border-top: 1px solid var(--rule);
      align-items: baseline;
    }
    .founder:nth-last-child(-n+2) { border-bottom: 1px solid var(--rule); }
    .founder__num {
      font-family: var(--display);
      font-size: 24px;
      line-height: 1;
      color: var(--muted);
    }
    .founder__name {
      font-family: var(--display);
      font-size: 22px;
      line-height: 1.15;
      letter-spacing: -0.005em;
      margin: 0 0 4px;
      color: var(--ink);
    }
    .founder__hood {
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--muted);
      margin: 0;
    }
    .founder--open .founder__num { color: var(--ink); }
    .founder--open .founder__name { font-style: italic; }
    .founders-foot {
      padding: 8px 12px 56px;
      margin: 0;
    }
    .founders-foot__cta {
      display: inline-block;
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--ink);
      border-bottom: 2px solid var(--ink);
      padding-bottom: 4px;
    }
    .founders-foot__cta:hover { opacity: 0.6; }
    @media (max-width: 640px) {
      .founders { grid-template-columns: 1fr; gap: 0; }
      .founder { grid-template-columns: 48px 1fr; gap: 14px; padding: 18px 0; }
    }

    @media (max-width: 980px) { .tiers { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 640px) { .tiers { grid-template-columns: 1fr; } .split__row { grid-template-columns: 1fr; } .org { grid-template-columns: 1fr; gap: 8px; } }

    /* Work-with-us link strip — horizontal row of 4 destinations */
    .work-with-strip { max-width: 1100px; margin: 56px auto; padding: 32px 12px; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
    .work-with-strip__label { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0 0 14px; }
    .work-with-strip__list { display: flex; flex-wrap: wrap; gap: 16px 36px; list-style: none; padding: 0; margin: 0; }
    .work-with-strip__list a { font-family: var(--display); font-size: clamp(20px, 2.2vw, 30px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; color: var(--ink); border-bottom: 1px solid currentColor; padding-bottom: 2px; transition: opacity 150ms; }
    .work-with-strip__list a:hover { opacity: 0.55; }
  </style>
</ExhibitionLayout>
