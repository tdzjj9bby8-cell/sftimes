---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';

/**
 * Per GOOGLE-NEWS-AUDIT-AND-PLAN.md Phase 4: contact-driven 2-lane model.
 * Lane A: Fund (Zelle, bank, check). Lane B: Volunteer (3 roles).
 * No Stripe checkout. No suggested tier amounts. No fabricated supporter
 * count or fabricated subscriber count. Gifts are not tax-deductible
 * (SF Times is for-profit).
 */

const orgs = [
  { n: '01', name: 'SF-MARIN FOOD BANK',     what: 'Feeds 53,000 households a week across SF and Marin.' },
  { n: '02', name: 'LA COCINA',              what: 'Mission incubator for immigrant women food entrepreneurs.' },
  { n: '03', name: '826 VALENCIA',           what: 'Youth writing programs across the city, free, with named tutors.' },
  { n: '04', name: 'LARKIN STREET YOUTH',    what: 'Housing and case work for young people without a bed.' },
  { n: '05', name: 'SELF-HELP FOR ELDERLY',  what: 'Citywide senior services, delivered in English, Cantonese, and Mandarin.' },
];

const volunteerRoles = [
  {
    name: 'PHOTO SUPPORT',
    sub: 'Extra eyes and lenses on Saturday shoots.',
    what: 'Especially when Kiwi is booked. Available-light reportorial work only, no staged.',
    subject: 'Volunteer · Photo support',
  },
  {
    name: 'NEIGHBORHOOD TIPSTERS',
    sub: 'Notice a keeper in your corridor.',
    what: 'Send us 3 sentences. We do not publish your name unless you want us to.',
    subject: 'Volunteer · Neighborhood tipster',
  },
  {
    name: 'COPY-EDIT',
    sub: 'Extra read on the Saturday letter before it goes out.',
    what: 'Strong attention to detail required. Roughly 30 minutes per week.',
    subject: 'Volunteer · Copy-edit',
  },
];
---
<ExhibitionLayout
  title="KEEP IT ALIVE · The Keepers · SF Times"
  description="Reader-funded. Two ways to support: fund the publication (Zelle, bank, check) or volunteer (photo support, tipsters, copy-edit). Pre-launch. Contact the editor directly."
  active="support"
>
  <ExhibitionMasthead
    slot="masthead"
    title="KEEP IT ALIVE"
    subscript="2 LANES"
    cutouts={[]}
  />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">READER-FUNDED · NO BANNER ADS · NO PAYWALL</p>
    <h1 class="ex-prose__title">YOU READ IT FREE.<br>SOMEONE HAS<br>TO FUND IT.</h1>
    <p>Two ways in: fund the publication with money, or volunteer your time on a real role. No tiers, no suggested amounts, no checkout page. Both lanes route through the editor directly.</p>
  </article>

  <!-- LANE A: FUND -->
  <a href="#fund" class="ex-colmark__link">
    <section class="ex-colmark" id="fund">
      <h2 class="ex-colmark__text">LANE A: FUND THE PUBLICATION</h2>
    </section>
  </a>

  <section class="lane">
    <div class="lane__intro">
      <p>Three payment paths. You pick the amount. You pick the cadence. We send a thank-you and your name goes on the supporters wall if you want it there.</p>
      <p class="lane__legal"><strong>SF Times is a for-profit publication. Gifts are not tax-deductible.</strong> If you need a tax-deductible donation, the five named charities below are good places to send it directly.</p>
    </div>

    <div class="paths">
      <article class="path">
        <p class="path__label">PATH 01</p>
        <h3 class="path__name">ZELLE</h3>
        <p class="path__what">Fastest path. Direct bank transfer, no fees.<!-- TODO: Eric provides Zelle email/phone. Currently routes to mailto. --></p>
        <a class="path__cta" href="mailto:support@sftimes.com?subject=Zelle%20support%20%2D%20need%20handle">EMAIL FOR ZELLE HANDLE &rarr;</a>
      </article>

      <article class="path">
        <p class="path__label">PATH 02</p>
        <h3 class="path__name">BANK TRANSFER / WIRE</h3>
        <p class="path__what">For larger or recurring support. We send routing details on request.</p>
        <a class="path__cta" href="mailto:support@sftimes.com?subject=Bank%20transfer%20support%20%2D%20need%20routing">EMAIL FOR ROUTING &rarr;</a>
      </article>

      <article class="path">
        <p class="path__label">PATH 03</p>
        <h3 class="path__name">CHECK BY MAIL</h3>
        <p class="path__what">Old school works. We send mailing address on request.</p>
        <a class="path__cta" href="mailto:support@sftimes.com?subject=Check%20by%20mail%20support%20%2D%20need%20address">EMAIL FOR ADDRESS &rarr;</a>
      </article>
    </div>
  </section>

  <!-- LANE B: VOLUNTEER -->
  <a href="#volunteer" class="ex-colmark__link">
    <section class="ex-colmark" id="volunteer">
      <h2 class="ex-colmark__text">LANE B: VOLUNTEER</h2>
    </section>
  </a>

  <section class="lane">
    <div class="lane__intro">
      <p>Three real roles. Real time commitment, real bylines or named credits where it makes sense. Email the editor with the role you want and a sentence about why.</p>
    </div>

    <div class="roles">
      {volunteerRoles.map((r) => (
        <article class="role">
          <h3 class="role__name">{r.name}</h3>
          <p class="role__sub">{r.sub}</p>
          <p class="role__what">{r.what}</p>
          <a class="role__cta" href={`mailto:support@sftimes.com?subject=${encodeURIComponent(r.subject)}`}>EMAIL THE EDITOR &rarr;</a>
        </article>
      ))}
    </div>
  </section>

  <!-- WHERE THE MONEY GOES: architectural commitment, not a published metric -->
  <a href="#money" class="ex-colmark__link">
    <section class="ex-colmark" id="money">
      <h2 class="ex-colmark__text">WHERE THE MONEY GOES</h2>
    </section>
  </a>

  <section class="split">
    <div class="split__row">
      <span class="split__pct">75%</span>
      <div>
        <p class="split__label">OPERATIONS</p>
        <p class="split__detail">Editor pay, hosting, photography, and the costs of shipping the Saturday letter and the daily Brief. Commitment, not yet audited because the publication has not run a full revenue year. First annual audit publishes 12 months after the first paid Profile.</p>
      </div>
    </div>
    <div class="split__row">
      <span class="split__pct">25%</span>
      <div>
        <p class="split__label">LOCAL BAY AREA CHARITIES</p>
        <p class="split__detail">The five organizations below. Distributed annually once the publication has revenue to distribute. Reported on the corrections page so you can check our math.</p>
      </div>
    </div>
  </section>

  <a href="#orgs" class="ex-colmark__link">
    <section class="ex-colmark" id="orgs">
      <h2 class="ex-colmark__text">THE FIVE ORGS</h2>
    </section>
  </a>

  <section class="orgs">
    {orgs.map((o) => (
      <article class="org">
        <span class="org__num">{o.n}</span>
        <div>
          <h3 class="org__name">{o.name}</h3>
          <p class="org__what">{o.what}</p>
        </div>
      </article>
    ))}
  </section>

  <!-- WORK WITH US strip preserved from prior interlinking -->
  <section class="work-with-strip" aria-label="Work with the keepers">
    <p class="work-with-strip__label">WORK WITH US</p>
    <ul class="work-with-strip__list">
      <li><a href="/partners">Partner packages</a></li>
      <li><a href="/tell-your-story">Tell us your story</a></li>
      <li><a href="/submit">Send a tip</a></li>
      <li><a href="/team#hiring">We're hiring</a></li>
    </ul>
  </section>

  <style>
    /* LANE intro + structure */
    .lane { padding: 0 12px 48px; max-width: 1080px; margin: 0 auto; }
    .lane__intro { max-width: 720px; margin: 0 auto 32px; padding: 0 4px; }
    .lane__intro p { font-size: 15px; line-height: 1.6; color: var(--ink); margin: 0 0 16px; }
    .lane__legal { font-size: 13px; color: var(--muted); line-height: 1.55; padding: 14px 18px; background: var(--paper-2); border-left: 3px solid var(--ink); }
    .lane__legal strong { color: var(--ink); }

    /* PATHS (fund) and ROLES (volunteer) share the same 3-card grid pattern */
    .paths, .roles { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
    @media (max-width: 880px) { .paths, .roles { grid-template-columns: 1fr; } }
    .path, .role { padding: 28px; border: 1px solid var(--rule); background: var(--paper-2); display: flex; flex-direction: column; gap: 12px; }
    .path__label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0; }
    .path__name, .role__name { font-family: var(--display); font-size: clamp(22px, 2.4vw, 30px); line-height: 1.1; margin: 0; text-transform: uppercase; letter-spacing: -0.005em; }
    .path__what, .role__what { font-size: 14px; line-height: 1.55; margin: 0; color: var(--ink); }
    .role__sub { font-size: 13px; line-height: 1.45; margin: 0; color: var(--muted); font-style: italic; }
    .path__cta, .role__cta { margin-top: auto; padding-top: 12px; border-top: 1px solid var(--rule); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--ink); }
    .path__cta:hover, .role__cta:hover { opacity: 0.6; }

    /* WHERE THE MONEY GOES: 75/25 split */
    .split { padding: 0 12px 48px; max-width: 1080px; margin: 0 auto; }
    .split__row { display: grid; grid-template-columns: 320px 1fr; gap: 40px; padding: 44px 0; border-top: 1px solid var(--rule); align-items: start; }
    .split__row:last-child { border-bottom: 1px solid var(--rule); }
    .split__pct { font-family: var(--display); font-size: clamp(56px, 7.5vw, 100px); line-height: 1; padding-right: 16px; }
    .split__label { font-family: var(--display); font-size: 22px; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 8px; padding-top: 18px; }
    .split__detail { font-size: 14px; line-height: 1.55; color: var(--muted); margin: 0; max-width: 56ch; }
    @media (max-width: 640px) { .split__row { grid-template-columns: 1fr; } }

    /* FIVE ORGS */
    .orgs { padding: 0 12px 48px; max-width: 1080px; margin: 0 auto; }
    .org { display: grid; grid-template-columns: 80px 1fr; gap: 28px; padding: 28px 0; border-top: 1px solid var(--rule); align-items: baseline; }
    .org:last-child { border-bottom: 1px solid var(--rule); }
    .org__num { font-family: var(--display); font-size: 36px; line-height: 1; color: var(--ink); }
    .org__name { font-family: var(--display); font-size: clamp(22px, 2.4vw, 32px); text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 6px; }
    .org__what { font-size: 14px; line-height: 1.55; color: var(--muted); margin: 0; }
    @media (max-width: 640px) { .org { grid-template-columns: 1fr; gap: 8px; } }

    /* Work-with-us link strip: horizontal row of 4 destinations */
    .work-with-strip { max-width: 1100px; margin: 56px auto; padding: 32px 12px; border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }
    .work-with-strip__label { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0 0 14px; }
    .work-with-strip__list { display: flex; flex-wrap: wrap; gap: 16px 36px; list-style: none; padding: 0; margin: 0; }
    .work-with-strip__list a { font-family: var(--display); font-size: clamp(20px, 2.2vw, 30px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; color: var(--ink); border-bottom: 1px solid currentColor; padding-bottom: 2px; transition: opacity 150ms; }
    .work-with-strip__list a:hover { opacity: 0.55; }
  </style>
</ExhibitionLayout>
