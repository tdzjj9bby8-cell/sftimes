---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="work with us — the keepers."
  description="Two ways into the keepers: editorial sponsorship and named placement. Six packages, capped, named, audited."
  current="partners"
>

  <!-- HERO -->
  <section class="wwu-hero container container-narrow">
    <p class="ui-label">work with us</p>
    <h1>tell your story. reach <em>saturday</em> morning.</h1>
    <p class="wwu-hero__lead">
      Five thousand newsletter subscribers and growing. One issue every saturday. Readers who pay attention because we earn it. Two ways in.
    </p>
    <div class="wwu-hero__metrics">
      <div><span class="wwu-metric__num">5,000</span><span class="wwu-metric__label">saturday subscribers</span></div>
      <div><span class="wwu-metric__num">57</span><span class="wwu-metric__label">issues live</span></div>
      <div><span class="wwu-metric__num">100%</span><span class="wwu-metric__label">human bylines</span></div>
      <div><span class="wwu-metric__num">0</span><span class="wwu-metric__label">banner ads, ever</span></div>
    </div>
  </section>

  <!-- ARTICLE PACKAGES -->
  <section class="wwu-section container container-narrow">
    <p class="ui-label wwu-section__eyebrow">option one · editorial sponsorship</p>
    <h2 class="wwu-section__title">we write the story. you keep the <em>backlink</em>, forever.</h2>
    <p class="wwu-section__lead">
      Three article packages. Each one is reported and written by a named editor in our voice, with you as the subject. Lives on the keepers site forever. Includes a DoFollow backlink to your site. Customizable scope, tone, and length.
    </p>

    <div class="wwu-tiers">

      <article class="wwu-tier">
        <p class="wwu-tier__price">starting at $1,500</p>
        <h3 class="wwu-tier__name">the <em>profile</em>.</h3>
        <p class="wwu-tier__sub">One feature, one backlink, one saturday newsletter.</p>
        <ul class="wwu-tier__list">
          <li>1,200-word original feature on you or your business, reported and written by a named keepers editor</li>
          <li>One DoFollow backlink to your site, placed naturally in the body</li>
          <li>Lives at sftimes.com/stories/[slug] forever, indexed in google</li>
          <li>Promoted in one saturday newsletter to all subscribers</li>
          <li>One round of revisions before publish</li>
          <li>Editor-labeled "in collaboration with" tag, per our standards</li>
        </ul>
      </article>

      <article class="wwu-tier wwu-tier--featured">
        <span class="wwu-tier__badge">most chosen</span>
        <p class="wwu-tier__price">starting at $3,500</p>
        <h3 class="wwu-tier__name">the <em>feature</em>.</h3>
        <p class="wwu-tier__sub">Deeper reporting, multiple links, homepage rotation.</p>
        <ul class="wwu-tier__list">
          <li>2,500-word in-depth piece. We come onsite, photograph, interview your people</li>
          <li>Up to three DoFollow backlinks across the piece</li>
          <li>Lives forever, indexed in google</li>
          <li>Featured slot on the homepage for one full week</li>
          <li>Promoted in one saturday newsletter, plus a tease the following week</li>
          <li>Three rounds of revisions, custom photography by our staff photographer included</li>
          <li>Editor-labeled "in collaboration with" tag</li>
        </ul>
      </article>

      <article class="wwu-tier">
        <p class="wwu-tier__price">starting at $7,500</p>
        <h3 class="wwu-tier__name">the <em>bespoke</em>.</h3>
        <p class="wwu-tier__sub">Personal brand piece, durable, multi-channel.</p>
        <ul class="wwu-tier__list">
          <li>3,500-word durable article. Origin story, what you keep, why it matters now</li>
          <li>Up to five DoFollow backlinks placed where you want them</li>
          <li>Lives forever, indexed in google, fully customizable layout</li>
          <li>Homepage hero slot for two weeks, sticky position in the archive</li>
          <li>Promoted in two saturday newsletters, sponsor mention in a third</li>
          <li>Unlimited rounds of revisions, custom photography and short video b-roll included</li>
          <li>Personal brand advisory call with the editor before reporting begins</li>
          <li>Editor-labeled "in collaboration with" tag</li>
        </ul>
      </article>

    </div>
  </section>

  <!-- UNDERWRITING PACKAGES -->
  <section class="wwu-section container container-narrow">
    <p class="ui-label wwu-section__eyebrow">option two · editorial underwriting</p>
    <h2 class="wwu-section__title">no banner ads. ever. <em>better</em> ways in.</h2>
    <p class="wwu-section__lead">
      We promised readers no banner ads, no tracking pixels, no paywall. We meant it. So we built underwriting products that put your name in front of readers the way public radio does: stated plainly, by the editor, in the keepers voice. Three packages.
    </p>

    <div class="wwu-tiers">

      <article class="wwu-tier">
        <p class="wwu-tier__price">starting at $500 / saturday</p>
        <h3 class="wwu-tier__name">the <em>patron</em>.</h3>
        <p class="wwu-tier__sub">A named sponsor line at the close of one saturday letter.</p>
        <ul class="wwu-tier__list">
          <li>Editor-written sponsor credit at the close of one saturday newsletter: "this saturday's letter supported by [you]"</li>
          <li>Text only, no logos, no images, no banners, no trackers</li>
          <li>Same credit appears on the archived web version of that issue, forever</li>
          <li>Name listed on the supporters wall on the about page</li>
          <li>One patron per saturday letter, four slots per month</li>
        </ul>
      </article>

      <article class="wwu-tier wwu-tier--featured">
        <span class="wwu-tier__badge">most chosen</span>
        <p class="wwu-tier__price">starting at $1,200 / saturday</p>
        <h3 class="wwu-tier__name">the <em>co-presented</em>.</h3>
        <p class="wwu-tier__sub">A full saturday issue, presented in collaboration with your name.</p>
        <ul class="wwu-tier__list">
          <li>"presented by [you]" credit at the top of one saturday issue, on the newsletter and the web version</li>
          <li>Editor-written 80-word sponsor blurb inside the issue, in keepers voice, you approve before publish</li>
          <li>Name appears on the homepage feature card alongside the lead story for that week</li>
          <li>Inclusion in the print archive page for that issue when the annual zine prints</li>
          <li>One co-presenter per saturday, four caps per month, no overlap with article packages</li>
        </ul>
      </article>

      <article class="wwu-tier">
        <p class="wwu-tier__price">starting at $18,000 / year</p>
        <h3 class="wwu-tier__name">the <em>pillar</em>.</h3>
        <p class="wwu-tier__sub">Annual partner, masthead recognition, print and event.</p>
        <ul class="wwu-tier__list">
          <li>"the keepers, presented this year with [you]" credit on the homepage masthead for twelve months</li>
          <li>Four co-presented saturday issues a year, one per quarter, your pick of dates</li>
          <li>Back cover credit on the annual print zine, mailed to every supporter</li>
          <li>Name on the about page as a founding underwriter, perpetual</li>
          <li>Co-host slot at the annual reader dinner, named on the invitation</li>
          <li>One pillar per year, exclusive, first-look offered to last year's pillar</li>
        </ul>
      </article>

    </div>
  </section>

  <!-- WHY THIS MATTERS -->
  <section class="wwu-why container container-narrow">
    <h2 class="wwu-why__title">why these instead of <em>banners</em>.</h2>
    <p>Readers gave us the goodwill of a no-ad, no-tracking publication. We are not going to spend that goodwill on rectangular boxes that pretend to be content. The underwriting model is older than banner ads and works better for the kind of brand that wants to be associated with a serious publication, not embedded in one against the reader's will. Your name gets stated, by name, by us, in our voice. The reader knows who you are. The reader doesn't feel sold to.</p>
    <p>If your goal is volume clicks, this is not the right buy. If your goal is to be the brand a saturday reader trusts because a saturday writer named you, this is the right buy.</p>
  </section>

  <!-- EDITORIAL FIREWALL -->
  <section class="wwu-firewall container container-narrow">
    <h2 class="wwu-firewall__title">the editorial firewall.</h2>
    <p class="wwu-firewall__line">Sponsors do <em>not</em> pick stories.</p>
    <p>The editor who writes a piece is named on the piece. Every collaboration is labeled. Promoted entries on best of lists carry a labeled badge and must still meet the editorial bar. We will say no to sponsorship requests that conflict with reporting we have planned. If you want to be in this magazine, your story has to actually be worth telling. That's the deal.</p>
    <p><a href="/standards">read our standards →</a></p>
  </section>

  <!-- CONTACT -->
  <section class="wwu-contact">
    <div class="wwu-contact__inner container container-narrow">
      <h2 class="wwu-contact__title">start a <em>conversation</em>.</h2>
      <p class="wwu-contact__sub">All pricing above is a starting point. We gate the real number behind a conversation so we can match the package to your business. Tell us what you're working on, what you want readers to know, and what success looks like. We reply within two business days.</p>
      <div class="wwu-contact__methods">
        <a class="wwu-contact__method" href="mailto:eric@seod.com?subject=keepers%20partnership%20inquiry">
          <span class="wwu-contact__kind">email</span>
          <span class="wwu-contact__val">eric@seod.com</span>
        </a>
        <a class="wwu-contact__method" href="tel:+17077183579">
          <span class="wwu-contact__kind">phone or text</span>
          <span class="wwu-contact__val">707·718·3579</span>
        </a>
      </div>
      <p class="wwu-contact__note">Mention the package name above and we will send a one-pager back within two business days with concrete pricing, timeline, and the editor we'd assign.</p>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .wwu-hero {
    padding-top: var(--s-9);
    padding-bottom: var(--s-8);
    border-bottom: 1px solid var(--rule);
  }
  .wwu-hero h1 {
    margin-block: var(--s-3) var(--s-5);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
    max-width: 20ch;
  }
  .wwu-hero h1 :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .wwu-hero__lead {
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 1.6vw, 1.5rem);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0 0 var(--s-7);
  }
  .wwu-hero__metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s-5);
    padding-top: var(--s-5);
    border-top: 1px solid var(--rule);
  }
  .wwu-hero__metrics > div { display: flex; flex-direction: column; gap: var(--s-1); }
  .wwu-metric__num {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .wwu-metric__label {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--fog);
  }

  /* SECTIONS */
  .wwu-section { padding-block: var(--s-9); border-bottom: 1px solid var(--rule); }
  .wwu-section__eyebrow { color: var(--terracotta); margin-bottom: var(--s-3); }
  .wwu-section__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.022em;
    margin: 0 0 var(--s-5);
    max-width: 22ch;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .wwu-section__title :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .wwu-section__lead {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0 0 var(--s-7);
  }

  /* TIERS */
  .wwu-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-5);
  }
  .wwu-tier {
    padding: var(--s-6);
    border: 1px solid var(--rule);
    background: var(--bg);
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    position: relative;
    transition: border-color var(--t-fast) var(--ease-out);
  }
  .wwu-tier:hover { border-color: var(--ink); }
  .wwu-tier--featured {
    border-color: var(--terracotta);
    border-width: 2px;
    background: var(--paper);
  }
  .wwu-tier__badge {
    position: absolute;
    top: -12px;
    left: var(--s-5);
    background: var(--terracotta);
    color: var(--bg);
    padding: 5px var(--s-3);
    font-family: var(--font-ui);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    font-weight: 500;
  }
  .wwu-tier__price {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    color: var(--fog);
    margin: 0;
  }
  .wwu-tier__name {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .wwu-tier__name :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .wwu-tier__sub {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0 0 var(--s-3);
  }
  .wwu-tier__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--s-2);
    border-top: 1px solid var(--rule);
    padding-top: var(--s-4);
  }
  .wwu-tier__list li {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--ink-soft);
    padding-left: var(--s-4);
    position: relative;
  }
  .wwu-tier__list li::before {
    content: "·";
    position: absolute;
    left: var(--s-2);
    color: var(--terracotta);
    font-weight: bold;
  }

  /* WHY THIS MATTERS */
  .wwu-why {
    padding-block: var(--s-9);
    background: var(--paper);
    margin-block: var(--s-9) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }
  .wwu-why__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.022em;
    margin: 0 0 var(--s-5);
    max-width: 22ch;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .wwu-why__title :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .wwu-why p {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 62ch;
    margin: 0 0 var(--s-4);
  }

  /* FIREWALL */
  .wwu-firewall { padding-block: var(--s-9); border-bottom: 1px solid var(--rule); }
  .wwu-firewall__title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 0 0 var(--s-4);
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .wwu-firewall__line {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.2;
    margin: 0 0 var(--s-4);
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .wwu-firewall__line :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .wwu-firewall p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 60ch;
    margin: 0 0 var(--s-4);
  }
  .wwu-firewall a {
    color: var(--terracotta);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }

  /* CONTACT */
  .wwu-contact {
    background: var(--ink);
    color: var(--bg);
    padding-block: var(--s-9);
  }
  .wwu-contact__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1;
    letter-spacing: -0.022em;
    margin: 0 0 var(--s-5);
    color: var(--bg);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .wwu-contact__title :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .wwu-contact__sub {
    font-family: var(--font-body);
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    line-height: 1.5;
    color: rgba(244,241,234,0.85);
    max-width: 56ch;
    margin: 0 0 var(--s-7);
  }
  .wwu-contact__methods {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--s-4);
    margin-bottom: var(--s-6);
  }
  .wwu-contact__method {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    padding: var(--s-5);
    border: 1px solid rgba(244,241,234,0.3);
    color: var(--bg);
    transition: background var(--t-fast) var(--ease-out), border-color var(--t-fast) var(--ease-out);
  }
  .wwu-contact__method:hover {
    background: rgba(244,241,234,0.08);
    border-color: var(--bg);
  }
  .wwu-contact__kind {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    color: rgba(244,241,234,0.6);
  }
  .wwu-contact__val {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--bg);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .wwu-contact__note {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: rgba(244,241,234,0.7);
    max-width: 56ch;
    margin: 0;
  }

  /* MOBILE */
  @media (max-width: 1024px) {
    .wwu-tiers { grid-template-columns: 1fr; }
    .wwu-hero__metrics { grid-template-columns: repeat(2, 1fr); gap: var(--s-4); }
  }
  @media (max-width: 880px) {
    .wwu-contact__methods { grid-template-columns: 1fr; }
  }
</style>
