---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';

/**
 * Three distinct products, two tiers each. Per GOOGLE-NEWS-AUDIT-AND-PLAN.md
 * Phase 4 spec, pre-launch language only: no invented audience metrics, no
 * Stripe checkout, no fabricated case-study numbers. Editorial firewall on
 * every placement, integrity caps surfaced.
 */

// THE PROFILE: a Saturday Profile feature article with backlink and forever URL.
const profilePkgs = [
  {
    price: '$1,500',
    name: 'THE PROFILE · STANDARD',
    sub: 'One Saturday Profile feature, 1,200 to 2,000 words.',
    featured: true,
    features: [
      '1,200 to 2,000-word feature in the SF Times voice',
      'Original photography by Kiwi, available-light reportorial',
      'DoFollow backlink in the body, indexed by Google',
      'Permanent permalink at sftimes.com forever',
      '"In Collaboration With" chip above the headline',
      'Editorial firewall disclosure block on the page',
      'Optional 30-second print-zine credit when quarterly print ships',
    ],
  },
  {
    price: '$2,500',
    name: 'THE PROFILE · EXTENDED',
    sub: 'Deeper reporting, 2,000 to 3,500 words.',
    features: [
      '2,000 to 3,500-word in-depth feature',
      'Original photography by Kiwi, multiple frames',
      'DoFollow backlink in the body',
      'Permanent permalink at sftimes.com forever',
      '"In Collaboration With" chip above the headline',
      'Editorial firewall disclosure block on the page',
      'Optional 30-second print-zine credit when quarterly print ships',
    ],
  },
];

// THE SPOTLIGHT: newsletter-only placement in one Saturday letter.
// No permanent permalink page. Higher cadence than Profile, lower commitment.
const spotlightPkgs = [
  {
    price: '$350',
    name: 'THE SPOTLIGHT · MID-LETTER',
    sub: '200 to 300-word block, mid-letter placement.',
    features: [
      '200 to 300-word summary block inside one Saturday letter',
      'Newsletter only, no permanent permalink page',
      'One editor-selected photo',
      'Outbound link to your site',
      'Labeled "Spotlight" placement',
      'Mid-letter position (above-fold sold first)',
    ],
  },
  {
    price: '$500',
    name: 'THE SPOTLIGHT · ABOVE-FOLD',
    sub: '200 to 300-word block, top of letter.',
    featured: true,
    features: [
      '200 to 300-word summary block inside one Saturday letter',
      'Newsletter only, no permanent permalink page',
      'One editor-selected photo',
      'Outbound link to your site',
      'Labeled "Spotlight" placement',
      'Above-fold position, first paid block readers see',
    ],
  },
];

// THE BRIEF MENTION: inline block at top of one daily Brief reader surface.
// Reader-surface only. Not in RSS, JSON Feed, or category landings.
const briefPkgs = [
  {
    price: '$100 / DAY',
    name: 'THE BRIEF MENTION · ONE DAY',
    sub: 'Inline mention at top of one daily Brief.',
    features: [
      '"TODAY\'S BRIEF IS BROUGHT TO YOU BY [name + line + link]"',
      'Inline block at top of /brief/{date} archive page',
      'Reader surface only',
      'Not in RSS feed, JSON Feed, or category landings',
      'Preserves syndicated-feed editorial integrity',
    ],
  },
  {
    price: '$400 / 5 DAYS',
    name: 'THE BRIEF MENTION · FIVE DAYS',
    sub: 'Five Brief days at a $100 discount.',
    featured: true,
    features: [
      'Same inline placement, five days',
      'Days do not need to be consecutive',
      'Reader surface only, not in RSS or JSON Feed or categories',
      '$100 off versus five single-day buys',
      'One Brief sponsor per day, max one same-sponsor in any 30-day window',
    ],
  },
];

const faqs = [
  { q: 'Can we pick the angle of the article?', a: 'You can suggest one. The editor selects the angle. Editorial firewall holds: if we cannot honestly cover what you want covered, we tell you on the intro call, not after.' },
  { q: 'What if you decline the project?', a: 'We talk it through first. We will not accept money for a piece we cannot write with integrity. If the project is not a fit, we say so on the intro call and refer you to honest alternatives.' },
  { q: 'How long until the Profile ships?', a: 'Standard typically lands in 3 to 4 weeks from contract signoff. Extended in 4 to 6. We block one Saturday slot per partner and do not double-book.' },
  { q: 'Is the backlink really DoFollow?', a: 'Yes. Marked DoFollow in the HTML and indexed by Google. We do not believe in NoFollow trickery. The article lives at a real URL on a real publication, which carries more SEO weight than a directory listing.' },
  { q: 'What does the Spotlight look like in the letter?', a: 'A 200 to 300-word block with one photo and an outbound link, labeled "Spotlight." Above-fold is the first paid block readers see. Mid-letter sits between sections. Both are clearly differentiated from editorial.' },
  { q: 'Where does the Brief Mention appear?', a: 'At the top of one daily Brief archive page at /brief/{date}. Reader surface only. Not in the RSS feed, not in the JSON Feed, not in category landing pages. Syndicated-feed integrity is the reason.' },
  { q: 'Why no banner ads?', a: 'Because we promised our readers. The promise is the product. We monetize through editorial sponsorship instead, which keeps readers reading and keeps your name in front of an audience that trusts what they read.' },
  { q: 'Can we see what the placement looks like before signing?', a: 'Yes. Ask on the intro call and we send a sample article, sample Spotlight, and sample Brief Mention. We treat every partner the same way.' },
  { q: 'How do we pay?', a: 'Check, bank transfer, or Zelle. We do not run a Stripe checkout. We invoice once the angle is signed off and ship after payment clears. Refund-if-killed clause applies on the contract.' },
];
---
<ExhibitionLayout
  title="WORK WITH US · The Keepers · SF Times"
  description="Three distinct products: The Profile, The Spotlight, The Brief Mention. Editorial firewall on every placement. Integrity caps in writing. No banner ads, ever."
  active="support"
>
  <ExhibitionMasthead
    slot="masthead"
    title="WORK WITH US"
    subscript="SF TIMES"
    cutouts={[]}
  />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">EDITORIAL PARTNERSHIPS · CAPPED · NAMED · FIREWALL</p>
    <h1 class="ex-prose__title">TELL YOUR STORY.<br>READ FOR REAL.</h1>
    <p>Pre-launch. Founding-supporter cohort building now. Three distinct products: a Saturday Profile feature (The Profile), a 200 to 300-word block in one Saturday letter (The Spotlight), and an inline mention at the top of one daily Brief (The Brief Mention). Editorial firewall on every placement. No banner ads, no pop-ups, no tracking pixels.</p>
  </article>

  <!-- EDITOR'S NOTE -->
  <section class="editor-note">
    <div class="editor-note__inner">
      <p class="editor-note__label">A NOTE FROM THE EDITOR</p>
      <p class="editor-note__body">I pick every sponsor. If a business does not pass the bar we hold the bylines to, I say no on the intro call and you keep your money. The bar is honest: do you treat your people well, are you specific about what you do, and would your story make a Saturday letter or Brief day our readers actually want to open? If yes, let us talk. If you are not sure, the call is the right place to find out.</p>
      <p class="editor-note__sign">Eric, founder &amp; editor</p>
    </div>
  </section>

  <!-- SAMPLE CASE STUDY: illustrative format only, no fabricated metrics -->
  <section class="case">
    <div class="case__head">
      <p class="case__label">SAMPLE CASE STUDY · ILLUSTRATIVE FORMAT</p>
      <h2 class="case__title">What a Saturday Profile partnership looks like.</h2>
      <p class="case__intro">SF Times has not yet shipped a paid sponsored Profile. The card below shows the format a real partnership would take, the framing the editor would use, and the structural deliverables that ship with every placement. The first real case study replaces this card with real numbers and a quote from the partner.</p>
    </div>

    <div class="case__body">
      <div class="case__story">
        <p class="case__story-eyebrow">SAMPLE · IN COLLABORATION WITH [YOUR BUSINESS]</p>
        <h3 class="case__story-title">A Profile of Your Business, in Our Voice</h3>
        <p class="case__story-deck">A 1,200 to 2,000-word reported feature by Eric, with a DoFollow backlink to your site and a permanent URL on sftimes.com that lives forever.</p>
        <a class="case__story-link" href="/stories/olive-branch-roasters-bernal">READ A FORMAT SAMPLE →</a>
      </div>

      <div class="case__metrics">
        <p class="case__metrics-label">STRUCTURAL DELIVERABLES · NOT AUDIENCE PROJECTIONS</p>
        <div class="case__metric"><span class="case__num">1,200+</span><p>WORDS, EDITOR-WRITTEN</p></div>
        <div class="case__metric"><span class="case__num">∞</span><p>DOFOLLOW BACKLINK · FOREVER</p></div>
        <div class="case__metric"><span class="case__num">1</span><p>SATURDAY LETTER PROMOTION</p></div>
        <div class="case__metric"><span class="case__num">∞</span><p>PERMANENT URL · INDEXED</p></div>
      </div>
    </div>

    <p class="case__note">Structural deliverables are real. Audience reach numbers are deliberately not shown until the publication has audited weekly performance to report.</p>
  </section>

  <!-- OVERALL INTEGRITY CAPS: the structural rules across all 3 products -->
  <section class="caps">
    <div class="caps__inner">
      <p class="caps__label">INTEGRITY CAPS · ACROSS EVERY PRODUCT</p>
      <h2 class="caps__title">THE RULES THAT HOLD<br>EVERY PLACEMENT.</h2>
      <ul class="caps__list">
        <li><strong>Editorial firewall.</strong> Every placement carries the firewall language linked to <a href="/standards">/standards</a>. Sponsor approves facts, never angle.</li>
        <li><strong>Editor selects every partner.</strong> Before any money changes hands. If a business cannot pass the editorial bar, we decline on the intro call.</li>
        <li><strong>Fact-check window.</strong> Sponsor sees the draft 72 hours before publish for fact-correction only. Angle is not up for revision.</li>
        <li><strong>Right to kill.</strong> If the sponsor objects to a fact-correct angle and we cannot resolve, we refund the placement fee and kill the piece.</li>
        <li><strong>Combined sponsored-letter cap.</strong> No more than 2 sponsored Saturday letters per year across The Profile + The Spotlight $500 above-fold tier.</li>
        <li><strong>One Brief sponsor per day.</strong> Same sponsor cannot repeat within a rolling 30-day window.</li>
        <li><strong>One Spotlight per Saturday letter.</strong> Mid-letter only when above-fold is unsold. Max 4 Spotlight placements in any rolling 8-week window.</li>
      </ul>
    </div>
  </section>

  <!-- SECTION 1: THE PROFILE -->
  <a href="#profile" class="ex-colmark__link">
    <section class="ex-colmark" id="profile">
      <h2 class="ex-colmark__text">THE PROFILE</h2>
    </section>
  </a>

  <article class="ex-prose">
    <p>A Saturday Profile feature article. Editor-written in the SF Times voice with you as the subject. Original photography by Kiwi. DoFollow backlink. Permanent permalink at sftimes.com. Lives forever, indexed by Google. Standard is 1,200 to 2,000 words; Extended doubles depth.</p>
  </article>

  <!-- Profile mockup -->
  <section class="mock-section">
    <p class="mock-section__label">HOW THE PROFILE APPEARS LIVE</p>
    <div class="mock mock--article">
      <p class="mock__eyebrow">ISSUE №X · BY ERIC · IN COLLABORATION WITH <strong>[YOUR BUSINESS]</strong></p>
      <h3 class="mock__title">A 1,200 TO 2,000-WORD PROFILE OF YOUR BUSINESS, IN OUR VOICE.</h3>
      <p class="mock__deck">Lede paragraph with specifics: what you do, where, since when, why it matters in the neighborhood. Visit at <a href="#mock">yoursite.com</a>.</p>
      <p class="mock__firewall">EDITORIAL FIREWALL: SPONSOR APPROVED FACTS, NOT ANGLE. EDITOR WROTE EVERY WORD.</p>
    </div>
  </section>

  <section class="pkgs pkgs--two">
    {profilePkgs.map((p) => (
      <article class={`pkg${p.featured ? ' pkg--featured' : ''}`}>
        {p.featured && <span class="pkg__badge">MOST CHOSEN</span>}
        <p class="pkg__price">{p.price}</p>
        <h3 class="pkg__name">{p.name}</h3>
        <p class="pkg__sub">{p.sub}</p>
        <ul>{p.features.map((f) => <li>{f}</li>)}</ul>
      </article>
    ))}
  </section>

  <p class="section-cta">Inquire about The Profile: <a href="mailto:partners@sftimes.com?subject=The%20Profile%20inquiry">partners@sftimes.com</a> or call 707-718-3579.</p>

  <!-- SECTION 2: THE SPOTLIGHT -->
  <a href="#spotlight" class="ex-colmark__link">
    <section class="ex-colmark" id="spotlight">
      <h2 class="ex-colmark__text">THE SPOTLIGHT</h2>
    </section>
  </a>

  <article class="ex-prose">
    <p>A 200 to 300-word block in one Saturday letter. Newsletter only, no permanent permalink page. One editor-selected photo, outbound link to your site, labeled "Spotlight" placement. Above-fold is the first paid block readers see; mid-letter sits between sections.</p>
  </article>

  <!-- Spotlight mockup -->
  <section class="mock-section">
    <p class="mock-section__label">HOW THE SPOTLIGHT APPEARS LIVE</p>
    <div class="mock mock--article">
      <span class="mock__chip">THE SPOTLIGHT · IN-LETTER BLOCK</span>
      <p class="mock__eyebrow">SPOTLIGHT · ABOVE-FOLD</p>
      <h3 class="mock__title">[YOUR BUSINESS] · 200 TO 300 WORDS, ONE PHOTO.</h3>
      <p class="mock__deck">Editor-selected photo on the left. Two-paragraph editor-written description on the right with one outbound link. Labeled "Spotlight" so readers know it is paid placement, not editorial.</p>
      <p class="mock__firewall">SPOTLIGHT PLACEMENT · CLEARLY LABELED · NEWSLETTER ONLY</p>
    </div>
  </section>

  <section class="pkgs pkgs--two">
    {spotlightPkgs.map((p) => (
      <article class={`pkg${p.featured ? ' pkg--featured' : ''}`}>
        {p.featured && <span class="pkg__badge">MOST CHOSEN</span>}
        <p class="pkg__price">{p.price}</p>
        <h3 class="pkg__name">{p.name}</h3>
        <p class="pkg__sub">{p.sub}</p>
        <ul>{p.features.map((f) => <li>{f}</li>)}</ul>
      </article>
    ))}
  </section>

  <p class="section-cta">Inquire about The Spotlight: <a href="mailto:partners@sftimes.com?subject=The%20Spotlight%20inquiry">partners@sftimes.com</a> or call 707-718-3579.</p>

  <!-- SECTION 3: THE BRIEF MENTION -->
  <a href="#brief" class="ex-colmark__link">
    <section class="ex-colmark" id="brief">
      <h2 class="ex-colmark__text">THE BRIEF MENTION</h2>
    </section>
  </a>

  <article class="ex-prose">
    <p>An inline block at the top of one daily Brief archive page at /brief/[date]. Reader surface only. Not in RSS, not in JSON Feed, not in category landings. Preserves syndicated-feed editorial integrity. One Brief sponsor per day. Same sponsor cannot repeat within 30 days.</p>
  </article>

  <!-- Brief mockup -->
  <section class="mock-section">
    <p class="mock-section__label">HOW THE BRIEF MENTION APPEARS LIVE</p>
    <div class="mock mock--article">
      <span class="mock__chip">THE BRIEF MENTION · TOP OF DAILY ARCHIVE</span>
      <p class="mock__eyebrow">TODAY'S BRIEF IS BROUGHT TO YOU BY <strong>[YOUR BUSINESS]</strong></p>
      <p class="mock__deck">[Your one-line description and outbound link.] yoursite.com</p>
      <p class="mock__firewall">BRIEF MENTION · READER SURFACE ONLY · NOT IN RSS OR JSON FEED</p>
    </div>
  </section>

  <section class="pkgs pkgs--two">
    {briefPkgs.map((p) => (
      <article class={`pkg${p.featured ? ' pkg--featured' : ''}`}>
        {p.featured && <span class="pkg__badge">MOST CHOSEN</span>}
        <p class="pkg__price">{p.price}</p>
        <h3 class="pkg__name">{p.name}</h3>
        <p class="pkg__sub">{p.sub}</p>
        <ul>{p.features.map((f) => <li>{f}</li>)}</ul>
      </article>
    ))}
  </section>

  <p class="section-cta">Inquire about The Brief Mention: <a href="mailto:partners@sftimes.com?subject=The%20Brief%20Mention%20inquiry">partners@sftimes.com</a> or call 707-718-3579.</p>

  <!-- FAQ -->
  <a href="#faq" class="ex-colmark__link">
    <section class="ex-colmark" id="faq">
      <h2 class="ex-colmark__text">QUESTIONS, ANSWERED.</h2>
    </section>
  </a>

  <section class="faq">
    {faqs.map((f) => (
      <details class="faq__item">
        <summary class="faq__q">{f.q}</summary>
        <p class="faq__a">{f.a}</p>
      </details>
    ))}
  </section>

  <section class="contact" id="contact">
    <h2>START A CONVERSATION.</h2>
    <p>All prices above are starting prices for the structural product. We gate the final scope behind a conversation so we can match the package to your business. Tell us what you are working on, what you want readers to know, and what success looks like. We reply within two business days.</p>
    <div class="contact__methods">
      <a href="mailto:partners@sftimes.com?subject=keepers%20partnership%20inquiry">
        <span>EMAIL</span>
        <strong>partners@sftimes.com</strong>
      </a>
      <a href="tel:+17077183579">
        <span>PHONE OR TEXT</span>
        <strong>707·718·3579</strong>
      </a>
    </div>
  </section>

  <style>
    /* PACKAGES */
    .pkgs { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; padding: 0 12px 16px; }
    .pkgs--two { grid-template-columns: repeat(2, 1fr); max-width: 800px; margin: 0 auto; }
    @media (max-width: 980px) { .pkgs, .pkgs--two { grid-template-columns: 1fr; } }
    .pkg { padding: 28px; border: 1px solid var(--rule); background: var(--paper-2); position: relative; display: flex; flex-direction: column; gap: 14px; }
    .pkg--featured { background: var(--ink); color: var(--paper); border-color: var(--ink); }
    .pkg--featured .pkg__price, .pkg--featured .pkg__sub, .pkg--featured ul li { color: rgba(244,241,234,0.85); }
    .pkg__badge { position: absolute; top: -12px; left: 16px; background: var(--ink); color: var(--paper); padding: 5px 12px; font-size: 10px; letter-spacing: 0.18em; }
    .pkg--featured .pkg__badge { background: var(--paper); color: var(--ink); }
    .pkg__price { font-size: 11px; letter-spacing: 0.18em; margin: 0; }
    .pkg__name { font-family: var(--display); font-size: clamp(22px, 2.4vw, 30px); line-height: 1.1; margin: 0; text-transform: uppercase; }
    .pkg__sub { font-size: 14px; line-height: 1.45; margin: 0; }
    .pkg ul { list-style: none; padding: 0; margin: 0; border-top: 1px solid currentColor; padding-top: 14px; }
    .pkg li { font-size: 13px; line-height: 1.5; padding: 4px 0 4px 16px; position: relative; }
    .pkg li::before { content: '·'; position: absolute; left: 4px; font-weight: bold; }

    /* SECTION CTA: one line per product, mailto + phone */
    .section-cta { text-align: center; font-size: 13px; color: var(--muted); padding: 14px 0; border-top: 1px solid var(--rule); max-width: 880px; margin: 0 auto 48px; }
    .section-cta a { color: var(--ink); font-weight: 600; border-bottom: 1px solid currentColor; padding-bottom: 1px; }

    /* EDITOR'S NOTE */
    .editor-note { padding: 0 12px 56px; }
    .editor-note__inner { max-width: 720px; margin: 0 auto; padding: 32px 36px; background: var(--paper-2); border-left: 3px solid var(--ink); }
    .editor-note__label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0 0 16px; }
    .editor-note__body { font-size: 16px; line-height: 1.7; margin: 0 0 14px; color: var(--ink); }
    .editor-note__sign { font-family: var(--display); font-size: 18px; letter-spacing: -0.005em; margin: 0; color: var(--ink); }

    /* CASE STUDY: illustrative format */
    .case { background: var(--paper-2); padding: 48px 12px; margin: 0 0 48px; border-block: 1px solid var(--rule); }
    .case__head { max-width: 880px; margin: 0 auto 32px; padding: 0 4px; }
    .case__label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin: 0 0 14px; font-weight: 700; }
    .case__title { font-family: var(--display); font-size: clamp(28px, 3.4vw, 44px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0; }
    .case__intro { font-size: 14px; line-height: 1.6; color: var(--ink); margin: 16px 0 0; max-width: 60ch; }
    .case__body { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 1fr; gap: 36px; padding: 0 4px; }
    @media (max-width: 880px) { .case__body { grid-template-columns: 1fr; } }
    .case__story { background: var(--paper); padding: 32px 28px; border: 1px solid var(--rule); }
    .case__story-eyebrow { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0 0 14px; }
    .case__story-title { font-family: var(--display); font-size: clamp(22px, 2.2vw, 30px); line-height: 1.1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 14px; }
    .case__story-deck { font-size: 14px; line-height: 1.55; margin: 0 0 18px; color: var(--ink); }
    .case__story-link { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); font-weight: 600; border-bottom: 1px solid currentColor; padding-bottom: 1px; }
    .case__metrics { background: var(--ink); color: var(--paper); padding: 32px 28px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px 18px; align-content: start; }
    .case__metrics-label { grid-column: 1 / -1; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(244,241,234,0.6); margin: 0 0 6px; font-weight: 700; }
    .case__metric { padding: 6px 0; }
    .case__num { font-family: var(--display); font-size: clamp(28px, 3vw, 40px); line-height: 1; display: block; }
    .case__metric p { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(244,241,234,0.7); margin: 6px 0 0; }
    .case__note { font-size: 11px; color: var(--muted); margin: 24px auto 0; max-width: 60ch; text-align: center; font-style: italic; }

    /* INTEGRITY CAPS */
    .caps { padding: 0 12px 56px; }
    .caps__inner { max-width: 880px; margin: 0 auto; padding: 36px 36px; background: var(--ink); color: var(--paper); }
    .caps__label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(244,241,234,0.6); margin: 0 0 18px; font-weight: 700; }
    .caps__title { font-family: var(--display); font-size: clamp(28px, 3.4vw, 44px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 24px; color: var(--paper); }
    .caps__list { list-style: none; padding: 0; margin: 0; }
    .caps__list li { padding: 12px 0; border-bottom: 1px solid rgba(244,241,234,0.18); font-size: 14px; line-height: 1.6; color: rgba(244,241,234,0.9); }
    .caps__list li:last-child { border-bottom: 0; }
    .caps__list strong { color: var(--paper); font-weight: 600; }
    .caps__list a { color: var(--paper); border-bottom: 1px solid currentColor; padding-bottom: 1px; }

    /* MOCKUPS */
    .mock-section { padding: 0 12px 32px; max-width: 720px; margin: 0 auto; }
    .mock-section__label { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0 0 18px; padding-left: 4px; }
    .mock { background: var(--paper); border: 1px solid var(--rule); padding: 28px; position: relative; }
    .mock__chip { position: absolute; top: -10px; left: 16px; background: var(--ink); color: var(--paper); padding: 4px 12px; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; }
    .mock--article { padding: 32px 36px; }
    .mock__eyebrow { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0 0 14px; }
    .mock__eyebrow strong { color: var(--ink); }
    .mock__title { font-family: var(--display); font-size: clamp(20px, 2.4vw, 28px); line-height: 1.1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 12px; }
    .mock__deck { font-size: 14px; line-height: 1.55; margin: 0 0 18px; color: var(--ink); }
    .mock__deck a { color: var(--ink); border-bottom: 1px solid currentColor; padding-bottom: 1px; }
