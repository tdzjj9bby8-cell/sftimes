---
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';
import Placeholder from '../components/Placeholder.astro';

const team = [
  {
    name: 'ERIC',
    slug: 'eric',
    role: 'FOUNDER, EDITOR',
    bio: 'Saturday letter writer. Walks the blocks.',
    longBio: "Eric is the founder and editor. He writes the Saturday letter, edits every published piece, picks the keepers, and answers the inquiries that come in through the partner page personally. Background: ten years in local independent media, three years at a tech company he won't name, two years freelancing across the West Coast while he figured out what he actually wanted to do. The keepers is what he wanted to do.",
    beats: ['Editorial direction', 'Profile features', 'Best Of curation', 'Partnerships'],
    sinceIssue: 1,
    issuesAuthored: 31,
    location: 'Mission, San Francisco',
  },
  {
    name: 'NICHOLAS',
    slug: 'nicholas',
    role: 'REPORTER',
    bio: 'Profiles, reported features, civic accountability.',
    longBio: "Nicholas joined in issue twelve. He writes the deeper profiles and the reported features that take more than one Saturday to finish. Background: investigative reporting for two local outlets before the keepers, plus a master's in journalism that he doesn't bring up unless someone asks. He covers civic accountability beats: courts, housing, the places where the city's promises meet the city's pavement.",
    beats: ['Reported profiles', 'Civic accountability', 'Housing', 'Courts'],
    sinceIssue: 12,
    issuesAuthored: 14,
    location: 'Outer Richmond, San Francisco',
  },
  {
    name: 'DAISY',
    slug: 'daisy',
    role: 'REPORTER',
    bio: 'Culture, neighborhoods, small business beats.',
    longBio: "Daisy joined in issue twenty-one. She owns the culture and small-business beats and writes most of the Top Tier best-of guides. Background: ten years freelancing for food and culture magazines around the Bay, plus a previous life as a cook in a Mission restaurant that closed in 2019. She knows the food world from both sides of the counter, which shows up in the work.",
    beats: ['Culture features', 'Small business profiles', 'Best Of editor', 'Restaurants'],
    sinceIssue: 21,
    issuesAuthored: 9,
    location: 'Bernal Heights, San Francisco',
  },
  {
    name: 'KIWI',
    slug: 'kiwi',
    role: 'PHOTOGRAPHER',
    bio: 'Hero photography for weekly features.',
    longBio: "Kiwi has been the lead photographer since issue three. She shoots the hero portrait for every Saturday feature plus the on-location work for the Top Tier guides. Background: ten years of editorial portraiture for national magazines before the keepers, plus a fine art practice she still maintains. She works in available light, never staged, and always names her subjects on the wall.",
    beats: ['Hero portraits', 'On-location reportage', 'Best Of photography', 'Print zine art direction'],
    sinceIssue: 3,
    issuesAuthored: 55,
    location: 'Outer Sunset, San Francisco',
  },
];
---
<ExhibitionLayout
  title="TEAM · The Keepers · SF Times"
  description="Who writes, photographs, and edits the saturday letter."
  active="about"
>
  <ExhibitionMasthead
    slot="masthead"
    title="THE TEAM"
    subscript="4 HUMANS"
    cutouts={[]}
  />

  <article class="ex-prose">
    <p class="ex-prose__eyebrow">NAMED BYLINES · NO AI · FOUR HUMANS</p>
    <h1 class="ex-prose__title">THE PEOPLE BEHIND<br>THE SATURDAY LETTER.</h1>
    <p>Every byline is a real person. We don't run AI-generated copy, we don't run syndicated filler, and the editor who picks a best of list is named on the list. Here's everyone.</p>
  </article>

  <!-- TEAM SUMMARY CARDS (jump to detail anchors below) -->
  <section class="team">
    {team.map((m) => (
      <a class="team-card" href={`#${m.slug}`}>
        <div class="team-card__photo">
          <Placeholder alt={`${m.name}, ${m.role}`} filenameHint={`team/${m.slug}.jpg`} aspect="1:1" showLabel={false} />
        </div>
        <h3 class="team-card__name">{m.name}</h3>
        <p class="team-card__role">{m.role}</p>
        <p class="team-card__bio">{m.bio}</p>
        <span class="team-card__more">FULL BIO →</span>
      </a>
    ))}
  </section>

  <!-- DETAIL BIOS · one per team member, with proper anchor IDs that
       match the Schema.org author URLs (/team#eric, etc.) -->
  <section class="team-bios">
    {team.map((m) => (
      <article class="bio" id={m.slug}>
        <div class="bio__photo">
          <Placeholder alt={`${m.name}, ${m.role}`} filenameHint={`team/${m.slug}.jpg`} aspect="3:4" showLabel={false} />
        </div>
        <div class="bio__body">
          <p class="bio__role">{m.role}</p>
          <h2 class="bio__name">{m.name}</h2>
          <p class="bio__long">{m.longBio}</p>

          <div class="bio__facts">
            <div class="bio__fact">
              <p class="bio__fact-label">BEATS</p>
              <p class="bio__fact-val">{m.beats.join(' · ')}</p>
            </div>
            <div class="bio__fact">
              <p class="bio__fact-label">FIRST ISSUE</p>
              <p class="bio__fact-val">№{String(m.sinceIssue).padStart(2, '0')}</p>
            </div>
            <div class="bio__fact">
              <p class="bio__fact-label">ISSUES AUTHORED</p>
              <p class="bio__fact-val">{m.issuesAuthored}</p>
            </div>
            <div class="bio__fact">
              <p class="bio__fact-label">BASED IN</p>
              <p class="bio__fact-val">{m.location}</p>
            </div>
          </div>

          <div class="bio__contact">
            <a href={`mailto:${m.slug}@sftimes.com?subject=From%20the%20site`}>{m.slug}@sftimes.com →</a>
          </div>
        </div>
      </article>
    ))}
  </section>

  <!-- HIRING -->
  <section class="hiring" id="hiring">
    <div class="hiring__head">
      <p class="hiring__eyebrow">OPEN ROLES · INTERNS · FIELD JOURNALISTS</p>
      <h2 class="hiring__title">JOIN THE TEAM.</h2>
      <p class="hiring__sub">Small pay. Real bylines. The blocks of San Francisco, on foot, on the record.</p>
    </div>

    <div class="hiring__roles">
      <article class="hiring__role">
        <p class="hiring__role-tag">ROLE №01</p>
        <h3 class="hiring__role-name">EDITORIAL INTERN</h3>
        <p class="hiring__role-what">For students or career-shifters who want to learn how a small publication actually runs. You'll pitch features, draft and edit copy, sit in on interviews, and help on saturday production. Real bylines from week one if your work clears the editor.</p>
        <ul class="hiring__role-perks">
          <li>Published work under your name</li>
          <li>1:1 editing time every week</li>
          <li>Minimum wage, plus gas and food covered on assignment days</li>
          <li>Flexible hours, part-time to start</li>
        </ul>
      </article>

      <article class="hiring__role">
        <p class="hiring__role-tag">ROLE №02</p>
        <h3 class="hiring__role-name">FIELD JOURNALIST</h3>
        <p class="hiring__role-what">For reporters who want to walk the city and meet the keepers. You'll run interviews, write profiles, hold the editorial line, and ship one feature per saturday. Two-week mentorship to start, permanent if it clicks.</p>
        <ul class="hiring__role-perks">
          <li>Named byline on every piece</li>
          <li>Editing that respects your voice</li>
          <li>Minimum wage, plus gas, food, and on-assignment expenses</li>
          <li>Print zine credit when we go to print quarterly</li>
        </ul>
      </article>
    </div>

    <p class="hiring__honest">We're a small operation. Pay is what we can afford right now: California minimum wage, plus gas and food on the days you're out reporting. We're upfront about that because we want people who care about the work, not just the paycheck. When we grow, you grow with us.</p>

    <div class="hiring__apply">
      <a href="mailto:eric@seod.com?subject=keepers%20application" class="hiring__cta">
        <span>SEND A PITCH AND A WRITING SAMPLE</span>
        <strong>eric@seod.com</strong>
      </a>
    </div>
  </section>

  <a href="/submit" class="ex-colmark__link">
    <section class="ex-colmark">
      <h2 class="ex-colmark__text">PITCH THE EDITOR →</h2>
    </section>
  </a>

  <style>
    .team { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; padding: 0 12px 48px; }
    .team-card__photo { aspect-ratio: 1/1; background: #2a2520; overflow: hidden; margin-bottom: 16px; }
    .team-card__photo :global(.real-image), .team-card__photo :global(.placeholder) { width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block; }
    .team-card__name { font-family: var(--display); font-size: clamp(28px, 3vw, 44px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 6px; }
    .team-card__role { font-size: 11px; letter-spacing: 0.16em; color: var(--muted); margin: 0 0 12px; }
    .team-card__bio { font-size: 13px; line-height: 1.5; margin: 0 0 10px; color: var(--ink); }
    .team-card { color: var(--ink); display: block; transition: opacity 200ms; }
    .team-card:hover { opacity: 0.85; }
    .team-card__more { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); border-bottom: 1px solid currentColor; padding-bottom: 1px; }

    /* === DETAIL BIOS === */
    .team-bios { max-width: 1080px; margin: 64px auto; padding: 0 12px; display: flex; flex-direction: column; gap: 56px; }
    .bio {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 36px;
      align-items: start;
      padding-top: 48px;
      border-top: 1px solid var(--rule);
      scroll-margin-top: 80px;
    }
    .bio:first-child { padding-top: 0; border-top: 0; }
    @media (max-width: 880px) { .bio { grid-template-columns: 1fr; } }
    .bio__photo { background: #2a2520; aspect-ratio: 3/4; overflow: hidden; }
    .bio__photo :global(.real-image), .bio__photo :global(.placeholder) { width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block; }
    .bio__role { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0 0 8px; font-weight: 600; }
    .bio__name { font-family: var(--display); font-size: clamp(36px, 5vw, 64px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 20px; }
    .bio__long { font-size: 16px; line-height: 1.7; max-width: 60ch; margin: 0 0 28px; }
    .bio__facts {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px 28px;
      padding: 18px 0;
      border-block: 1px solid var(--rule);
      margin: 0 0 24px;
    }
    .bio__fact-label { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--muted); margin: 0 0 4px; }
    .bio__fact-val { font-size: 13px; color: var(--ink); margin: 0; line-height: 1.45; }
    .bio__contact a {
      font-family: var(--display);
      font-size: clamp(18px, 1.8vw, 22px);
      letter-spacing: -0.005em;
      color: var(--ink);
      border-bottom: 1px solid currentColor;
      padding-bottom: 2px;
    }

    /* === HIRING BLOCK === */
    .hiring { background: var(--ink); color: var(--paper); padding: 72px 12px; margin-top: 48px; }
    .hiring__head { max-width: 880px; margin: 0 auto 40px; padding: 0 4px; }
    .hiring__eyebrow { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(244,241,234,0.6); margin: 0 0 18px; }
    .hiring__title { font-family: var(--display); font-size: clamp(48px, 6vw, 96px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0 0 18px; color: var(--paper); }
    .hiring__sub { font-size: clamp(16px, 1.4vw, 20px); line-height: 1.5; max-width: 44ch; color: rgba(244,241,234,0.85); margin: 0; }
    .hiring__roles { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; max-width: 1200px; margin: 0 auto 40px; padding: 0 4px; }
    .hiring__role { padding: 32px 28px; border: 1px solid rgba(244,241,234,0.18); background: rgba(244,241,234,0.04); display: flex; flex-direction: column; gap: 14px; }
    .hiring__role-tag { font-size: 10px; letter-spacing: 0.18em; color: rgba(244,241,234,0.5); margin: 0; }
    .hiring__role-name { font-family: var(--display); font-size: clamp(28px, 3vw, 40px); line-height: 1; text-transform: uppercase; letter-spacing: -0.005em; margin: 0; color: var(--paper); }
    .hiring__role-what { font-size: 14px; line-height: 1.6; color: rgba(244,241,234,0.85); margin: 0; }
    .hiring__role-perks { list-style: none; padding: 16px 0 0; margin: 0; border-top: 1px solid rgba(244,241,234,0.18); }
    .hiring__role-perks li { font-size: 13px; line-height: 1.5; padding: 4px 0 4px 16px; position: relative; color: rgba(244,241,234,0.85); }
    .hiring__role-perks li::before { content: '·'; position: absolute; left: 4px; font-weight: bold; }
    .hiring__honest { font-size: 13px; line-height: 1.65; max-width: 62ch; margin: 0 auto 36px; padding: 22px 24px; border-left: 3px solid var(--paper); color: rgba(244,241,234,0.78); background: rgba(244,241,234,0.03); }
    .hiring__apply { text-align: center; padding: 0 4px; }
    .hiring__cta { display: inline-flex; flex-direction: column; gap: 4px; padding: 22px 36px; background: var(--paper); color: var(--ink); transition: opacity 200ms; }
    .hiring__cta:hover { opacity: 0.85; }
    .hiring__cta span { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; }
    .hiring__cta strong { font-family: var(--display); font-size: clamp(22px, 2vw, 32px); letter-spacing: -0.005em; font-weight: 400; }

    @media (max-width: 980px) { .team { grid-template-columns: repeat(2, 1fr); } .hiring__roles { grid-template-columns: 1fr; } }
    @media (max-width: 480px) { .team { grid-template-columns: 1fr; } }
  </style>
</ExhibitionLayout>
