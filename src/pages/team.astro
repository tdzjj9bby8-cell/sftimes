---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';

import PageMasthead from '../components/PageMasthead.astro';

const team = [
  { name: 'Eric', role: 'founder, editor', bio: 'Saturday letter writer. Walks the blocks.' },
  { name: 'Nicholas', role: 'reporter', bio: 'Profiles, reported features, civic accountability.' },
  { name: 'Daisy', role: 'reporter', bio: 'Culture, neighborhoods, small business beats.' },
  { name: 'Kiwi', role: 'photographer', bio: 'Hero photography for weekly features.' },
];
---
<BaseLayout title="team — the keepers." description="Who writes, photographs, and edits the saturday letter." current="team">

  <PageMasthead
    title="the team."
    eyebrow="four humans · named bylines · no AI"
    subscript="THE KEEPERS"
    cutouts={[]}
  />

  <div class="container container-narrow page">
    <h2 class="page-subhead">the people <em>behind</em> the saturday letter.</h2>
    <div class="team-grid">
      {team.map((m) => (
        <article class="team-card">
          <Placeholder alt={`${m.name}, ${m.role}`} filenameHint={`team/${m.name.toLowerCase()}.jpg`} aspect="1:1" showLabel={false} rounded={true} class="team-card__photo" />
          <h3 class="team-card__name">{m.name.toLowerCase()}</h3>
          <p class="ui-label">{m.role}</p>
          <p class="team-card__bio">{m.bio}</p>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page { padding-block: var(--s-9); }
  .page-subhead {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    margin: var(--s-7) 0 var(--s-7);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .page-subhead :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .team-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--s-7); }
  .team-card { text-align: center; }
  /* Placeholder.astro renders the img with its own component scope, so target
     it globally to apply size + center it. */
  .team-card :global(.team-card__photo) {
    width: 220px;
    height: 220px;
    margin: 0 auto var(--s-4);
    object-fit: cover;
    aspect-ratio: 1 / 1 !important;
  }
  .team-card__name { font-family: var(--font-display); font-size: 1.5rem; margin: 0 0 var(--s-2); }
  .team-card__bio { color: var(--ink-soft); margin-top: var(--s-3); }
  @media (max-width: 600px) { .team-grid { grid-template-columns: 1fr; } }
</style>
