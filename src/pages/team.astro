---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';

const team = [
  { name: 'Eric', role: 'Founder, editor', bio: 'Saturday letter writer. Walks the blocks.' },
  { name: 'Nicholas', role: 'Reporter', bio: 'Profiles, reported features, civic accountability.' },
  { name: 'Daisy', role: 'Reporter', bio: 'Culture, neighborhoods, small business beats.' },
  { name: 'Kiwi', role: 'Photographer', bio: 'Hero photography for weekly features.' },
];
---
<BaseLayout title="Team — SF Times" description="Who writes, photographs, and edits SF Times." current="team">
  <div class="container container-narrow page">
    <p class="ui-label">Team</p>
    <h1>The people behind SF Times.</h1>
    <div class="team-grid">
      {team.map((m) => (
        <article class="team-card">
          <Placeholder alt={`${m.name}, ${m.role}`} filenameHint={`team/${m.name.toLowerCase()}.jpg`} aspect="1:1" showLabel={false} rounded={true} class="team-card__photo" />
          <h3 class="team-card__name">{m.name}</h3>
          <p class="ui-label">{m.role}</p>
          <p class="team-card__bio">{m.bio}</p>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page { padding-block: var(--s-9); }
  .page h1 { margin-block: var(--s-3) var(--s-7); }
  .team-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--s-7); }
  .team-card { text-align: center; }
  .team-card__photo { width: 220px; height: 220px; margin: 0 auto var(--s-4); }
  .team-card__name { font-family: var(--font-display); font-size: 1.5rem; margin: 0 0 var(--s-2); }
  .team-card__bio { color: var(--ink-soft); margin-top: var(--s-3); }
  @media (max-width: 600px) { .team-grid { grid-template-columns: 1fr; } }
</style>
