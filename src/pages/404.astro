---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageMasthead from '../components/PageMasthead.astro';
---
<BaseLayout title="not found — the keepers." current="">

  <PageMasthead
    title="page not found."
    eyebrow="404 · the page that wasn't"
    subscript="THE KEEPERS"
  />

  <div class="container container-narrow page">
    <p class="lead">Or maybe it has been written and the link got tangled. Either way, here's where to go from here.</p>
    <ul class="links">
      <li><a href="/">home</a></li>
      <li><a href="/stories">every story</a></li>
      <li><a href="/best-of">best of</a></li>
      <li><a href="/hidden-spots">hidden spots</a></li>
      <li><a href="/submit">send us a spot</a></li>
      <li><a href="/support">become a supporter</a></li>
    </ul>
  </div>
</BaseLayout>

<style>
  .page { padding-block: var(--s-10); }
  .page h1 {
    margin-block: var(--s-3) var(--s-5);
    max-width: 22ch;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .page h1 :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .page .lead { font-size: 1.125rem; color: var(--ink-soft); margin-bottom: var(--s-6); }
  .links { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--s-3); }
  .links a {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--s-2);
    display: inline-block;
    letter-spacing: -0.015em;
    transition: color var(--t-fast) var(--ease-out), border-color var(--t-fast) var(--ease-out);
  }
  .links a:hover { color: var(--terracotta); border-color: currentColor; }
</style>
