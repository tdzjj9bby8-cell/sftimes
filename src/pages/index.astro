---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import StoryCard from '../components/StoryCard.astro';
import { getCollection } from 'astro:content';

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);
const featured = stories.find((s) => s.data.is_featured) || stories[0];
const past = stories.filter((s) => s.slug !== featured.slug).slice(0, 12);

const bestOf = (await getCollection('best-of'));
const dateLong = featured.data.published
  .toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  .toLowerCase();
const titleHtml = featured.data.title_em
  ? featured.data.title.replace(featured.data.title_em, `<em>${featured.data.title_em}</em>`)
  : featured.data.title;
---

<BaseLayout
  title="the keepers. — sf times"
  description="One San Francisco keeper every Saturday. The people holding something the city would lose without them. Reader-funded, no parent company, no AI bylines."
  headerVariant="transparent"
  current=""
>
  <!-- FULL-BLEED HERO. Photo IS the top of the page. Headline lives inside it. -->
  <section class="home-hero">
    <a class="home-hero__link" href={`/stories/${featured.data.url_slug}`}>
      <div class="home-hero__media">
        <Placeholder
          alt={featured.data.hero_alt}
          filenameHint={featured.data.hero_filename_hint}
          aspect="21:9"
          showLabel={true}
          class="home-hero__placeholder"
        />
        <div class="home-hero__veil" aria-hidden="true"></div>
      </div>
      <span class="home-hero__stamp">a keepers essay · №{featured.data.issue}</span>
      <div class="home-hero__overlay container">
        <p class="home-hero__eyebrow">issue {featured.data.issue} · {dateLong} · {featured.data.read_minutes}-min read</p>
        <h1 class="home-hero__title" set:html={titleHtml} />
      </div>
    </a>
  </section>

  <!-- DECK BLOCK — under the hero, on paper -->
  <section class="home-deck container">
    <p class="home-deck__text">{featured.data.deck}</p>
    <p class="home-deck__byline">
      by <strong>{featured.data.author}</strong>
      {featured.data.photographer && featured.data.photographer !== 'Staff' && (
        <> · photographs by <strong>{featured.data.photographer}</strong></>
      )}
    </p>
    <a class="home-deck__cta" href={`/stories/${featured.data.url_slug}`}>read the full essay →</a>
  </section>

  <!-- ARCHIVE GRID -->
  <section class="home-archive container">
    <div class="home-archive__header">
      <h2 class="section-title">more keepers</h2>
      <a class="home-archive__view-all" href="/stories">browse every story →</a>
    </div>
    <div class="home-archive__grid" id="archive-grid">
      {past.map((s, i) => (
        <div class={`home-archive__cell home-archive__cell--${(i % 3) + 1}`}>
          <StoryCard story={s} size="md" />
        </div>
      ))}
    </div>
    <div class="home-archive__more">
      <a class="btn-ghost" href="/stories">load more stories</a>
    </div>
  </section>

  <!-- BEST OF -->
  <section class="home-bestof container">
    <div class="home-bestof__header">
      <h2 class="section-title">best of</h2>
      <p class="home-bestof__intro">
        Hand-picked lists, refreshed quarterly. Named editors, conflict of interest disclosed, no affiliate links.
      </p>
    </div>
    <div class="home-bestof__grid">
      {bestOf.map((c) => (
        <a class="bestof-card reveal" href={`/best-of/${c.data.url_slug}`}>
          <Placeholder
            alt={c.data.hero_alt}
            filenameHint={c.data.hero_filename_hint}
            aspect="4:3"
            showLabel={false}
            class="bestof-card__media"
          />
          <h3 class="bestof-card__title">{c.data.title}</h3>
          <p class="ui-label">refreshed {c.data.last_refreshed.toLocaleDateString('en-US',{month:'short',year:'numeric'}).toLowerCase()}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- HIDDEN SPOTS -->
  <section class="home-hidden">
    <div class="container">
      <div class="home-hidden__header">
        <h2 class="section-title">hidden spots</h2>
        <p class="home-hidden__intro">
          Reader-submitted. Editor-vetted. We protect the place over the page view. If a spot can't handle the traffic, we describe it without naming it.
        </p>
      </div>
      <div class="home-hidden__empty">
        <p>No published hidden spots yet. Be the first.</p>
        <a class="btn-ghost" href="/submit">submit a spot</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="home-newsletter container">
    <div class="home-newsletter__inner">
      <h2 class="section-title">saturday letter</h2>
      <p class="home-newsletter__copy">
        One profile every Saturday. Free for every reader. No spam, no tracking, no parent company.
      </p>
      <form class="home-newsletter__form" action="#" method="post" data-newsletter>
        <label class="visually-hidden" for="newsletter-email">Email address</label>
        <input id="newsletter-email" type="email" name="email" placeholder="you@email.com" required />
        <button type="submit" class="btn-primary">subscribe</button>
      </form>
    </div>
  </section>
</BaseLayout>

<style>
  /* FULL-BLEED HERO. No top margin trickery. The hero IS the top of the page,
     and the transparent header floats over it until you scroll. */
  .home-hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    max-height: 900px;
    overflow: hidden;
    background: var(--ink);
    isolation: isolate;
  }
  .home-hero__link {
    display: block;
    height: 100%;
    color: var(--bg);
  }
  .home-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .home-hero__media :global(.placeholder),
  .home-hero__media :global(.real-image),
  .home-hero__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: auto !important;
    display: block;
    transition: transform 700ms var(--ease-out);
  }
  .home-hero__link:hover .home-hero__media :global(.placeholder) {
    transform: scale(1.02);
  }
  /* Soft bottom-to-top veil so the headline sits readable on any photo */
  .home-hero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.7) 0%,
      rgba(0,0,0,0.35) 35%,
      rgba(0,0,0,0.05) 65%,
      rgba(0,0,0,0.25) 100%
    );
    pointer-events: none;
  }
  .home-hero__stamp {
    position: absolute;
    top: calc(var(--s-9) + var(--s-2));
    right: var(--gutter);
    z-index: 3;
    border: 1px solid rgba(244,241,234,0.55);
    padding: var(--s-2) var(--s-3);
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    color: var(--bg);
  }
  .home-hero__overlay {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    z-index: 2;
    padding-bottom: var(--s-9);
    color: var(--bg);
  }
  .home-hero__eyebrow {
    color: rgba(244,241,234,0.78);
    margin: 0 0 var(--s-4);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
  }
  .home-hero__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.022em;
    margin: 0;
    max-width: 18ch;
    color: var(--bg);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .home-hero__title :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }

  /* DECK BLOCK — on paper, under the hero */
  .home-deck {
    padding-top: var(--s-7);
    padding-bottom: var(--s-7);
    border-bottom: 1px solid var(--rule);
  }
  .home-deck__text {
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 1.6vw, 1.5rem);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0 0 var(--s-5);
    font-variation-settings: 'opsz' 16;
  }
  .home-deck__byline {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--fog);
    margin: 0 0 var(--s-5);
  }
  .home-deck__byline strong { color: var(--ink); font-weight: 500; }
  .home-deck__cta {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    color: var(--ink);
    transition: color var(--t-fast) var(--ease-out), border-color var(--t-fast) var(--ease-out);
  }
  .home-deck__cta:hover { color: var(--terracotta); border-color: var(--terracotta); }

  /* ARCHIVE */
  .home-archive { margin-top: var(--s-9); }
  .home-archive__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--s-7);
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--rule);
  }
  .home-archive__view-all {
    color: var(--ink-soft);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    padding-bottom: 2px;
  }
  .home-archive__view-all:hover { color: var(--terracotta); }
  .home-archive__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--s-7) var(--s-6);
  }
  /* Homepage cards: image-first, hide the deck so the photo carries the cell.
     The /stories archive page keeps the deck. */
  .home-archive__grid :global(.story-card__deck) { display: none; }
  .home-archive__more { text-align: center; margin-top: var(--s-9); }

  .section-title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 0;
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }

  .btn-ghost {
    display: inline-block;
    padding: var(--s-3) var(--s-5);
    border: 1px solid var(--ink);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    transition: background var(--t-fast) var(--ease-out), color var(--t-fast) var(--ease-out);
  }
  .btn-ghost:hover { background: var(--ink); color: var(--bg); }
  .btn-primary {
    display: inline-block;
    background: var(--ink);
    color: var(--bg);
    padding: var(--s-3) var(--s-5);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    border: 0;
    cursor: pointer;
    transition: background var(--t-fast) var(--ease-out);
  }
  .btn-primary:hover { background: var(--terracotta); }

  /* BEST OF */
  .home-bestof { margin-top: var(--s-9); }
  .home-bestof__header {
    margin-bottom: var(--s-6);
    max-width: 60ch;
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--rule);
  }
  .home-bestof__intro { margin-top: var(--s-3); color: var(--ink-soft); }
  .home-bestof__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--s-7);
  }
  .bestof-card {
    color: var(--ink);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .bestof-card__media { transition: transform var(--t-med) var(--ease-out); }
  .bestof-card:hover .bestof-card__media { transform: scale(1.03); }
  .bestof-card__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.5rem;
    margin: var(--s-3) 0 0;
    letter-spacing: -0.015em;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }

  /* HIDDEN SPOTS */
  .home-hidden { background: var(--paper); padding-block: var(--s-8); margin-top: var(--s-9); }
  .home-hidden__header { max-width: 60ch; margin-bottom: var(--s-6); }
  .home-hidden__intro { margin-top: var(--s-3); color: var(--ink-soft); }
  .home-hidden__empty { display: flex; flex-direction: column; gap: var(--s-3); align-items: flex-start; }

  /* NEWSLETTER */
  .home-newsletter { margin-top: var(--s-9); margin-bottom: var(--s-9); }
  .home-newsletter__inner {
    max-width: var(--max-narrow);
    margin-inline: auto;
    text-align: center;
  }
  .home-newsletter__copy { margin-top: var(--s-4); color: var(--ink-soft); max-width: 48ch; margin-inline: auto; }
  .home-newsletter__form {
    margin-top: var(--s-5);
    display: flex;
    gap: var(--s-2);
    justify-content: center;
    flex-wrap: wrap;
  }
  .home-newsletter__form input {
    padding: var(--s-3) var(--s-4);
    font-family: var(--font-body);
    font-size: 1rem;
    border: 1px solid var(--ink);
    background: var(--bg);
    min-width: min(280px, 100%);
  }
  .visually-hidden {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  @media (max-width: 1024px) {
    .home-archive__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 880px) {
    .home-hero { height: 88vh; min-height: 540px; }
    .home-hero__stamp { top: calc(var(--s-8) + var(--s-2)); right: var(--s-4); padding: 5px 9px; font-size: 0.625rem; }
    .home-hero__overlay { padding-bottom: var(--s-7); }
    .home-archive__grid { grid-template-columns: 1fr; }
    .home-bestof__grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .home-hero { height: 80vh; min-height: 480px; }
    .home-hero__title { font-size: 2rem; max-width: 16ch; }
    .home-hero__eyebrow { font-size: 0.6875rem; margin-bottom: var(--s-3); }
    .home-hero__overlay { padding-bottom: var(--s-6); }
    .home-deck__text { font-size: 1.0625rem; }
  }
</style>
