---
import BaseLayout from '../layouts/BaseLayout.astro';
import Placeholder from '../components/Placeholder.astro';
import StoryCard from '../components/StoryCard.astro';
import { getCollection } from 'astro:content';

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);
const featured = stories.find((s) => s.data.is_featured) || stories[0];
const restAfterFeatured = stories.filter((s) => s.slug !== featured.slug);

// Asymmetric layout: 1 big spotlight + 2 stacked tall + standard 3-col grid.
const spotlight = restAfterFeatured[0];
const sideStack = restAfterFeatured.slice(1, 3);
const gridStories = restAfterFeatured.slice(3, 12);

// Issue ticker: last 16 issues, newest first
const ticker = stories.slice(0, 16).map((s) => ({
  issue: s.data.issue,
  slug: s.data.url_slug,
  date: s.data.published
    .toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
    .toLowerCase(),
}));

// Keeper-flavor taxonomy: count by keeper_type
const FLAVORS = [
  { key: 'recipe',  label: 'a recipe',  note: 'something they cook, brew, or bake' },
  { key: 'routine', label: 'a routine', note: 'something they do, every day, on time' },
  { key: 'room',    label: 'a room',    note: 'a place they hold open' },
  { key: 'record',  label: 'a record',  note: 'something they remember out loud' },
  { key: 'refusal', label: 'a refusal', note: 'something they would not let go of' },
];
const flavorCounts = FLAVORS.map((f) => ({
  ...f,
  count: stories.filter((s) => s.data.keeper_type === f.key).length,
}));

// Pull quote of the week: the most recent story with a pull_quote, else featured deck
const quoteStory = stories.find((s) => s.data.pull_quote) || featured;
const quoteText = quoteStory.data.pull_quote || quoteStory.data.deck;
const quoteAttr = quoteStory.data.pull_quote_attr || quoteStory.data.author;
const quoteHref = `/stories/${quoteStory.data.url_slug}`;

const bestOf = (await getCollection('best-of'));
const dateLong = featured.data.published
  .toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
  .toLowerCase();
const titleHtml = featured.data.title_em
  ? featured.data.title.replace(featured.data.title_em, `<em>${featured.data.title_em}</em>`)
  : featured.data.title;
---

<BaseLayout
  title="the keepers. — sf times"
  description="One San Francisco keeper every Saturday. The people holding something the city would lose without them. Reader-funded, no parent company, no AI bylines."
  headerVariant="transparent"
  current=""
>
  <!-- FULL-BLEED HERO. Photo IS the top of the page. Headline lives inside it. -->
  <section class="home-hero">
    <a class="home-hero__link" href={`/stories/${featured.data.url_slug}`}>
      <div class="home-hero__media">
        <Placeholder
          alt={featured.data.hero_alt}
          filenameHint={featured.data.hero_filename_hint}
          aspect="21:9"
          showLabel={true}
          priority={true}
          class="home-hero__placeholder"
        />
        <div class="home-hero__veil" aria-hidden="true"></div>
      </div>
      <span class="home-hero__stamp">a keepers essay · №{featured.data.issue}</span>
      <div class="home-hero__overlay container">
        <p class="home-hero__eyebrow">issue {featured.data.issue} · {dateLong} · {featured.data.read_minutes}-min read</p>
        <h1 class="home-hero__title" set:html={titleHtml} />
      </div>
    </a>
  </section>

  <!-- ISSUE TICKER — horizontal scroll of the last 16 issue numbers -->
  <aside class="home-ticker" aria-label="Recent issues">
    <div class="home-ticker__rail">
      <span class="home-ticker__label">recent issues</span>
      <ol class="home-ticker__list">
        {ticker.map((t, i) => (
          <li class={`home-ticker__item ${i === 0 ? 'is-current' : ''}`}>
            <a href={`/stories/${t.slug}`}>
              <span class="home-ticker__num">№{String(t.issue).padStart(2, '0')}</span>
              <span class="home-ticker__date">{t.date}</span>
            </a>
          </li>
        ))}
        <li class="home-ticker__all">
          <a href="/stories">view all <em>{stories.length}</em> →</a>
        </li>
      </ol>
    </div>
  </aside>

  <!-- DECK BLOCK — under the hero, on paper -->
  <section class="home-deck container">
    <p class="home-deck__text">{featured.data.deck}</p>
    <p class="home-deck__byline">
      by <strong>{featured.data.author}</strong>
      {featured.data.photographer && featured.data.photographer !== 'Staff' && (
        <> · photographs by <strong>{featured.data.photographer}</strong></>
      )}
    </p>
    <a class="home-deck__cta" href={`/stories/${featured.data.url_slug}`}>read the full essay →</a>
  </section>

  <!-- FLAVOR STRIP — keeper-type taxonomy with counts -->
  <section class="home-flavors container">
    <div class="home-flavors__head">
      <h2 class="section-title">what we keep</h2>
      <p class="home-flavors__sub">Every keeper holds one of five things. Tap a flavor to see only those stories.</p>
    </div>
    <ol class="home-flavors__list">
      {flavorCounts.map((f, i) => (
        <li class="home-flavors__cell">
          <a href={`/stories?flavor=${f.key}`}>
            <span class="home-flavors__num">{String(i + 1).padStart(2, '0')}</span>
            <span class="home-flavors__label">{f.label}<em>.</em></span>
            <span class="home-flavors__note">{f.note}</span>
            <span class="home-flavors__count">
              {f.count === 0
                ? 'coming soon'
                : `${f.count} ${f.count === 1 ? 'keeper' : 'keepers'} →`}
            </span>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <!-- SPOTLIGHT — asymmetric featured layout, then standard grid -->
  <section class="home-archive container">
    <div class="home-archive__header">
      <h2 class="section-title">more keepers</h2>
      <a class="home-archive__view-all" href="/stories">browse every story →</a>
    </div>

    {spotlight && (
      <div class="home-spotlight">
        <a class="home-spotlight__main" href={`/stories/${spotlight.data.url_slug}`}>
          <div class="home-spotlight__media">
            <Placeholder
              alt={spotlight.data.hero_alt}
              filenameHint={spotlight.data.hero_filename_hint}
              aspect="5:4"
              showLabel={false}
            />
          </div>
          <p class="home-spotlight__eyebrow">issue {spotlight.data.issue} · {spotlight.data.read_minutes}-min read</p>
          <h3 class="home-spotlight__title" set:html={
            spotlight.data.title_em
              ? spotlight.data.title.replace(spotlight.data.title_em, `<em>${spotlight.data.title_em}</em>`)
              : spotlight.data.title
          } />
          {spotlight.data.deck && (
            <p class="home-spotlight__deck">{spotlight.data.deck}</p>
          )}
        </a>
        <div class="home-spotlight__side">
          {sideStack.map((s) => (
            <a class="home-spotlight__small" href={`/stories/${s.data.url_slug}`}>
              <div class="home-spotlight__small-media">
                <Placeholder
                  alt={s.data.hero_alt}
                  filenameHint={s.data.hero_filename_hint}
                  aspect="4:3"
                  showLabel={false}
                />
              </div>
              <p class="home-spotlight__small-eyebrow">issue {s.data.issue}</p>
              <h4 class="home-spotlight__small-title" set:html={
                s.data.title_em
                  ? s.data.title.replace(s.data.title_em, `<em>${s.data.title_em}</em>`)
                  : s.data.title
              } />
            </a>
          ))}
        </div>
      </div>
    )}

    <div class="home-archive__grid" id="archive-grid">
      {gridStories.map((s, i) => (
        <div class={`home-archive__cell home-archive__cell--${(i % 3) + 1}`}>
          <StoryCard story={s} size="md" />
        </div>
      ))}
    </div>
    <div class="home-archive__more">
      <a class="btn-ghost" href="/stories">load more stories</a>
    </div>
  </section>

  <!-- PULL QUOTE OF THE WEEK — big editorial moment between sections -->
  <aside class="home-quote">
    <div class="container container-narrow home-quote__inner">
      <p class="home-quote__mark">”</p>
      <blockquote class="home-quote__text">
        {quoteText}
      </blockquote>
      <p class="home-quote__attr">
        <strong>{quoteAttr}</strong>
        <span class="home-quote__sep">·</span>
        <a href={quoteHref}>read the keeper →</a>
      </p>
    </div>
  </aside>

  <!-- BEST OF -->
  <section class="home-bestof container">
    <div class="home-bestof__header">
      <h2 class="section-title">best of</h2>
      <p class="home-bestof__intro">
        Hand-picked lists, refreshed quarterly. Named editors, conflict of interest disclosed, no affiliate links.
      </p>
    </div>
    <div class="home-bestof__grid">
      {bestOf.map((c) => (
        <a class="bestof-card reveal" href={`/best-of/${c.data.url_slug}`}>
          <Placeholder
            alt={c.data.hero_alt}
            filenameHint={c.data.hero_filename_hint}
            aspect="16:9"
            showLabel={false}
            class="bestof-card__media"
          />
          <h3 class="bestof-card__title">{c.data.title}</h3>
          <p class="ui-label">refreshed {c.data.last_refreshed.toLocaleDateString('en-US',{month:'short',year:'numeric'}).toLowerCase()}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- HIDDEN SPOTS -->
  <section class="home-hidden">
    <div class="container">
      <div class="home-hidden__header">
        <h2 class="section-title">hidden spots</h2>
        <p class="home-hidden__intro">
          Reader-submitted. Editor-vetted. We protect the place over the page view. If a spot can't handle the traffic, we describe it without naming it.
        </p>
      </div>
      <div class="home-hidden__empty">
        <p>No published hidden spots yet. Be the first.</p>
        <a class="btn-ghost" href="/submit">submit a spot</a>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="home-newsletter container">
    <div class="home-newsletter__inner" data-newsletter-root>
      <h2 class="section-title">saturday letter</h2>
      <p class="home-newsletter__copy">
        One profile every Saturday. Free for every reader. No spam, no tracking, no parent company.
      </p>
      <form class="home-newsletter__form" action="#" method="post" data-newsletter>
        <label class="visually-hidden" for="newsletter-email">Email address</label>
        <input id="newsletter-email" type="email" name="email" placeholder="you@email.com" required />
        <button type="submit" class="btn-primary">subscribe</button>
      </form>
      <div class="home-newsletter__thanks" data-newsletter-thanks hidden>
        <p class="home-newsletter__thanks-line"><em>thanks.</em></p>
        <p class="home-newsletter__thanks-sub">Saturday morning, in your inbox. If we don't hit your inbox by next saturday, check spam, then write to <a href="mailto:hello@sftimes.com">hello@sftimes.com</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  // Capture-on-submit until the real provider lands. Stores entries in
  // localStorage so Eric can export later; shows a friendly thank-you state
  // either way. Re-runs on astro:page-load so View Transitions don't break it.
  function initNewsletter() {
    const form = document.querySelector('[data-newsletter]');
    if (!form || form.dataset.bound) return;
    form.dataset.bound = '1';
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type=email]');
      const email = (input && input.value || '').trim();
      if (!email) return;
      try {
        const key = 'keepers-newsletter';
        const existing = JSON.parse(localStorage.getItem(key) || '[]');
        existing.push({ email, at: new Date().toISOString() });
        localStorage.setItem(key, JSON.stringify(existing));
      } catch (err) { /* ignore */ }
      const root = form.closest('[data-newsletter-root]');
      const thanks = root && root.querySelector('[data-newsletter-thanks]');
      form.setAttribute('hidden', '');
      const copy = root && root.querySelector('.home-newsletter__copy');
      if (copy) copy.setAttribute('hidden', '');
      if (thanks) thanks.removeAttribute('hidden');
    });
  }
  initNewsletter();
  document.addEventListener('astro:page-load', initNewsletter);
</script>

<style>
  /* FULL-BLEED HERO. No top margin trickery. The hero IS the top of the page,
     and the transparent header floats over it until you scroll. */
  .home-hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    max-height: 900px;
    overflow: hidden;
    background: var(--ink);
    isolation: isolate;
  }
  .home-hero__link {
    display: block;
    height: 100%;
    color: var(--bg);
  }
  .home-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .home-hero__media :global(.placeholder),
  .home-hero__media :global(.real-image),
  .home-hero__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: auto !important;
    display: block;
    transition: transform 700ms var(--ease-out);
  }
  .home-hero__link:hover .home-hero__media :global(.placeholder) {
    transform: scale(1.02);
  }
  /* Soft bottom-to-top veil so the headline sits readable on any photo */
  .home-hero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0,0,0,0.7) 0%,
      rgba(0,0,0,0.35) 35%,
      rgba(0,0,0,0.05) 65%,
      rgba(0,0,0,0.25) 100%
    );
    pointer-events: none;
  }
  .home-hero__stamp {
    position: absolute;
    top: calc(var(--s-9) + var(--s-2));
    right: var(--gutter);
    z-index: 3;
    border: 1px solid rgba(244,241,234,0.55);
    padding: var(--s-2) var(--s-3);
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    color: var(--bg);
  }
  .home-hero__overlay {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    z-index: 2;
    padding-bottom: var(--s-9);
    color: var(--bg);
  }
  .home-hero__eyebrow {
    color: rgba(244,241,234,0.78);
    margin: 0 0 var(--s-4);
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.16em;
  }
  .home-hero__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.022em;
    margin: 0;
    max-width: 18ch;
    color: var(--bg);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .home-hero__title :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }

  /* ISSUE TICKER — horizontal scroll right under the hero */
  .home-ticker {
    background: var(--ink);
    color: var(--bg);
    border-block: 1px solid rgba(244,241,234,0.08);
    overflow: hidden;
  }
  .home-ticker__rail {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    overflow-x: auto;
    overflow-y: hidden;
    padding: var(--s-3) var(--gutter);
    scroll-behavior: smooth;
    scrollbar-width: none;
  }
  .home-ticker__rail::-webkit-scrollbar { display: none; }
  .home-ticker__label {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    letter-spacing: 0.18em;
    color: rgba(244,241,234,0.45);
    flex-shrink: 0;
    text-transform: uppercase;
  }
  .home-ticker__list {
    display: flex;
    align-items: center;
    gap: var(--s-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .home-ticker__item, .home-ticker__all { flex-shrink: 0; }
  .home-ticker__item a {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: rgba(244,241,234,0.6);
    transition: color var(--t-fast) var(--ease-out);
  }
  .home-ticker__item a:hover { color: var(--bg); }
  .home-ticker__item.is-current a { color: var(--terracotta); }
  .home-ticker__num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.9375rem;
    line-height: 1;
    letter-spacing: -0.01em;
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .home-ticker__date {
    font-family: var(--font-ui);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
  }
  .home-ticker__all a {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: rgba(244,241,234,0.6);
    transition: color var(--t-fast) var(--ease-out);
  }
  .home-ticker__all a:hover { color: var(--terracotta); }
  .home-ticker__all em {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }

  /* DECK BLOCK — on paper, under the hero */
  .home-deck {
    padding-top: var(--s-7);
    padding-bottom: var(--s-7);
    border-bottom: 1px solid var(--rule);
  }
  .home-deck__text {
    font-family: var(--font-body);
    font-size: clamp(1.125rem, 1.6vw, 1.5rem);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 56ch;
    margin: 0 0 var(--s-5);
    font-variation-settings: 'opsz' 16;
  }
  .home-deck__byline {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--fog);
    margin: 0 0 var(--s-5);
  }
  .home-deck__byline strong { color: var(--ink); font-weight: 500; }
  .home-deck__cta {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    color: var(--ink);
    transition: color var(--t-fast) var(--ease-out), border-color var(--t-fast) var(--ease-out);
  }
  .home-deck__cta:hover { color: var(--terracotta); border-color: var(--terracotta); }

  /* FLAVOR STRIP — keeper-type taxonomy */
  .home-flavors {
    margin-top: var(--s-9);
    padding-block: var(--s-8);
    border-block: 1px solid var(--rule);
    background: var(--paper);
  }
  .home-flavors__head { max-width: 56ch; margin-bottom: var(--s-6); }
  .home-flavors__sub {
    margin-top: var(--s-3);
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.5;
  }
  .home-flavors__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule);
  }
  .home-flavors__cell {
    border-right: 1px solid var(--rule);
  }
  .home-flavors__cell:last-child { border-right: 0; }
  .home-flavors__cell a {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    padding: var(--s-5);
    height: 100%;
    color: var(--ink);
    transition: background var(--t-fast) var(--ease-out);
  }
  .home-flavors__cell a:hover { background: var(--paper-deep); }
  .home-flavors__num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.125rem;
    color: var(--fog);
    line-height: 1;
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .home-flavors__cell a:hover .home-flavors__num { color: var(--terracotta); }
  .home-flavors__label {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.375rem, 2.2vw, 1.75rem);
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--ink);
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .home-flavors__label em {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .home-flavors__note {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink-soft);
    flex: 1;
  }
  .home-flavors__count {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    color: var(--fog);
  }
  .home-flavors__cell a:hover .home-flavors__count { color: var(--terracotta); }

  /* SPOTLIGHT — asymmetric big + 2 stacked */
  .home-spotlight {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: var(--s-6);
    margin-bottom: var(--s-9);
    padding-bottom: var(--s-7);
    border-bottom: 1px solid var(--rule);
  }
  .home-spotlight__main { color: var(--ink); display: flex; flex-direction: column; gap: var(--s-3); }
  .home-spotlight__media {
    overflow: hidden;
    margin-bottom: var(--s-3);
  }
  .home-spotlight__media :global(.real-image),
  .home-spotlight__media :global(.placeholder) {
    transition: transform 600ms var(--ease-out);
  }
  .home-spotlight__main:hover .home-spotlight__media :global(.real-image),
  .home-spotlight__main:hover .home-spotlight__media :global(.placeholder) {
    transform: scale(1.02);
  }
  .home-spotlight__eyebrow {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    color: var(--terracotta);
    margin: 0;
  }
  .home-spotlight__title {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.022em;
    margin: 0;
    font-variation-settings: 'opsz' 144, 'SOFT' 30;
  }
  .home-spotlight__title :global(em) {
    font-style: italic;
    color: var(--terracotta);
    font-variation-settings: 'opsz' 144, 'SOFT' 80, 'WONK' 1;
  }
  .home-spotlight__deck {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    max-width: 50ch;
  }
  .home-spotlight__side {
    display: grid;
