---
/**
 * /exhibition, homepage in the Exhibition Magazine visual language.
 * Pulls real data from the stories + best-of collections.
 *
 * Chrome (utility bar, drawer, section nav, newsletter, footer) comes from
 * ExhibitionLayout, identical to every other /* page. Only the
 * homepage-specific content blocks and the carousel rotation script live here.
 */
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import NominateKeeperCTA from '../components/NominateKeeperCTA.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';
import { getCollection } from 'astro:content';
import AuthorAvatar from '../components/AuthorAvatar.astro';

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);
const featured = stories.find((s) => s.data.is_featured) || stories[0];
const carouselStories = [featured, ...stories.filter((s) => s.slug !== featured.slug).slice(0, 3)];
// Drift-style editor's paragraph pulls the next 8 most recent stories.
// Each title becomes an inline link; connective prose carries the editor's voice.
const ledeStories = stories.filter((s) => s.slug !== featured.slug).slice(0, 8);
const bodyStory = stories.find((s) => s.data.pull_quote) || featured;
const bodyText = bodyStory.data.pull_quote || bodyStory.data.deck;
// Sponsored article slot: pulls the most recent story with a `sponsor` field set.
// Falls back to null (slot shows open-state placeholder) when none exist.
const sponsoredStory = stories.find((s) => !!s.data.sponsor);

// Calendar timeline: next 5 Saturdays from today.
function nextSaturdays(n: number) {
  const out: Date[] = [];
  const d = new Date();
  const daysUntilSat = (6 - d.getDay() + 7) % 7 || 7;
  d.setDate(d.getDate() + daysUntilSat);
  for (let i = 0; i < n; i++) {
    out.push(new Date(d));
    d.setDate(d.getDate() + 7);
  }
  return out;
}
function fmtSat(date: Date) {
  return date
    .toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: '2-digit', year: 'numeric' })
    .toUpperCase();
}
const upcoming = nextSaturdays(5);
const AUTHORS = ['ERIC', 'NICHOLAS', 'DAISY', 'ERIC', 'NICHOLAS'];
const thisSaturday = upcoming[0];
const thisSatLabel = thisSaturday
  .toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' })
  .toUpperCase();
const nextIssue = (featured.data.issue || 0) + 1;

// Brief homepage strip. Pulls top 3 items from the latest published brief.
// The full edition lives at /brief/, archive at /brief/[date]/, and each
// item has its own permalink at /brief/[date]/[slug]/.
const allBriefs = await getCollection('briefs');
const sortedBriefs = [...allBriefs].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestBrief = sortedBriefs[0];
const latestBriefDate = latestBrief ? latestBrief.data.date.toISOString().slice(0, 10) : null;

// Map brief signal tags to homepage strip color tokens for the left border.
const SIGNAL_COLOR_MAP: Record<string, string> = {
  'first-to-connect': 'terracotta',
  'underreported': 'pacific',
  'missing-context': 'fog',
  'structural-pattern': 'ink-soft',
};

function briefReadingTime(text: string): string {
  const words = text.trim().split(/\s+/).filter(Boolean).length;
  const seconds = Math.round((words / 200) * 60);
  if (seconds < 60) return `${Math.max(20, Math.ceil(seconds / 10) * 10)} sec`;
  if (seconds < 90) return '1 min';
  if (seconds < 150) return '2 min';
  return `${Math.round(seconds / 60)} min`;
}

const sortedBriefItems = latestBrief
  ? [...latestBrief.data.items].sort((a, b) => b.composite_score - a.composite_score)
  : [];

// Hero = top item by composite. Strip = items 2-4 below the hero.
const briefHeroRaw = sortedBriefItems[0] || null;
const briefHero = briefHeroRaw && latestBriefDate
  ? {
      category: briefHeroRaw.category,
      signal: briefHeroRaw.signal,
      headline: briefHeroRaw.source_headline,
      tldr: briefHeroRaw.tldr,
      angle: briefHeroRaw.angle_statement,
      source_outlet: briefHeroRaw.source_outlet,
      source_byline: briefHeroRaw.source_byline,
      read_time: briefReadingTime(briefHeroRaw.tldr + ' ' + briefHeroRaw.editor_note),
      href: `/brief/${latestBriefDate}/${briefHeroRaw.slug}/`,
    }
  : null;

const briefItems = sortedBriefItems
  .slice(1, 4)
  .map((item) => ({
    category: item.category,
    color: SIGNAL_COLOR_MAP[item.signal] || 'terracotta',
    headline: item.source_headline,
    source_outlet: item.source_outlet,
    read_time: briefReadingTime(item.tldr + ' ' + item.editor_note),
    href: `/brief/${latestBriefDate}/${item.slug}/`,
  }));

const briefDateLabel = latestBrief
  ? latestBrief.data.date
      .toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric' })
      .toUpperCase()
  : '';
const briefTotalItems = latestBrief ? latestBrief.data.items.length : 0;

// This Week strip. Pulls the latest published weekly digest, if any exists.
// Rendered between the news blocks and the KEEPERS vertical. Empty until the
// first weekly ships (the section simply doesn't render).
const allWeeklies = await getCollection('weeklies');
const latestWeekly = [...allWeeklies].sort(
  (a, b) => b.data.end_date.valueOf() - a.data.end_date.valueOf()
)[0];
const weeklyRange = latestWeekly
  ? `${latestWeekly.data.start_date.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })} to ${latestWeekly.data.end_date.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })}`
  : '';
const weeklyDeck = latestWeekly
  ? latestWeekly.data.intro.split(/(?<=[.!?])\s+/).filter(Boolean).slice(0, 2).join(' ')
  : '';
---
<ExhibitionLayout
  title="THE KEEPERS · SF TIMES"
  description="One San Francisco keeper every Saturday. Reader-funded."
  active="home"
>
  <ExhibitionMasthead slot="masthead" title="THE KEEPERS" subscript="SF TIMES" cutouts={[]} />

  <p class="ex-tagline">One San Francisco keeper, every Saturday morning. <span class="ex-tagline__nowrap">Reader&#8209;funded.</span></p>

  <!-- PRESENTED-BY STRIP · single editorial sponsor credit at top of homepage.
       Mirrors how the Co-Presented credit appears at the top of each saturday letter.
       Empty state doubles as promotion for /partners. -->
  <aside class="presented" aria-label="Saturday letter sponsor">
    <span class="presented__label">THIS SATURDAY'S LETTER</span>
    <span class="presented__divider">·</span>
    <span class="presented__slot">
      Co-Presented slot open for June 14.
      <a href="/partners#saturday">Claim this slot →</a>
    </span>
  </aside>

  <!-- FEATURED CAROUSEL · TYPOGRAPHIC (PATH A, text-first) -->
  <div class="feat" id="featCarousel">
    {carouselStories.map((s, i) => (
      <a class={`feat__slide feat__slide--keeper-${s.data.keeper_type || 'default'}${i === 0 ? ' is-on' : ''}`} data-slide={i} href={`/stories/${s.data.url_slug}`}>
        <span class="feat__issue-bg" aria-hidden="true">№{String(s.data.issue).padStart(2, '0')}</span>
        <div class="feat__inner">
          <div class="feat__tags">
            {s.data.keeper_type && <span class="feat__keeper">{s.data.keeper_type.toUpperCase()}</span>}
            {s.data.neighborhood && <span class="feat__neighborhood">{s.data.neighborhood.toUpperCase()}</span>}
          </div>
          <p class="feat__eyebrow">
            ISSUE №{s.data.issue} · BY {s.data.author.toUpperCase()} · {s.data.read_minutes}-MIN READ
          </p>
          <h2 class="feat__title">{s.data.title}</h2>
          <p class="feat__deck">{s.data.deck}</p>
          <span class="feat__cta">Read the profile <span aria-hidden="true">→</span></span>
        </div>
      </a>
    ))}
    <div class="feat__dots" id="featDots">
      {carouselStories.map((s, i) => (
        <button class={`feat__dot${i === 0 ? ' is-on' : ''}`} data-dot={i} aria-label={`Slide ${i + 1}: ${s.data.title}`}></button>
      ))}
    </div>
  </div>

  <!-- EDITOR'S PARAGRAPH. Drift-style hyperlinked landing block.
       Each title is a link inline. Connective text comes from each story's
       own lede_line (preferred, hand-curated) or falls back to the first
       sentence of the deck. -->
  <section class="lede">
    <p class="lede__eyebrow">FROM THE EDITOR · WHAT WE'VE BEEN KEEPING</p>
    <p class="lede__text">
      {ledeStories.map((s) => {
        const clause = s.data.lede_line || (s.data.deck.split(/\.\s+/)[0] + '.');
        return (
          <>
            <a href={`/stories/${s.data.url_slug}`}>{s.data.title}</a>
            {' '}{clause}{' '}
          </>
        );
      })}
      <a href="/stories" class="lede__all">All {stories.length} issues →</a>
    </p>
  </section>

  <!-- SPONSORED ARTICLE SLOT · highlights an "In collaboration with" feature.
       Live state: shows the most recent story with a sponsor field set.
       Empty state: soft pitch promoting /partners. -->
  {sponsoredStory ? (
    <section class={`sponsored sponsored--live sponsored--text sponsored--keeper-${sponsoredStory.data.keeper_type || 'default'}`} aria-label="Sponsored feature">
      <a class="sponsored__link" href={`/stories/${sponsoredStory.data.url_slug}`}>
        <span class="sponsored__issue-bg" aria-hidden="true">№{String(sponsoredStory.data.issue).padStart(2, '0')}</span>
        <div class="sponsored__body-wrap">
          <p class="sponsored__chip">PARTNER FEATURE · IN COLLABORATION WITH {sponsoredStory.data.sponsor.name.toUpperCase()}</p>
          {sponsoredStory.data.keeper_type && (
            <span class="sponsored__keeper">{sponsoredStory.data.keeper_type.toUpperCase()}</span>
          )}
          <h2 class="sponsored__title">{sponsoredStory.data.title}</h2>
          <p class="sponsored__deck">{sponsoredStory.data.deck}</p>
          <div class="sponsored__cta-row">
            <span class="sponsored__cta">READ THE FEATURE →</span>
            <span class="sponsored__byline">ISSUE №{sponsoredStory.data.issue} · BY {sponsoredStory.data.author.toUpperCase()} · {sponsoredStory.data.read_minutes}-MIN READ</span>
          </div>
          <p class="sponsored__firewall">EDITORIAL FIREWALL: SPONSOR APPROVED FACTS, NOT ANGLE. EDITOR WROTE EVERY WORD.</p>
        </div>
      </a>
    </section>
  ) : (
    <section class="sponsored" aria-label="Sponsored article slot">
      <div class="sponsored__inner">
        <p class="sponsored__chip">PARTNER FEATURE · SLOT OPEN</p>
        <h2 class="sponsored__title">YOUR STORY HERE.<br>WRITTEN BY US.<br>READ EVERY SATURDAY.</h2>
        <p class="sponsored__body">This is where a sponsored Profile sits when a partner books it. Same column width, same editorial voice, same Saturday readers. Marked in collaboration, never disguised.</p>
        <div class="sponsored__cta-row">
          <a class="sponsored__cta" href="/partners#stories">CLAIM THIS SLOT →</a>
        </div>
      </div>
    </section>
  )}

  <!-- THE BRIEF · daily news section · sits between the sponsored feature
       and the KEEPERS vertical block. Two-tier hierarchy on the homepage:
       (1) a lead-story hero with full editor's note preview, (2) a 3-card
       strip with the next 3 items by composite score. Each card links to
       its permalink at /brief/[date]/[slug]/. -->
  {latestBrief && (
    <section class="brief-home" aria-label="Today's Brief">
      <div class="brief-home__head">
        <div>
          <p class="brief-home__eyebrow">THE BRIEF · {briefDateLabel}</p>
          <h2 class="brief-home__title">What we read this morning.</h2>
          <p class="brief-home__sub">Daily curated SF news. Linked out, never rewritten. Editor's note in our voice.</p>
        </div>
        <a class="brief-home__see-all" href="/brief/">
          SEE ALL {briefTotalItems} IN TODAY'S BRIEF →
        </a>
      </div>

      {briefHero && (
        <a class={`brief-hero brief-hero--${briefHero.signal}`} href={briefHero.href}>
          <header class="brief-hero__head">
            <p class="brief-hero__lead-label">TODAY'S LEAD STORY</p>
            <div class="brief-hero__tags">
              <span class="brief-hero__category">{briefHero.category}</span>
              <span class={`brief-hero__signal brief-hero__signal--${briefHero.signal}`}>
                {briefHero.signal.replace(/-/g, ' ').toUpperCase()}
              </span>
              <span class="brief-hero__time">{briefHero.read_time}</span>
            </div>
          </header>

          <h3 class="brief-hero__headline">{briefHero.headline}</h3>
          <p class="brief-hero__tldr">{briefHero.tldr}</p>

          <div class="brief-hero__angle">
            <p class="brief-hero__angle-label">THE ANGLE</p>
            <p class="brief-hero__angle-text">{briefHero.angle}</p>
          </div>

          <footer class="brief-hero__foot">
            <p class="brief-hero__source">
              Reported by <strong>{briefHero.source_byline}</strong> at {briefHero.source_outlet}
            </p>
            <span class="brief-hero__cta">Read editor's note <span aria-hidden="true">→</span></span>
          </footer>
        </a>
      )}

      {briefItems.length > 0 && (
        <>
          <p class="brief-home__more-label">MORE FROM TODAY</p>
          <div class="brief-strip__grid">
            {briefItems.map((item) => (
              <a class={`brief-strip__card brief-strip__card--${item.color}`} href={item.href}>
                <div class="brief-strip__card-head">
                  <span class="brief-strip__category">{item.category}</span>
                  <span class="brief-strip__time">{item.read_time}</span>
                </div>
                <h3 class="brief-strip__headline">{item.headline}</h3>
                <span class="brief-strip__source">Reported by {item.source_outlet}</span>
              </a>
            ))}
          </div>
        </>
      )}
    </section>
  )}

  <!-- THIS WEEK IN SF · weekly digest strip · sits between the news blocks
       and the KEEPERS vertical. Renders only when a weekly has been published;
       links to the latest /this-week/[week_id] post. -->
  {latestWeekly && (
    <section class="thisweek-home" aria-label="This week in SF">
      <a class="thisweek-home__link" href={`/this-week/${latestWeekly.data.week_id}/`}>
        <div class="thisweek-home__label-col">
          <p class="thisweek-home__eyebrow">THIS WEEK IN SF</p>
          <p class="thisweek-home__range">{weeklyRange}</p>
        </div>
        <div class="thisweek-home__body">
          <h2 class="thisweek-home__title">The week, made sense of.</h2>
          <p class="thisweek-home__deck">{weeklyDeck}</p>
          <span class="thisweek-home__cta">Read this week's digest <span aria-hidden="true">→</span></span>
        </div>
      </a>
    </section>
  )}

  <!-- KEEPERS VERTICAL BLOCK · TYPOGRAPHIC (PATH A)
       Dark band with a pull quote from the featured story instead of a photo.
       The third column carries the issue number set huge as a typographic
       counterweight to the wordmark. -->
  <a href={`/stories/${bodyStory.data.url_slug}`} class="vbar" style="text-decoration:none;">
    <div class="vbar__brand">KEEPERS</div>
    <div class="vbar__copy">
      <p>{bodyText}</p>
      <p style="margin-top:18px; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(244,241,234,0.6);">{(bodyStory.data.pull_quote_attr || bodyStory.data.author).toUpperCase()} · ISSUE №{bodyStory.data.issue} →</p>
    </div>
    <div class="vbar__issue">
      <span class="vbar__issue-num" aria-hidden="true">№{String(bodyStory.data.issue).padStart(2, '0')}</span>
      <span class="vbar__issue-label">{bodyStory.data.keeper_type ? bodyStory.data.keeper_type.toUpperCase() : 'KEEPER'}</span>
      {bodyStory.data.neighborhood && (
        <span class="vbar__issue-neighborhood">{bodyStory.data.neighborhood.toUpperCase()}</span>
      )}
    </div>
  </a>

  <NominateKeeperCTA size="compact" />

  <!-- ARCHIVE STRIP: clean horizontal scroll of past issues -->
  <section class="archive">
    <div class="archive__head">
      <div>
        <p class="archive__label">THE ARCHIVE</p>
        <p class="archive__sub">{stories.length} issues · Next saturday: {thisSatLabel.toLowerCase()}</p>
      </div>
      <a class="archive__viewall" href="/stories">VIEW ALL →</a>
    </div>
    <div class="archive__strip">
      {stories.slice(0, 10).map((s) => (
        <a class={`archive__item archive__item--text archive__item--keeper-${s.data.keeper_type || 'default'}`} href={`/stories/${s.data.url_slug}`}>
          <span class="archive__issue" aria-hidden="true">№{String(s.data.issue).padStart(2, '0')}</span>
          {s.data.keeper_type && (
            <span class="archive__keeper">{s.data.keeper_type.toUpperCase()}</span>
          )}
          <p class="archive__title">{s.data.title}</p>
          <p class="archive__meta">{fmtSat(new Date(s.data.published))} · BY {s.data.author.toUpperCase()}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- CLASSIFIEDS · six text-only sponsor lines, alphabetized.
       Maps to "The Classified" tier in /partners. Editorial typography,
       no banners, no logos. Empty slots advertise themselves. -->
  <section class="classifieds" aria-label="Classified sponsor mentions">
    <p class="classifieds__label">CLASSIFIEDS · SATURDAY №{nextIssue}</p>
    <ul class="classifieds__list">
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">Claim a classified for this Saturday, $149.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">One line, six slots, alphabetized by sponsor.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">No logos, no banners, just your name.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">Lives forever on this Saturday's archive page.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">See work with us for the full lineup of partner tiers.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">Book before Thursday at 5pm for this Saturday's letter.</a></span></li>
    </ul>
    <p class="classifieds__foot"><a href="/partners#saturday">See all partner tiers →</a></p>
  </section>

</ExhibitionLayout>

<style>
  /* === TAGLINE (under masthead, above carousel) === */
  .ex-tagline {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    padding: 0 20px;
    margin: 0 0 24px;
    line-height: 1.6;
    hyphens: none;
    word-break: keep-all;
  }
  .ex-tagline__nowrap { white-space: nowrap; }

  /* === FEATURED CAROUSEL · TYPOGRAPHIC (PATH A) ===
     Photo carousel replaced with a colored panel carousel. Each slide is
     a paper-2 background with massive issue number watermark, keeper-typed
     stripe, and headline at display scale. */
  .feat { position: relative; margin: 12px 12px 0; aspect-ratio: 24/10; overflow: hidden; background: var(--paper-2); }
  .feat__slide {
    position: absolute; inset: 0;
    opacity: 0; transition: opacity 500ms;
    pointer-events: none;
    display: block;
    padding: 48px 48px 56px;
    color: var(--ink);
    overflow: hidden;
  }
  .feat__slide.is-on { opacity: 1; pointer-events: auto; }
  .feat__slide::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 8px;
    background: var(--accent);
  }
  .feat__slide--keeper-routine::before { background: #2c5582; }
  .feat__slide--keeper-room::before { background: var(--muted); }
  .feat__slide--keeper-record::before { background: var(--ink-2); }
  .feat__slide--keeper-refusal::before { background: #a82919; }
  .feat__issue-bg {
    position: absolute;
    right: -4vw;
    top: 25%;
    transform: translateY(-50%);
    font-family: var(--display);
    font-size: clamp(180px, 26vw, 360px);
    line-height: 0.85;
    color: rgba(189, 182, 164, 0.35);
    letter-spacing: -0.04em;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }
  .feat__inner {
    position: relative; z-index: 1;
    max-width: 1080px;
    margin: 0 auto;
    height: 100%;
    display: flex; flex-direction: column; justify-content: center;
  }
  .feat__tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
  .feat__keeper, .feat__neighborhood {
    display: inline-block;
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-transform: uppercase;
    padding: 5px 12px;
    background: var(--paper);
    color: var(--ink);
    border: 1px solid var(--rule);
  }
  .feat__keeper { background: var(--accent); color: var(--paper); border-color: var(--accent); }
  .feat__slide--keeper-routine .feat__keeper { background: #2c5582; border-color: #2c5582; }
  .feat__slide--keeper-room .feat__keeper { background: var(--muted); border-color: var(--muted); }
  .feat__slide--keeper-record .feat__keeper { background: var(--ink-2); border-color: var(--ink-2); }
  .feat__slide--keeper-refusal .feat__keeper { background: #a82919; border-color: #a82919; }
  .feat__eyebrow {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 700;
    margin: 0 0 16px;
  }
  .feat__title {
    font-family: var(--display);
    font-size: clamp(36px, 6vw, 84px);
    line-height: 0.96;
    letter-spacing: -0.015em;
    margin: 0 0 16px;
    color: var(--ink);
    text-transform: uppercase;
    max-width: 22ch;
  }
  .feat__deck {
    font-family: var(--body);
    font-size: clamp(15px, 1.6vw, 20px);
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 24px;
    max-width: 56ch;
    font-style: italic;
  }
  .feat__cta {
    font-family: var(--ui);
    font-size: 12px;
    letter-spacing: 0.14em;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    display: inline-block;
  }
  .feat__dots { position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 3; }
  .feat__dot { width: 24px; height: 2px; background: rgba(24, 22, 18, 0.25); cursor: pointer; transition: background 150ms; border: 0; padding: 0; }
  .feat__dot.is-on { background: var(--ink); }

  @media (max-width: 640px) {
    .feat { aspect-ratio: 16/13; }
    .feat__slide { padding: 36px 24px 48px; }
    .feat__issue-bg { font-size: clamp(140px, 48vw, 220px); top: 30%; }
    .feat__title { font-size: clamp(28px, 9vw, 44px); }
    .feat__deck { font-size: 15px; }
  }

  /* === EDITOR'S PARAGRAPH (Drift-style hyperlinked lede) === */
  .lede { padding: 80px 24px 72px; max-width: 880px; margin: 0 auto; }
  .lede__eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0 0 32px; padding-bottom: 14px; border-bottom: 1px solid var(--rule); }
  .lede__text {
    font-family: var(--ui);
    font-size: clamp(17px, 1.6vw, 21px);
    line-height: 1.65;
    letter-spacing: 0;
    color: var(--ink);
    margin: 0;
    text-wrap: pretty;
  }
  .lede__text a {
    color: var(--ink);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    transition: border-bottom-width 180ms ease, opacity 180ms;
  }
  .lede__text a:hover { border-bottom-width: 2px; opacity: 0.7; }
  .lede__text .lede__all {
    display: inline-block;
    margin-top: 8px;
    font-weight: 600;
    border-bottom: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
  }
  .lede__text .lede__all:hover { opacity: 0.7; }

  /* === VERTICAL BLOCK === */
  /* KEEPERS wordmark sits in its own column. Font cap and column width
     are paired so the brand never bleeds into the copy column. */
  .vbar { display: grid; grid-template-columns: 360px 1.1fr 1.4fr; margin: 64px 0 0; background: var(--ink); color: var(--paper); min-height: 360px; overflow: hidden; }
  .vbar__brand { font-family: var(--display); font-size: clamp(40px, 4.4vw, 62px); line-height: 1; text-transform: uppercase; align-self: center; padding-left: 32px; letter-spacing: -0.01em; white-space: nowrap; }
  .vbar__copy { padding: 64px 36px; font-size: 14px; line-height: 1.55; color: rgba(244,241,234,0.92); align-self: center; max-width: 36ch; min-width: 0; }
  /* Path A: third column is a typographic counterweight to the wordmark.
     Massive issue number stacked with the keeper_type label and neighborhood. */
  .vbar__issue {
    background: var(--ink-2);
    padding: 48px 36px;
    display: flex; flex-direction: column; justify-content: center; align-items: flex-start;
    gap: 14px;
    color: var(--paper);
    overflow: hidden;
    position: relative;
  }
  .vbar__issue-num {
    font-family: var(--display);
    font-size: clamp(120px, 14vw, 220px);
    line-height: 0.85;
    color: rgba(244, 241, 234, 0.18);
    letter-spacing: -0.04em;
    margin: -8px 0 0;
    word-break: keep-all;
    white-space: nowrap;
  }
  .vbar__issue-label {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
  }
  .vbar__issue-neighborhood {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(244, 241, 234, 0.55);
    font-weight: 500;
  }

  /* === ARCHIVE STRIP === */
  /* Replaces the awkward cal+strip pair. Horizontal scroll of past issues,
     small photo + meta + title. Clean, no vertical text, no dead zones. */
  .archive { background: var(--paper); padding: 64px 12px 80px; }
  .archive__head { display: flex; align-items: flex-end; justify-content: space-between; margin: 0 0 28px; gap: 24px; }
  .archive__label { font-family: var(--display); font-size: clamp(28px, 3.4vw, 48px); line-height: 1; letter-spacing: -0.005em; text-transform: uppercase; color: var(--ink); margin: 0 0 6px; }
  .archive__sub { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin: 0; }
  .archive__viewall { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink); padding-bottom: 2px; border-bottom: 1px solid currentColor; transition: opacity 200ms; flex-shrink: 0; }
  .archive__viewall:hover { opacity: 0.6; }
  .archive__strip { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 14px; scroll-behavior: smooth; }
  .archive__strip::-webkit-scrollbar { height: 4px; }
  .archive__strip::-webkit-scrollbar-track { background: var(--paper-2); }
  .archive__strip::-webkit-scrollbar-thumb { background: var(--rule); }
  .archive__item--text {
    flex: 0 0 auto;
    width: clamp(220px, 22vw, 280px);
    scroll-snap-align: start;
    color: var(--ink);
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-top: 4px solid var(--accent);
    padding: 18px 20px 20px;
    position: relative;
    overflow: hidden;
    transition: background 200ms, transform 200ms;
    display: flex; flex-direction: column; gap: 10px;
    min-height: 200px;
  }
  .archive__item--text:hover { background: var(--paper); transform: translateY(-2px); }
  .archive__item--keeper-routine { border-top-color: #2c5582; }
  .archive__item--keeper-room { border-top-color: var(--muted); }
  .archive__item--keeper-record { border-top-color: var(--ink-2); }
  .archive__item--keeper-refusal { border-top-color: #a82919; }
  .archive__issue {
    position: absolute;
    right: -10px;
    top: 0;
    font-family: var(--display);
    font-size: 80px;
    line-height: 0.9;
    color: rgba(189, 182, 164, 0.35);
    letter-spacing: -0.03em;
    pointer-events: none;
    user-select: none;
  }
  .archive__keeper {
    display: inline-block;
    font-family: var(--ui);
    font-size: 9.5px;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-transform: uppercase;
    padding: 3px 9px;
    background: var(--accent);
    color: var(--paper);
    align-self: flex-start;
    position: relative;
    z-index: 1;
  }
  .archive__item--keeper-routine .archive__keeper { background: #2c5582; }
  .archive__item--keeper-room .archive__keeper { background: var(--muted); }
  .archive__item--keeper-record .archive__keeper { background: var(--ink-2); }
  .archive__item--keeper-refusal .archive__keeper { background: #a82919; }
  .archive__title {
    font-family: var(--display);
    font-size: 18px;
    line-height: 1.1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0;
    position: relative;
    z-index: 1;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .archive__meta {
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin: auto 0 0;
    font-weight: 700;
    position: relative;
    z-index: 1;
  }

  /* === PRESENTED BY STRIP === */
  .presented {
    display: flex; flex-wrap: wrap; align-items: center; gap: 12px;
    padding: 14px 24px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--ink);
  }
  .presented__label { font-weight: 700; text-transform: uppercase; }
  .presented__divider { color: var(--muted); }
  .presented__slot { color: var(--ink); }
  .presented__slot a {
    color: #d9551f;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    margin-left: 6px;
  }
  .presented__slot a:hover { opacity: 0.7; }

  /* === SPONSORED ARTICLE SLOT === */
  /* Two states:
     - Empty slot: bordered card with soft-pitch CTA to /partners.
     - Live state: photo + copy split, in collaboration with [SPONSOR] chip. */
  .sponsored { padding: 0 12px 0; margin: 0 0 56px; }
  .sponsored__inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 48px 40px;
    border: 1px solid var(--rule);
    background: var(--paper-2);
    position: relative;
  }
  .sponsored__chip {
    background: var(--ink); color: var(--paper);
    padding: 5px 14px;
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    margin: 0;
    display: inline-block;
  }
  .sponsored__inner > .sponsored__chip {
    position: absolute; top: -10px; left: 28px;
  }
  .sponsored__title {
    font-family: var(--display);
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    margin: 0 0 18px;
    color: var(--ink);
  }
  .sponsored__body {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 24px;
    max-width: 52ch;
  }
  .sponsored__deck {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 24px;
    max-width: 52ch;
  }
  .sponsored__cta-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-top: 18px;
    border-top: 1px solid var(--rule);
    flex-wrap: wrap;
  }
  .sponsored__cta {
    color: var(--ink);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  .sponsored__cta:hover { opacity: 0.7; }
  .sponsored__byline {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Live state · TYPOGRAPHIC (PATH A): full-width text-first card with
     issue-number watermark behind. No photo column. */
  .sponsored--live { padding: 0; margin: 0 0 64px; }
  .sponsored--live .sponsored__link {
    display: block;
    max-width: 1200px;
    margin: 0 auto;
    border-block: 1px solid var(--rule);
    color: var(--ink);
    transition: background 200ms, transform 200ms;
    position: relative;
    overflow: hidden;
    background: var(--paper-2);
  }
  .sponsored--live .sponsored__link:hover { background: var(--paper); transform: translateY(-1px); }
  .sponsored__issue-bg {
    position: absolute;
    right: -2vw;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--display);
    font-size: clamp(180px, 26vw, 360px);
    line-height: 0.85;
    color: rgba(189, 182, 164, 0.30);
    letter-spacing: -0.04em;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }
  .sponsored__keeper {
    display: inline-block;
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-transform: uppercase;
    padding: 4px 11px;
    background: var(--accent);
    color: var(--paper);
    margin-bottom: 14px;
    align-self: flex-start;
  }
  .sponsored--keeper-routine .sponsored__keeper { background: #2c5582; }
  .sponsored--keeper-room .sponsored__keeper { background: var(--muted); }
  .sponsored--keeper-record .sponsored__keeper { background: var(--ink-2); }
  .sponsored--keeper-refusal .sponsored__keeper { background: #a82919; }
  .sponsored__body-wrap {
    position: relative;
    z-index: 1;
    padding: 48px 48px 44px;
    max-width: 880px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sponsored--live .sponsored__chip { align-self: flex-start; margin-bottom: 4px; }
  .sponsored--live .sponsored__title { font-size: clamp(28px, 3.2vw, 42px); margin: 0; text-transform: uppercase; }
  .sponsored--live .sponsored__deck { margin: 0; }
  .sponsored--live .sponsored__cta-row { margin-top: auto; }
  .sponsored__firewall {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
  }

  /* === THE BRIEF · HOMEPAGE SECTION === */
  /* Daily curated news between the sponsored feature and KEEPERS block.
     Two-tier hierarchy: hero (lead story) + strip (next 3 by composite). */
  .brief-home {
    max-width: 1200px;
    margin: 0 auto 64px;
    padding: 0 24px;
  }
  .brief-home__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
    padding-bottom: 18px;
    border-bottom: 1px solid var(--rule);
  }
  .brief-home__eyebrow {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 8px;
    font-weight: 700;
  }
  .brief-home__title {
    font-family: var(--display);
    font-size: clamp(28px, 3.6vw, 48px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 8px;
  }
  .brief-home__sub {
    font-family: var(--ui);
    font-size: 13px;
    line-height: 1.45;
    color: var(--muted);
    margin: 0;
    max-width: 56ch;
  }
  .brief-home__see-all {
    font-family: var(--ui);
    font-size: 12px;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .brief-home__more-label {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 700;
    margin: 32px 0 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--rule);
  }

  /* ============ HERO LEAD STORY ============ */
  .brief-hero {
    display: block;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-left-width: 6px;
    padding: 32px 40px 28px;
    color: var(--ink);
    transition: background 200ms, transform 200ms;
  }
  .brief-hero:hover {
    background: var(--paper);
    transform: translateY(-2px);
  }
  .brief-hero--first-to-connect { border-left-color: var(--accent); }
  .brief-hero--underreported { border-left-color: #2c5582; }
  .brief-hero--missing-context { border-left-color: var(--muted); }
  .brief-hero--structural-pattern { border-left-color: var(--ink-2); }

  .brief-hero__head {
    margin-bottom: 18px;
  }
  .brief-hero__lead-label {
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
    margin: 0 0 10px;
  }
  .brief-hero__tags {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }
  .brief-hero__category {
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.18em;
    font-weight: 700;
    text-transform: uppercase;
    background: var(--paper);
    padding: 4px 10px;
    color: var(--ink);
  }
  .brief-hero:hover .brief-hero__category { background: var(--paper-2); }
  .brief-hero__signal {
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.14em;
    font-weight: 700;
    padding: 4px 10px;
    color: white;
  }
  .brief-hero__signal--first-to-connect { background: var(--accent); }
  .brief-hero__signal--underreported { background: #2c5582; }
  .brief-hero__signal--missing-context { background: var(--muted); }
  .brief-hero__signal--structural-pattern { background: var(--ink-2); }
  .brief-hero__time {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.10em;
    color: var(--muted);
    text-transform: uppercase;
    margin-left: auto;
  }
  .brief-hero__headline {
    font-family: var(--display);
    font-size: clamp(28px, 3.6vw, 42px);
    line-height: 1.08;
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    color: var(--ink);
    max-width: 26ch;
  }
  .brief-hero__tldr {
    font-family: var(--ui);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 18px;
    max-width: 58ch;
  }
  .brief-hero__angle {
    padding: 14px 18px;
    background: rgba(217, 85, 31, 0.08);
    border-left: 3px solid var(--accent);
    margin: 0 0 20px;
    max-width: 58ch;
  }
  .brief-hero__angle-label {
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.20em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
    margin: 0 0 6px;
  }
  .brief-hero__angle-text {
    font-family: var(--display);
    font-size: clamp(16px, 1.8vw, 19px);
    line-height: 1.4;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.005em;
  }
  .brief-hero__foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 14px;
    border-top: 1px solid var(--rule);
    gap: 16px;
    flex-wrap: wrap;
  }
  .brief-hero__source {
    font-family: var(--ui);
    font-size: 12px;
    color: var(--muted);
    margin: 0;
    line-height: 1.45;
  }
  .brief-hero__source strong { color: var(--ink); font-weight: 700; }
  .brief-hero__cta {
    font-family: var(--ui);
    font-size: 12px;
    letter-spacing: 0.16em;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* ============ STRIP (NEXT 3 ITEMS) ============ */
  .brief-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .brief-strip__card {
    background: var(--paper-2);
    padding: 16px 18px;
    border-left: 3px solid var(--accent);
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background 200ms ease, transform 200ms ease;
    color: var(--ink);
  }
  .brief-strip__card:hover {
    background: #d9d3c2;
    transform: translateY(-1px);
  }
  .brief-strip__card--terracotta { border-left-color: var(--accent); }
  .brief-strip__card--pacific    { border-left-color: #2c5582; }
  .brief-strip__card--fog        { border-left-color: var(--muted); }
  .brief-strip__card--ink-soft   { border-left-color: var(--ink-2); }
  .brief-strip__card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
  }
  .brief-strip__category {
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.18em;
    font-weight: 700;
    color: var(--ink);
    text-transform: uppercase;
  }
  .brief-strip__time {
    font-family: var(--ui);
    font-size: 10px;
    letter-spacing: 0.10em;
    color: var(--muted);
    text-transform: uppercase;
    font-weight: 500;
  }
  .brief-strip__headline {
    font-family: var(--display);
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.25;
    letter-spacing: -0.005em;
    text-transform: none;
    color: var(--ink);
    margin: 0;
    font-weight: 500;
  }
  .brief-strip__source {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--muted);
    margin-top: auto;
  }

  @media (max-width: 880px) {
    .brief-strip__grid {
      grid-template-columns: 1fr;
    }
    .brief-home__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }
    .brief-hero { padding: 24px 24px 22px; }
    .brief-hero__headline { font-size: 26px; }
    .brief-hero__tldr { font-size: 16px; }
    .brief-hero__time { margin-left: 0; }
  }

  @media (max-width: 420px) {
    .brief-hero { padding: 20px 18px 18px; }
    .brief-hero__headline { font-size: 22px; }
    .brief-hero__tldr { font-size: 15px; }
    .brief-hero__angle { padding: 12px 14px; }
    .brief-hero__angle-text { font-size: 15px; }
    .brief-hero__foot { flex-direction: column; align-items: flex-start; gap: 8px; }
  }

  /* === THIS WEEK IN SF · HOMEPAGE STRIP === */
  .thisweek-home { max-width: 1200px; margin: 0 auto 64px; padding: 0 24px; }
  .thisweek-home__link {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 32px;
    align-items: center;
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-left: 6px solid var(--accent);
    padding: 32px 40px;
    color: var(--ink);
    transition: background 200ms, transform 200ms;
  }
  .thisweek-home__link:hover { background: var(--paper); transform: translateY(-2px); }
  .thisweek-home__eyebrow {
    font-family: var(--display);
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 8px;
  }
  .thisweek-home__range {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 700;
    margin: 0;
  }
  .thisweek-home__title {
    font-family: var(--display);
    font-size: clamp(22px, 2.6vw, 32px);
    line-height: 1.05;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    color: var(--ink);
    margin: 0 0 10px;
  }
  .thisweek-home__deck {
    font-family: 'Newsreader', Georgia, serif;
    font-style: italic;
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 14px;
    max-width: 60ch;
  }
  .thisweek-home__cta {
    font-family: var(--ui);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--accent);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  @media (max-width: 880px) {
    .thisweek-home__link {
