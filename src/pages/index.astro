---
/**
 * /exhibition, homepage in the Exhibition Magazine visual language.
 * Pulls real data from the stories + best-of collections.
 *
 * Chrome (utility bar, drawer, section nav, newsletter, footer) comes from
 * ExhibitionLayout, identical to every other /* page. Only the
 * homepage-specific content blocks and the carousel rotation script live here.
 */
import ExhibitionLayout from '../layouts/ExhibitionLayout.astro';
import ExhibitionMasthead from '../components/ExhibitionMasthead.astro';
import { getCollection } from 'astro:content';
import Placeholder from '../components/Placeholder.astro';
import AuthorAvatar from '../components/AuthorAvatar.astro';

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.published.valueOf() - a.data.published.valueOf()
);
const featured = stories.find((s) => s.data.is_featured) || stories[0];
const carouselStories = [featured, ...stories.filter((s) => s.slug !== featured.slug).slice(0, 3)];
// Drift-style editor's paragraph pulls the next 8 most recent stories.
// Each title becomes an inline link; connective prose carries the editor's voice.
const ledeStories = stories.filter((s) => s.slug !== featured.slug).slice(0, 8);
const bodyStory = stories.find((s) => s.data.pull_quote) || featured;
const bodyText = bodyStory.data.pull_quote || bodyStory.data.deck;
// Sponsored article slot — pulls the most recent story with a `sponsor` field set.
// Falls back to null (slot shows open-state placeholder) when none exist.
const sponsoredStory = stories.find((s) => !!s.data.sponsor);

// Calendar timeline: next 5 Saturdays from today.
function nextSaturdays(n: number) {
  const out: Date[] = [];
  const d = new Date();
  const daysUntilSat = (6 - d.getDay() + 7) % 7 || 7;
  d.setDate(d.getDate() + daysUntilSat);
  for (let i = 0; i < n; i++) {
    out.push(new Date(d));
    d.setDate(d.getDate() + 7);
  }
  return out;
}
function fmtSat(date: Date) {
  return date
    .toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: '2-digit', year: 'numeric' })
    .toUpperCase();
}
const upcoming = nextSaturdays(5);
const AUTHORS = ['ERIC', 'NICHOLAS', 'DAISY', 'ERIC', 'NICHOLAS'];
const thisSaturday = upcoming[0];
const thisSatLabel = thisSaturday
  .toLocaleDateString('en-US', { month: 'long', day: '2-digit', year: 'numeric' })
  .toUpperCase();
const nextIssue = (featured.data.issue || 0) + 1;
---
<ExhibitionLayout
  title="THE KEEPERS · SF TIMES"
  description="One San Francisco keeper every Saturday. Reader-funded."
  active="home"
>
  <ExhibitionMasthead slot="masthead" title="THE KEEPERS" subscript="SF TIMES" cutouts={[]} />

  <p class="ex-tagline">One San Francisco keeper, every Saturday morning. Reader-funded.</p>

  <!-- PRESENTED-BY STRIP · single editorial sponsor credit at top of homepage.
       Mirrors how the Co-Presented credit appears at the top of each saturday letter.
       Empty state doubles as promotion for /partners. -->
  <aside class="presented" aria-label="Saturday letter sponsor">
    <span class="presented__label">THIS SATURDAY'S LETTER</span>
    <span class="presented__divider">·</span>
    <span class="presented__slot">
      Co-Presented slot open for June 14.
      <a href="/partners#saturday">Claim this slot →</a>
    </span>
  </aside>

  <!-- FEATURED CAROUSEL -->
  <div class="feat" id="featCarousel">
    {carouselStories.map((s, i) => (
      <div class={`feat__slide${i === 0 ? ' is-on' : ''}`} data-slide={i}>
        <Placeholder
          alt={s.data.hero_alt}
          filenameHint={s.data.hero_filename_hint}
          aspect="21:9"
          showLabel={false}
          priority={i === 0}
          focal={s.data.hero_focal}
        />
        <div class="feat__overlay">
          <h2 class="feat__title">{s.data.title.toUpperCase()}</h2>
          <p class="feat__eyebrow">
            <AuthorAvatar name={s.data.author} size={22} variant="light" />
            <span>ISSUE №{s.data.issue} · BY {s.data.author.toUpperCase()} · {s.data.read_minutes}-MIN READ</span>
          </p>
          <a class="feat__cta" href={`/stories/${s.data.url_slug}`}>Read the Essay</a>
        </div>
      </div>
    ))}
    <div class="feat__dots" id="featDots">
      {carouselStories.map((s, i) => (
        <button class={`feat__dot${i === 0 ? ' is-on' : ''}`} data-dot={i} aria-label={`Slide ${i + 1}: ${s.data.title}`}></button>
      ))}
    </div>
  </div>

  <!-- EDITOR'S PARAGRAPH — Drift-style hyperlinked landing block.
       Each title is a link inline. Connective text comes from each story's
       own lede_line (preferred, hand-curated) or falls back to the first
       sentence of the deck. -->
  <section class="lede">
    <p class="lede__eyebrow">FROM THE EDITOR · WHAT WE'VE BEEN KEEPING</p>
    <p class="lede__text">
      {ledeStories.map((s) => {
        const clause = s.data.lede_line || (s.data.deck.split(/\.\s+/)[0] + '.');
        return (
          <>
            <a href={`/stories/${s.data.url_slug}`}>{s.data.title}</a>
            {' '}{clause}{' '}
          </>
        );
      })}
      <a href="/stories" class="lede__all">All {stories.length} issues →</a>
    </p>
  </section>

  <!-- SPONSORED ARTICLE SLOT · highlights an "In collaboration with" feature.
       Live state: shows the most recent story with a sponsor field set.
       Empty state: soft pitch promoting /partners. -->
  {sponsoredStory ? (
    <section class="sponsored sponsored--live" aria-label="Sponsored feature">
      <a class="sponsored__link" href={`/stories/${sponsoredStory.data.url_slug}`}>
        <div class="sponsored__media">
          <Placeholder
            alt={sponsoredStory.data.hero_alt}
            filenameHint={sponsoredStory.data.hero_filename_hint}
            aspect="16:9"
            showLabel={false}
            focal={sponsoredStory.data.hero_focal}
          />
        </div>
        <div class="sponsored__body-wrap">
          <p class="sponsored__chip">PARTNER FEATURE · IN COLLABORATION WITH {sponsoredStory.data.sponsor.name.toUpperCase()}</p>
          <h2 class="sponsored__title">{sponsoredStory.data.title}</h2>
          <p class="sponsored__deck">{sponsoredStory.data.deck}</p>
          <div class="sponsored__cta-row">
            <span class="sponsored__cta">READ THE FEATURE →</span>
            <span class="sponsored__byline">ISSUE №{sponsoredStory.data.issue} · BY {sponsoredStory.data.author.toUpperCase()} · {sponsoredStory.data.read_minutes}-MIN READ</span>
          </div>
          <p class="sponsored__firewall">EDITORIAL FIREWALL: SPONSOR APPROVED FACTS, NOT ANGLE. EDITOR WROTE EVERY WORD.</p>
        </div>
      </a>
    </section>
  ) : (
    <section class="sponsored" aria-label="Sponsored article slot">
      <div class="sponsored__inner">
        <p class="sponsored__chip">PARTNER FEATURE · SLOT OPEN</p>
        <h2 class="sponsored__title">YOUR STORY HERE.<br>WRITTEN BY US.<br>READ EVERY SATURDAY.</h2>
        <p class="sponsored__body">This is where a sponsored Profile sits when a partner books it. Same column width, same editorial voice, same Saturday readers. Marked in collaboration, never disguised.</p>
        <div class="sponsored__cta-row">
          <a class="sponsored__cta" href="/partners#stories">CLAIM THIS SLOT →</a>
        </div>
      </div>
    </section>
  )}

  <!-- KEEPERS VERTICAL BLOCK -->
  <a href={`/stories/${bodyStory.data.url_slug}`} class="vbar" style="text-decoration:none;">
    <div class="vbar__brand">KEEPERS</div>
    <div class="vbar__copy">
      <p>{bodyText}</p>
      <p style="margin-top:18px; font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:rgba(244,241,234,0.6);">{(bodyStory.data.pull_quote_attr || bodyStory.data.author).toUpperCase()} · ISSUE №{bodyStory.data.issue} →</p>
    </div>
    <div class="vbar__img">
      <Placeholder alt={bodyStory.data.hero_alt} filenameHint={bodyStory.data.hero_filename_hint} aspect="4:5" showLabel={false} focal={bodyStory.data.hero_focal} />
    </div>
  </a>

  <!-- ARCHIVE STRIP — clean horizontal scroll of past issues -->
  <section class="archive">
    <div class="archive__head">
      <div>
        <p class="archive__label">THE ARCHIVE</p>
        <p class="archive__sub">{stories.length} issues · Next saturday: {thisSatLabel.toLowerCase()}</p>
      </div>
      <a class="archive__viewall" href="/stories">VIEW ALL →</a>
    </div>
    <div class="archive__strip">
      {stories.slice(0, 10).map((s) => (
        <a class="archive__item" href={`/stories/${s.data.url_slug}`}>
          <div class="archive__media">
            <Placeholder alt={s.data.hero_alt} filenameHint={s.data.hero_filename_hint} aspect="4:5" showLabel={false} focal={s.data.hero_focal} />
          </div>
          <p class="archive__meta">ISSUE №{s.data.issue} · {fmtSat(new Date(s.data.published))}</p>
          <p class="archive__title">{s.data.title}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- CLASSIFIEDS · six text-only sponsor lines, alphabetized.
       Maps to "The Classified" tier in /partners. Editorial typography,
       no banners, no logos. Empty slots advertise themselves. -->
  <section class="classifieds" aria-label="Classified sponsor mentions">
    <p class="classifieds__label">CLASSIFIEDS · SATURDAY №{nextIssue}</p>
    <ul class="classifieds__list">
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">Claim a classified for this Saturday, $149.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">One line, six slots, alphabetized by sponsor.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">No logos, no banners, just your name.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">Lives forever on this Saturday's archive page.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">See work with us for the full lineup of partner tiers.</a></span></li>
      <li class="cls cls--open"><span class="cls__name">[ SLOT OPEN ]</span> <span class="cls__line"><a href="/partners#saturday">Book before Thursday at 5pm for this Saturday's letter.</a></span></li>
    </ul>
    <p class="classifieds__foot"><a href="/partners#saturday">See all partner tiers →</a></p>
  </section>

</ExhibitionLayout>

<style>
  /* === TAGLINE (under masthead, above carousel) === */
  .ex-tagline {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    padding: 0 12px;
    margin: 0 0 24px;
  }

  /* === FEATURED CAROUSEL === */
  .feat { position: relative; margin: 12px 12px 0; aspect-ratio: 24/10; overflow: hidden; background: #2a2520; }
  .feat__slide { position: absolute; inset: 0; opacity: 0; transition: opacity 500ms; pointer-events: none; }
  .feat__slide.is-on { opacity: 1; pointer-events: auto; }
  /* Placeholder renders the img in its own component scope, so target it
     globally to make sure each slide's image fills the carousel container. */
  .feat__slide :global(.real-image),
  .feat__slide :global(.placeholder),
  .feat__slide :global(img) {
    width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block;
  }
  .feat__overlay {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center; padding: 24px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0.4) 60%, rgba(0,0,0,0.65) 100%);
  }
  .feat__title { color: #fff; font-family: var(--ui); font-size: clamp(22px, 2.6vw, 36px); font-weight: 500; line-height: 1.1; letter-spacing: 0.02em; margin: 0 0 18px; max-width: 70%; text-shadow: 0 2px 12px rgba(0,0,0,0.5); }
  .feat__eyebrow { color: rgba(255,255,255,0.85); font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.55); width: 320px; margin: 0 0 22px; display: flex; align-items: center; gap: 10px; justify-content: center; }
  .feat__cta { color: #fff; font-size: 12px; letter-spacing: 0.04em; padding-bottom: 2px; border-bottom: 1px solid rgba(255,255,255,0.7); transition: opacity 150ms; }
  .feat__cta:hover { opacity: 0.7; }
  .feat__dots { position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 3; }
  .feat__dot { width: 24px; height: 2px; background: rgba(255,255,255,0.4); cursor: pointer; transition: background 150ms; }
  .feat__dot.is-on { background: #fff; }

  /* === EDITOR'S PARAGRAPH (Drift-style hyperlinked lede) === */
  .lede { padding: 80px 24px 72px; max-width: 880px; margin: 0 auto; }
  .lede__eyebrow { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin: 0 0 32px; padding-bottom: 14px; border-bottom: 1px solid var(--rule); }
  .lede__text {
    font-family: var(--ui);
    font-size: clamp(17px, 1.6vw, 21px);
    line-height: 1.65;
    letter-spacing: 0;
    color: var(--ink);
    margin: 0;
    text-wrap: pretty;
  }
  .lede__text a {
    color: var(--ink);
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 1px;
    transition: border-bottom-width 180ms ease, opacity 180ms;
  }
  .lede__text a:hover { border-bottom-width: 2px; opacity: 0.7; }
  .lede__text .lede__all {
    display: inline-block;
    margin-top: 8px;
    font-weight: 600;
    border-bottom: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 13px;
  }
  .lede__text .lede__all:hover { opacity: 0.7; }

  /* === VERTICAL BLOCK === */
  /* KEEPERS wordmark sits in its own column. Font cap and column width
     are paired so the brand never bleeds into the copy column. */
  .vbar { display: grid; grid-template-columns: 360px 1.1fr 1.4fr; margin: 64px 0 0; background: var(--ink); color: var(--paper); min-height: 360px; overflow: hidden; }
  .vbar__brand { font-family: var(--display); font-size: clamp(40px, 4.4vw, 62px); line-height: 1; text-transform: uppercase; align-self: center; padding-left: 32px; letter-spacing: -0.01em; white-space: nowrap; }
  .vbar__copy { padding: 64px 36px; font-size: 14px; line-height: 1.55; color: rgba(244,241,234,0.92); align-self: center; max-width: 36ch; min-width: 0; }
  .vbar__img { background: #2a2520; overflow: hidden; }
  .vbar__img :global(.real-image), .vbar__img :global(.placeholder) { width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block; }

  /* === ARCHIVE STRIP === */
  /* Replaces the awkward cal+strip pair. Horizontal scroll of past issues,
     small photo + meta + title. Clean, no vertical text, no dead zones. */
  .archive { background: var(--paper); padding: 64px 12px 80px; }
  .archive__head { display: flex; align-items: flex-end; justify-content: space-between; margin: 0 0 28px; gap: 24px; }
  .archive__label { font-family: var(--display); font-size: clamp(28px, 3.4vw, 48px); line-height: 1; letter-spacing: -0.005em; text-transform: uppercase; color: var(--ink); margin: 0 0 6px; }
  .archive__sub { font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); margin: 0; }
  .archive__viewall { font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink); padding-bottom: 2px; border-bottom: 1px solid currentColor; transition: opacity 200ms; flex-shrink: 0; }
  .archive__viewall:hover { opacity: 0.6; }
  .archive__strip { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 14px; scroll-behavior: smooth; }
  .archive__strip::-webkit-scrollbar { height: 4px; }
  .archive__strip::-webkit-scrollbar-track { background: var(--paper-2); }
  .archive__strip::-webkit-scrollbar-thumb { background: var(--rule); }
  .archive__item { flex: 0 0 auto; width: clamp(180px, 18vw, 220px); scroll-snap-align: start; color: var(--ink); transition: opacity 200ms; }
  .archive__item:hover { opacity: 0.85; }
  .archive__media { background: #2a2520; aspect-ratio: 4/5; overflow: hidden; margin-bottom: 12px; }
  .archive__media :global(.real-image), .archive__media :global(.placeholder) { width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block; transition: transform 500ms; }
  .archive__item:hover .archive__media :global(.real-image) { transform: scale(1.05); }
  .archive__meta { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted); margin: 0 0 4px; }
  .archive__title { font-size: 13px; line-height: 1.3; font-weight: 600; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  /* === PRESENTED BY STRIP === */
  .presented {
    display: flex; flex-wrap: wrap; align-items: center; gap: 12px;
    padding: 14px 24px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--rule);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--ink);
  }
  .presented__label { font-weight: 700; text-transform: uppercase; }
  .presented__divider { color: var(--muted); }
  .presented__slot { color: var(--ink); }
  .presented__slot a {
    color: #d9551f;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    margin-left: 6px;
  }
  .presented__slot a:hover { opacity: 0.7; }

  /* === SPONSORED ARTICLE SLOT === */
  /* Two states:
     - Empty slot: bordered card with soft-pitch CTA to /partners.
     - Live state: photo + copy split, in collaboration with [SPONSOR] chip. */
  .sponsored { padding: 0 12px 0; margin: 0 0 56px; }
  .sponsored__inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 48px 40px;
    border: 1px solid var(--rule);
    background: var(--paper-2);
    position: relative;
  }
  .sponsored__chip {
    background: var(--ink); color: var(--paper);
    padding: 5px 14px;
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    margin: 0;
    display: inline-block;
  }
  .sponsored__inner > .sponsored__chip {
    position: absolute; top: -10px; left: 28px;
  }
  .sponsored__title {
    font-family: var(--display);
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    margin: 0 0 18px;
    color: var(--ink);
  }
  .sponsored__body {
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink);
    margin: 0 0 24px;
    max-width: 52ch;
  }
  .sponsored__deck {
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 24px;
    max-width: 52ch;
  }
  .sponsored__cta-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding-top: 18px;
    border-top: 1px solid var(--rule);
    flex-wrap: wrap;
  }
  .sponsored__cta {
    color: var(--ink);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
  }
  .sponsored__cta:hover { opacity: 0.7; }
  .sponsored__byline {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Live state (article booked) — photo + copy split */
  .sponsored--live { padding: 0; margin: 0 0 64px; }
  .sponsored--live .sponsored__link {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    max-width: 1200px;
    margin: 0 auto;
    border-block: 1px solid var(--rule);
    color: var(--ink);
    transition: opacity 200ms;
  }
  .sponsored--live .sponsored__link:hover { opacity: 0.9; }
  @media (max-width: 880px) { .sponsored--live .sponsored__link { grid-template-columns: 1fr; } }
  .sponsored__media { background: #2a2520; aspect-ratio: 16/9; overflow: hidden; position: relative; }
  .sponsored__media :global(.real-image), .sponsored__media :global(.placeholder) {
    width: 100%; height: 100%; object-fit: cover; aspect-ratio: auto !important; display: block;
  }
  .sponsored__body-wrap {
    padding: 36px 40px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: var(--paper-2);
  }
  .sponsored--live .sponsored__chip { align-self: flex-start; margin-bottom: 4px; }
  .sponsored--live .sponsored__title { font-size: clamp(28px, 3.2vw, 42px); margin: 0; text-transform: uppercase; }
  .sponsored--live .sponsored__deck { margin: 0; }
  .sponsored--live .sponsored__cta-row { margin-top: auto; }
  .sponsored__firewall {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
  }

  /* === CLASSIFIEDS STRIP === */
  .classifieds {
    max-width: 1080px;
    margin: 24px auto 80px;
    padding: 32px 24px;
    border-block: 1px solid var(--rule);
  }
  .classifieds__label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--rule);
  }
  .classifieds__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 32px;
  }
  @media (max-width: 720px) { .classifieds__list { grid-template-columns: 1fr; } }
  .cls {
    display: flex;
    gap: 10px;
    align-items: baseline;
    padding: 6px 0;
    font-size: 13px;
    line-height: 1.45;
  }
  .cls__name {
    font-weight: 700;
    color: var(--ink);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    font-size: 11px;
  }
  .cls--open .cls__name { color: var(--muted); }
  .cls__line { color: var(--ink); }
  .cls--open .cls__line { color: var(--muted); font-style: italic; }
  .cls__line a {
    color: inherit;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .cls__line a:hover { color: var(--ink); }
  .classifieds__foot {
    margin: 18px 0 0;
    padding-top: 14px;
    border-top: 1px solid var(--rule);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .classifieds__foot a {
    color: var(--ink);
    font-weight: 600;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }

  @media (max-width: 980px) {
    .lede__text { font-size: clamp(20px, 4.2vw, 28px); }
    .vbar { grid-template-columns: 1fr; }
    .vbar__brand { padding: 32px 24px 0; }
    .vbar__copy { padding: 24px; }
    .archive__head { flex-direction: column; align-items: flex-start; gap: 8px; }
    .sponsored__inner { padding: 40px 28px; }
  }
</style>

<script is:inline>
  // Hero carousel, auto-rotate every 6s, dot click jumps to slide
  (function () {
    const car = document.getElementById('featCarousel');
    const dots = document.getElementById('featDots');
    if (!car || !dots) return;
    const slides = car.querySelectorAll('.feat__slide');
    const dotEls = dots.querySelectorAll('.feat__dot');
    let i = 0;
    let timer;
    function show(n) {
      slides.forEach((s, idx) => s.classList.toggle('is-on', idx === n));
      dotEls.forEach((d, idx) => d.classList.toggle('is-on', idx === n));
      i = n;
    }
    function next() { show((i + 1) % slides.length); }
    function start() {
      stop();
      // WCAG 2.3.3 — respect prefers-reduced-motion. Dots still work for manual nav.
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      timer = setInterval(next, 6000);
    }
    function stop() { if (timer) clearInterval(timer); }
    dotEls.forEach((d, idx) => d.addEventListener('click', () => { show(idx); start(); }));
    car.addEventListener('mouseenter', stop);
    car.addEventListener('mouseleave', start);
    start();
  })();
</script>
